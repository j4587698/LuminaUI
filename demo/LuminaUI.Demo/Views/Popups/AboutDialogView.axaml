<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="LuminaUI.Demo.Views.Popups.AboutDialogView"
             x:Name="Root">
             
    <StackPanel Spacing="16" Margin="24" MinWidth="320">
        <!-- Brand logo -->
        <Image Source="avares://LuminaUI.Demo/Assets/logo.png" 
               Width="64" Height="64" 
               HorizontalAlignment="Center" />

        <!-- App Name -->
        <TextBlock Text="Lumina UI Framework"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <!-- Description -->
        <TextBlock Text="{l10n:Loc Sandbox.Popups.About.Description}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Opacity="0.8" />

        <!-- Version Info -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="{Binding AppVersion, ElementName=Root}" Opacity="0.6" />
            <TextBlock Text="•" Opacity="0.4" />
            <TextBlock Text="Avalonia 12" Opacity="0.6" />
        </StackPanel>
    </StackPanel>
</UserControl>
