<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.WindowDialogShowcasePage"
             x:DataType="vm:WindowDialogShowcaseViewModel">

  <ScrollViewer x:Name="PageScroll" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="24" Width="{Binding #PageScroll.Bounds.Width}" Margin="0,0,0,24">
      
      <!-- Header -->
      <StackPanel Spacing="8" MaxWidth="760">
        <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.Title}" Classes="Display"/>
        <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.Description}"
                   Classes="Body" Foreground="{DynamicResource LuminaTextSecondaryBrush}" TextWrapping="Wrap"/>
      </StackPanel>

      <lumina:LuminaResponsivePanel MinItemWidth="280" MaxItemWidth="520" HorizontalSpacing="16" VerticalSpacing="16">
        
        <!-- Standard Message Boxes -->
        <lumina:LuminaCard Padding="18" Classes="Glass">
          <StackPanel Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.StandardMessageBox}" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.StandardMessageBoxDesc}"
                         Foreground="{DynamicResource LuminaTextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnOkCancel}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowOkCancelCommand}"/>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnYesNo}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowYesNoCommand}"/>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnYesNoCancel}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowYesNoCancelCommand}"/>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnDanger}" Classes="Outline Danger" Margin="0,0,10,10"
                      Command="{Binding ShowDangerCommand}"/>
            </WrapPanel>
            
            <TextBlock Text="{Binding MessageBoxResultText}" Foreground="{DynamicResource LuminaTextSecondaryBrush}"/>
          </StackPanel>
        </lumina:LuminaCard>

        <!-- Custom Content / Form Input -->
        <lumina:LuminaCard Padding="18" Classes="Glass">
          <StackPanel Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.FormInputSelect}" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.FormInputSelectDesc}"
                         Foreground="{DynamicResource LuminaTextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnSelectOptions}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowSelectDialogCommand}"/>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnDataEntry}" Classes="Primary" Margin="0,0,10,10"
                      Command="{Binding ShowFormDialogCommand}"/>
            </WrapPanel>
            
            <TextBlock Text="{Binding CustomResultText}" Foreground="{DynamicResource LuminaTextSecondaryBrush}"/>
          </StackPanel>
        </lumina:LuminaCard>

        <!-- Fully Custom Footer & No Footer -->
        <lumina:LuminaCard Padding="18" Classes="Glass">
          <StackPanel Spacing="16">
            <StackPanel Spacing="6">
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.CustomFooter}" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="{l10n:Loc Sandbox.Popups.WindowDialogs.CustomFooterDesc}"
                         Foreground="{DynamicResource LuminaTextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>

            <WrapPanel>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnCustomFooter}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowCustomFooterCommand}"/>
              <Button Content="{l10n:Loc Sandbox.Popups.WindowDialogs.BtnNoFooter}" Classes="Outline" Margin="0,0,10,10"
                      Command="{Binding ShowNoFooterCommand}"/>
            </WrapPanel>
          </StackPanel>
        </lumina:LuminaCard>

      </lumina:LuminaResponsivePanel>
    </StackPanel>
  </ScrollViewer>
</ContentPage>
