<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.SandboxRootView"
             x:Name="RootView">
    <!-- Root TopView provides safe-area insets and application-level overlays for the shell. -->
    <lumina:LuminaTopView x:Name="RootTopView"
                           TopViewKey="SandboxRoot">
        <Grid>
            <lumina:LuminaShell x:Name="AppShell"
                                ShellKey="Sandbox"
                                DefaultPageTitle="{l10n:Loc Sandbox.Shell.Title}"
                                IsWindowGlassEnabled="{Binding $parent[lumina:LuminaWindow].IsWindowGlassEnabled, FallbackValue=False}">
                <lumina:LuminaShell.MenuHeader>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="avares://LuminaUI.Demo/Assets/logo.png" Width="24" Height="24" />
                            <TextBlock Text="Lumina UI"
                                       FontSize="20"
                                       FontWeight="Black"
                                       Foreground="{DynamicResource LuminaTextForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </lumina:LuminaShell.MenuHeader>

                <lumina:LuminaShell.MenuFooter>
                    <lumina:LuminaCard Padding="12"
                                       Margin="0"
                                       Background="{DynamicResource LuminaNavigationPaneItemBrush}"
                                       BorderThickness="0"
                                       Classes="Interactive">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource LuminaBorderBrush}" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{l10n:Loc Sandbox.User.Name}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                                <TextBlock Text="{l10n:Loc Sandbox.Text.1175}"
                                           FontSize="12"
                                           Foreground="{DynamicResource LuminaTextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </lumina:LuminaCard>
                </lumina:LuminaShell.MenuFooter>

                <lumina:LuminaShell.MenuContent>
                    <lumina:LuminaNavigationView Name="AppNavView"
                                                 SelectedKey="{Binding #AppShell.ActiveNavigationKey, Mode=TwoWay}">
                        <lumina:LuminaNavigationItem Name="NavDesignSystem" Header="{l10n:Loc Sandbox.Nav.DesignSystem}" Icon="DS" />
                        <lumina:LuminaNavigationItem Name="NavLocalizationResources" Header="{l10n:Loc Sandbox.Nav.LocalizationResources}" Icon="LR" />
                        <lumina:LuminaNavigationItem Name="NavColors" Header="{l10n:Loc Sandbox.Nav.Colors}" Icon="CL" />

                        <lumina:LuminaNavigationItem Name="NavFoundationGroup" Header="{l10n:Loc Sandbox.Nav.FoundationGroup}" Icon="Aa" IsExpanded="True">
                            <lumina:LuminaNavigationItem Name="NavFoundation" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Foundation}" Icon="Aa" />
                            <lumina:LuminaNavigationItem Name="NavCards" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Cards}" Icon="CA" />
                            <lumina:LuminaNavigationItem Name="NavGroupBox" Classes="Child" Header="{l10n:Loc Sandbox.Nav.GroupBox}" Icon="GB" />
                            <lumina:LuminaNavigationItem Name="NavImages" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Images}" Icon="IM" />
                            <lumina:LuminaNavigationItem Name="NavAvatarBadge" Classes="Child" Header="{l10n:Loc Sandbox.Nav.AvatarBadge}" Icon="AB" />
                            <lumina:LuminaNavigationItem Name="NavButtons" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Buttons}" Icon="BT" />
                            <lumina:LuminaNavigationItem Name="NavButtonGroup" Classes="Child" Header="{l10n:Loc Sandbox.Nav.ButtonGroup}" Icon="BG" />
                            <lumina:LuminaNavigationItem Name="NavAutoCompleteBox" Classes="Child" Header="{l10n:Loc Sandbox.Nav.AutoCompleteBox}" Icon="AB" />
                            <lumina:LuminaNavigationItem Name="NavDropDownButton" Classes="Child" Header="{l10n:Loc Sandbox.Nav.DropDownButton}" Icon="DB" />
                            <lumina:LuminaNavigationItem Name="NavSplitButton" Classes="Child" Header="{l10n:Loc Sandbox.Nav.SplitButton}" Icon="SB" />
                            <lumina:LuminaNavigationItem Name="NavCommandBar" Classes="Child" Header="{l10n:Loc Sandbox.Nav.CommandBar}" Icon="CB" />
                        </lumina:LuminaNavigationItem>

                        <lumina:LuminaNavigationItem Name="NavLayoutGroup" Header="{l10n:Loc Sandbox.Nav.LayoutGroup}" Icon="LY">
                            <lumina:LuminaNavigationItem Name="NavHeaderedContentControl" Classes="Child" Header="{l10n:Loc Sandbox.Nav.HeaderedContentControl}" Icon="HC" />
                            <lumina:LuminaNavigationItem Name="NavItemsControl" Classes="Child" Header="{l10n:Loc Sandbox.Nav.ItemsControl}" Icon="IC" />
                            <lumina:LuminaNavigationItem Name="NavVirtualizingWrapView" Classes="Child" Header="{l10n:Loc Sandbox.Nav.VirtualizingWrapView}" Icon="VW" />
                            <lumina:LuminaNavigationItem Name="NavSplitView" Classes="Child" Header="{l10n:Loc Sandbox.Nav.SplitView}" Icon="SV" />
                            <lumina:LuminaNavigationItem Name="NavNavigationPage" Classes="Child" Header="{l10n:Loc Sandbox.Nav.NavigationPage}" Icon="NP" />
                            <lumina:LuminaNavigationItem Name="NavDrawerPage" Classes="Child" Header="{l10n:Loc Sandbox.Nav.DrawerPage}" Icon="DP" />
                            <lumina:LuminaNavigationItem Name="NavTabbedPage" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TabbedPage}" Icon="TP" />
                            <lumina:LuminaNavigationItem Name="NavCarousel" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Carousel}" Icon="CR" />
                            <lumina:LuminaNavigationItem Name="NavTransitioningContentControl" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TransitioningContentControl}" Icon="TC" />
                            <lumina:LuminaNavigationItem Name="NavBreadcrumb" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Breadcrumb}" Icon="BR" />
                            <lumina:LuminaNavigationItem Name="NavTabStrip" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TabStrip}" Icon="TS" />
                            <lumina:LuminaNavigationItem Name="NavTabControl" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TabControl}" Icon="TC" />
                            <lumina:LuminaNavigationItem Name="NavTabsExpanders" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TabsExpanders}" Icon="TE" />
                        </lumina:LuminaNavigationItem>

                        <lumina:LuminaNavigationItem Name="NavDataEntryGroup" Header="{l10n:Loc Sandbox.Nav.DataEntryGroup}" Icon="TX">
                            <lumina:LuminaNavigationItem Name="NavTextInputs" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TextInputs}" Icon="TX" />
                            <lumina:LuminaNavigationItem Name="NavInputOtp" Classes="Child" Header="{l10n:Loc Sandbox.Nav.InputOtp}" Icon="OTP" />
                            <lumina:LuminaNavigationItem Name="NavForm" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Form}" Icon="FM" />
                            <lumina:LuminaNavigationItem Name="NavMultiSelect" Classes="Child" Header="{l10n:Loc Sandbox.Nav.MultiSelect}" Icon="MS" />
                            <lumina:LuminaNavigationItem Name="NavTagInput" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TagInput}" Icon="TI" />
                            <lumina:LuminaNavigationItem Name="NavCascader" Classes="Child" Header="{l10n:Loc Sandbox.Text.1134}" Icon="CA" />
                            <lumina:LuminaNavigationItem Name="NavSelection" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Selection}" Icon="SE" />
                            <lumina:LuminaNavigationItem Name="NavPickers" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Pickers}" Icon="PK" />
                            <lumina:LuminaNavigationItem Name="NavColorPicker" Classes="Child" Header="{l10n:Loc Sandbox.Nav.ColorPicker}" Icon="CP" />
                            <lumina:LuminaNavigationItem Name="NavDateRangePicker" Classes="Child" Header="{l10n:Loc Sandbox.Nav.DateRangePicker}" Icon="DR" />
                            <lumina:LuminaNavigationItem Name="NavRange" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Range}" Icon="RG" />
                            <lumina:LuminaNavigationItem Name="NavRangeSlider" Classes="Child" Header="{l10n:Loc Sandbox.Nav.RangeSlider}" Icon="RS" />
                            <lumina:LuminaNavigationItem Name="NavRating" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Rating}" Icon="RT" />
                        </lumina:LuminaNavigationItem>

                        <lumina:LuminaNavigationItem Name="NavDataDisplayGroup" Header="{l10n:Loc Sandbox.Nav.DataDisplayGroup}" Icon="DG">
                            <lumina:LuminaNavigationItem Name="NavDescriptions" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Descriptions}" Icon="DE" />
                            <lumina:LuminaNavigationItem Name="NavProperties" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Properties}" Icon="PR" />
                            <lumina:LuminaNavigationItem Name="NavCollections" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Collections}" Icon="CO" />
                            <lumina:LuminaNavigationItem Name="NavDataGrid" Classes="Child" Header="{l10n:Loc Sandbox.Nav.DataGrid}" Icon="DG" />
                            <lumina:LuminaNavigationItem Name="NavTreeDataGrid" Classes="Child" Header="{l10n:Loc Sandbox.Nav.TreeDataGrid}" Icon="TG" />
                            <lumina:LuminaNavigationItem Name="NavAutoScrollText" Classes="Child" Header="{l10n:Loc Sandbox.Nav.AutoScrollText}" Icon="AT" />
                            <lumina:LuminaNavigationItem Name="NavIndexedList" Classes="Child" Header="{l10n:Loc Sandbox.Nav.IndexedList}" Icon="IL" />
                            <lumina:LuminaNavigationItem Name="NavLinkedCategory" Classes="Child" Header="{l10n:Loc Sandbox.Nav.LinkedCategory}" Icon="LC" />
                            <lumina:LuminaNavigationItem Name="NavPagination" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Pagination}" Icon="PG" />
                            <lumina:LuminaNavigationItem Name="NavTimeline" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Timeline}" Icon="TL" />
                            <lumina:LuminaNavigationItem Name="NavSteps" Classes="Child" Header="{l10n:Loc Sandbox.Text.1248}" Icon="ST" />
                            <lumina:LuminaNavigationItem Name="NavEmpty" Classes="Child" Header="{l10n:Loc Sandbox.Text.0808}" Icon="EM" />
                        </lumina:LuminaNavigationItem>

                        <lumina:LuminaNavigationItem Name="NavFeedbackGroup" Header="{l10n:Loc Sandbox.Nav.FeedbackGroup}" Icon="PC">
                            <lumina:LuminaNavigationItem Name="NavLoading" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Loading}" Icon="LD" />
                            <lumina:LuminaNavigationItem Name="NavLoadingContainer" Classes="Child" Header="{l10n:Loc Sandbox.Nav.LoadingContainer}" Icon="LC" />
                            <lumina:LuminaNavigationItem Name="NavBanner" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Banner}" Icon="BN" />
                            <lumina:LuminaNavigationItem Name="NavPopConfirm" Classes="Child" Header="{l10n:Loc Sandbox.Nav.PopConfirm}" Icon="PC" />
                            <lumina:LuminaNavigationItem Name="NavNotificationCard" Classes="Child" Header="{l10n:Loc Sandbox.Nav.NotificationCard}" Icon="PC" />
                        </lumina:LuminaNavigationItem>

                        <lumina:LuminaNavigationItem Name="NavPatternsGroup" Header="{l10n:Loc Sandbox.Nav.Patterns}" Icon="PT">
                            <lumina:LuminaNavigationItem Name="NavShell" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Shell}" Icon="SH" />
                            <lumina:LuminaNavigationItem Name="NavMenus" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Menus}" Icon="MN" />
                            <lumina:LuminaNavigationItem Name="NavOverlays" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Overlays}" Icon="OV" />
                            <lumina:LuminaNavigationItem Name="NavOverlayScope" Classes="Child" Header="{l10n:Loc Sandbox.Nav.OverlayScope}" Icon="OS" />
                            <lumina:LuminaNavigationItem Name="NavWindowDialogs" Classes="Child" Header="{l10n:Loc Sandbox.Nav.WindowDialogs}" Icon="WD" />
                            <lumina:LuminaNavigationItem Name="NavLayout" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Layout}" Icon="LY" />
                            <lumina:LuminaNavigationItem Name="NavMotion" Classes="Child" Header="{l10n:Loc Sandbox.Text.1313}" Icon="HM" />
                            <lumina:LuminaNavigationItem Name="NavMobileRoot" Classes="Child" Header="{l10n:Loc Sandbox.Text.0836}" Icon="MO" />
                            <lumina:LuminaNavigationItem Name="NavLogin" Classes="Child" Header="{l10n:Loc Sandbox.Nav.Login}" Icon="LG" />
                        </lumina:LuminaNavigationItem>

                        <Separator Margin="0,6" />
                        <lumina:LuminaNavigationItem Name="NavSettings" Header="{l10n:Loc Sandbox.Nav.Settings}" Icon="ST" />
                    </lumina:LuminaNavigationView>
                </lumina:LuminaShell.MenuContent>

                <lumina:LuminaShell.Title>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <lumina:LuminaHamburgerButton Grid.Column="0"
                                                       IsOpen="{Binding #AppShell.IsMenuOpen}"
                                                       IsVisible="{Binding #AppShell.EffectiveIsMenuCompact, Converter={x:Static BoolConverters.Not}}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding #AppShell.ActivePageTitle}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding #AppShell.ActivePageSubtitle}"
                                       FontSize="12"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       IsVisible="{Binding #AppShell.ActivePageSubtitle, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        </StackPanel>
                        <ContentPresenter Grid.Column="2"
                                          Content="{Binding #AppShell.ActivePageActions}"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding #AppShell.ActivePageActions, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Grid>
                </lumina:LuminaShell.Title>
            </lumina:LuminaShell>

            <ItemsControl ItemsSource="{Binding #RootView.NotificationCenter.Notifications}"
                          HorizontalAlignment="{Binding #RootView.NotificationCenter.HorizontalAlignment}"
                          VerticalAlignment="{Binding #RootView.NotificationCenter.VerticalAlignment}"
                          Margin="24,56,24,24"
                          MaxWidth="360"
                          ZIndex="2500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="14" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:SandboxNotificationItem">
                        <Border MinWidth="280"
                                MaxWidth="360"
                                Padding="14"
                                Background="{DynamicResource LuminaPopoverBrush}"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                BoxShadow="{DynamicResource LuminaShadowNotification}"
                                Cursor="Hand"
                                lumina:LuminaCommand.TappedCommand="{Binding CloseCommand}"
                                lumina:LuminaCommand.MarkHandled="True">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="{Binding AccentBrush}"
                                        VerticalAlignment="Top"
                                        Margin="0,5,0,0" />
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource LuminaTextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                                </StackPanel>
                                <PathIcon Grid.Column="2"
                                          Width="14"
                                          Height="14"
                                          Margin="8,3,0,0"
                                          VerticalAlignment="Top"
                                          Data="M6,6 L18,18 M18,6 L6,18"
                                          Foreground="{DynamicResource LuminaTextMutedBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </lumina:LuminaTopView>
</UserControl>
