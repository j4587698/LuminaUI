<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.ButtonGroupShowcasePage"
             x:DataType="vm:ButtonGroupShowcaseViewModel">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" Width="{Binding #PageScroll.Bounds.Width}" HorizontalAlignment="Stretch" Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.0107}" />
                <TextBlock Text="{l10n:Loc Sandbox.Text.0108}" Foreground="{DynamicResource LuminaTextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="280" MaxItemWidth="460" HorizontalSpacing="16" VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0142}" />
                        <lumina:LuminaButtonGroup SelectedIndex="{Binding SelectedDensityIndex}">
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0155}" />
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0156}" />
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0157}" />
                        </lumina:LuminaButtonGroup>
                        <TextBlock Text="{Binding DensityText}" Foreground="{DynamicResource LuminaTextMutedBrush}" />
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0109}" />
                        <lumina:LuminaButtonGroup SelectedIndex="{Binding SelectedBillingIndex}">
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0430}" />
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0431}" />
                            <lumina:LuminaButtonGroupItem Content="{l10n:Loc Sandbox.Text.0432}" />
                        </lumina:LuminaButtonGroup>
                        <TextBlock Text="{Binding BillingText}" Foreground="{DynamicResource LuminaTextMutedBrush}" />
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</lumina:LuminaPage>
