<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:views="using:LuminaUI.Demo.Views"
             x:Class="LuminaUI.Demo.Views.FloatingWindowShowcasePage"
             x:Name="Root">

  <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="24" Width="{Binding #PageScroll.Bounds.Width}" HorizontalAlignment="Stretch" Margin="0,36,0,40">

      <StackPanel Spacing="4">
        <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.FloatingWindow.Title}" />
        <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.Subtitle}"
                   Foreground="{DynamicResource LuminaTextMutedBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <lumina:LuminaResponsivePanel MinItemWidth="320" MaxItemWidth="560" HorizontalSpacing="16" VerticalSpacing="16">

        <!-- Overview -->
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.Overview}" />
            <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OverviewDesc}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
          </StackPanel>
        </lumina:LuminaCard>

        <!-- Features -->
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.Features}" />
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap"><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.FeatureLockedName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.FeatureLockedDesc}" /></TextBlock>
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap"><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.FeatureHoveredName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.FeatureHoveredDesc}" /></TextBlock>
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap"><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.FeatureDragName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.FeatureDragDesc}" /></TextBlock>
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap"><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.FeaturePositionName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.FeaturePositionDesc}" /></TextBlock>
              </Grid>
            </StackPanel>
          </StackPanel>
        </lumina:LuminaCard>

        <!-- Open Demo Button -->
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.DemoSection}" />
            <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.DemoDesc}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
            <Button Classes="Primary" x:Name="OpenDemoButton" Click="OnOpenDemo">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <icons:MaterialIcon Kind="WindowRestore" Width="18" Height="18" Foreground="{DynamicResource LuminaPrimaryForegroundBrush}" />
                <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OpenDemo}" />
              </StackPanel>
            </Button>
          </StackPanel>
        </lumina:LuminaCard>

        <!-- Code Example -->
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.Usage}" />
            <Border Padding="16"
                    Background="{DynamicResource LuminaSurfaceBrush}"
                    BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
              <StackPanel Spacing="8">
                <TextBlock FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.Step1}" />
                <Border Padding="12"
                        Background="{DynamicResource LuminaHoverBackgroundBrush}"
                        CornerRadius="6">
                  <StackPanel Spacing="2" TextElement.FontFamily="Consolas" TextElement.FontSize="12">
                    <TextBlock Text="&lt;lumina:LuminaFloatingWindow" />
                    <TextBlock Text="    Width=&quot;800&quot; Height=&quot;160&quot;" />
                    <TextBlock Text="    WindowDecorations=&quot;None&quot;" />
                    <TextBlock Text="    Topmost=&quot;True&quot;" />
                    <TextBlock Text="    ShowInTaskbar=&quot;False&quot;" />
                    <TextBlock Text="    TransparencyLevelHint=&quot;Transparent&quot;" />
                    <TextBlock Text="    x:Class=&quot;MyApp.LyricsWindow&quot;&gt;" />
                    <TextBlock Text="  &lt;!-- 你的内容 --&gt;" />
                    <TextBlock Text="&lt;/lumina:LuminaFloatingWindow&gt;" />
                  </StackPanel>
                </Border>
                <TextBlock FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.Step2}" />
                <Border Padding="12"
                        Background="{DynamicResource LuminaHoverBackgroundBrush}"
                        CornerRadius="6">
                    <StackPanel Spacing="2" TextElement.FontFamily="Consolas" TextElement.FontSize="12">
                      <TextBlock Text="// 开窗时定位到底部" />
                      <TextBlock Text="protected override void OnOpened(EventArgs e)" />
                      <TextBlock Text="{} {" />
                      <TextBlock Text="    base.OnOpened(e);" />
                      <TextBlock Text="    PositionAtScreenBottom();" />
                      <TextBlock Text="    UpdatePassthroughState();" />
                      <TextBlock Text="{} }" />
                      <TextBlock Text="" />
                      <TextBlock Text="// 拖拽事件中调用" />
                      <TextBlock Text="private void OnDrag(object? s, PointerPressedEventArgs e)" />
                      <TextBlock Text="{} {" />
                      <TextBlock Text="    BeginDrag(e);" />
                      <TextBlock Text="{} }" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>
          </StackPanel>
        </lumina:LuminaCard>

      </lumina:LuminaResponsivePanel>

      <!-- KaraokeTextBlock Section -->
      <StackPanel Spacing="4" Margin="0,12,0,0">
        <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.FloatingWindow.KaraokeTitle}" />
        <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.KaraokeSubtitle}"
                   Foreground="{DynamicResource LuminaTextMutedBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <lumina:LuminaResponsivePanel MinItemWidth="320" MaxItemWidth="560" HorizontalSpacing="16" VerticalSpacing="16">
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.KaraokeDemo}" />
            <Border Padding="20"
                    Background="{DynamicResource LuminaSurfaceBrush}"
                    BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MinHeight="80">
              <lumina:LuminaKaraokeTextBlock x:Name="KaraokeDemo"
                                             Words="{Binding KaraokeWords, ElementName=Root}"
                                             PlaybackPosition="{Binding KaraokePosition, ElementName=Root}"
                                             FontSize="36"
                                             FontWeight="Black"
                                             SungBrush="{DynamicResource LuminaPrimaryBrush}"
                                             UnsungBrush="{DynamicResource LuminaTextMutedBrush}"
                                             StrokeBrush="#66000000"
                                             StrokeThickness="1.5"
                                             TextAlignment="Center"
                                             HorizontalAlignment="Stretch" />
            </Border>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
              <Button x:Name="KaraokePlayButton" Classes="Primary Icon" Width="36" Height="36" Padding="0"
                      Click="OnKaraokeToggle" lumina:LuminaButton.IconSize="20"
                      ToolTip.Tip="{l10n:Loc Sandbox.FloatingWindow.PlayPause}">
                <lumina:LuminaButton.Icon>
                  <icons:MaterialIcon x:Name="KaraokePlayIcon" Kind="Play" Width="20" Height="20"
                                      Foreground="{DynamicResource LuminaPrimaryForegroundBrush}" />
                </lumina:LuminaButton.Icon>
              </Button>
              <Slider Grid.Column="1" x:Name="KaraokeSlider" Minimum="0" Maximum="4" Value="{Binding KaraokePosition, ElementName=Root}"
                      VerticalAlignment="Center" />
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Classes="Ghost Icon" Width="28" Height="28" Padding="0" Click="OnKaraokeReset"
                        ToolTip.Tip="{l10n:Loc Sandbox.FloatingWindow.Reset}" lumina:LuminaButton.IconSize="16">
                  <lumina:LuminaButton.Icon>
                    <icons:MaterialIcon Kind="Restart" Width="16" Height="16" Foreground="{DynamicResource LuminaTextMutedBrush}" />
                  </lumina:LuminaButton.Icon>
                </Button>
              </StackPanel>
            </Grid>
            <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.KaraokeText}"
                       FontSize="12"
                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                       TextAlignment="Center" />
          </StackPanel>
        </lumina:LuminaCard>

        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.Properties}" />
            <StackPanel Spacing="6">
              <TextBlock><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.PropWordsName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.PropWordsDesc}" /></TextBlock>
              <TextBlock><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.PropPositionName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.PropPositionDesc}" /></TextBlock>
              <TextBlock><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.PropBrushesName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.PropBrushesDesc}" /></TextBlock>
              <TextBlock><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.PropStrokeName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.PropStrokeDesc}" /></TextBlock>
              <TextBlock><Run FontWeight="Bold" Text="{l10n:Loc Sandbox.FloatingWindow.PropFontName}" /><Run Text="{l10n:Loc Sandbox.FloatingWindow.PropFontDesc}" /></TextBlock>
            </StackPanel>
          </StackPanel>
        </lumina:LuminaCard>

        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.DataModel}" />
            <Border Padding="12"
                    Background="{DynamicResource LuminaHoverBackgroundBrush}"
                    CornerRadius="6">
              <StackPanel Spacing="2" TextElement.FontFamily="Consolas" TextElement.FontSize="12">
                <TextBlock Text="public class LuminaKaraokeWord" />
                <TextBlock Text="{} {" />
                <TextBlock Text="{}     public string Text { get; }" />
                <TextBlock Text="{}     public double StartTime { get; }" />
                <TextBlock Text="{}     public double Duration { get; }" />
                <TextBlock Text="{} }" />
              </StackPanel>
            </Border>
          </StackPanel>
        </lumina:LuminaCard>
      </lumina:LuminaResponsivePanel>

      <!-- OutlinedTextBlock Section -->
      <StackPanel Spacing="4" Margin="0,12,0,0">
        <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedTitle}" />
        <TextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedSubtitle}"
                   Foreground="{DynamicResource LuminaTextMutedBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <lumina:LuminaResponsivePanel MinItemWidth="320" MaxItemWidth="560" HorizontalSpacing="16" VerticalSpacing="16">
        <lumina:LuminaCard>
          <StackPanel Spacing="16">
            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedDemo}" />
            <Border Padding="16"
                    Background="{DynamicResource LuminaSurfaceBrush}"
                    BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
              <StackPanel Spacing="16">
                <lumina:LuminaOutlinedTextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedSample1}"
                                                FontSize="32"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource LuminaPrimaryBrush}"
                                                Stroke="#66000000"
                                                StrokeThickness="1.5"
                                                TextAlignment="Center" />
                <lumina:LuminaOutlinedTextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedSample2}"
                                                FontSize="20"
                                                Foreground="{DynamicResource LuminaTextSecondaryBrush}"
                                                Stroke="#44000000"
                                                StrokeThickness="1"
                                                TextAlignment="Center" />
                <lumina:LuminaOutlinedTextBlock Text="{l10n:Loc Sandbox.FloatingWindow.OutlinedSample3}"
                                                FontSize="16"
                                                Foreground="{DynamicResource LuminaTextForegroundBrush}"
                                                Stroke="#33000000"
                                                StrokeThickness="0.8"
                                                TextWrapping="Wrap"
                                                MaxLines="3" />
              </StackPanel>
            </Border>
          </StackPanel>
        </lumina:LuminaCard>
      </lumina:LuminaResponsivePanel>

    </StackPanel>
  </ScrollViewer>
</lumina:LuminaPage>