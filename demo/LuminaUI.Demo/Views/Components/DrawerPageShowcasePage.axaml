<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.DrawerPageShowcasePage"
             x:DataType="vm:DrawerPageShowcaseViewModel">
    <ScrollViewer Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" HorizontalAlignment="Stretch" Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.1153}" />
                <TextBlock Classes="Body" Text="{l10n:Loc Sandbox.Text.0766}" TextWrapping="Wrap" />
            </StackPanel>
            <lumina:LuminaResponsivePanel MinItemWidth="320" MaxItemWidth="720" HorizontalSpacing="16" VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.1153}" />
                            <ToggleButton Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="{l10n:Loc Sandbox.Text.0212}"
                                          IsChecked="{Binding IsDrawerOpen, Mode=TwoWay}" />
                        </Grid>
                        <WrapPanel>
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Text.0359}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Left}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Text.0051}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Right}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Text.0360}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Top}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Text.0361}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Bottom}" />
                        </WrapPanel>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <TextBlock Text="DrawerLength" VerticalAlignment="Center" Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                            <Slider Grid.Column="1"
                                    Minimum="140"
                                    Maximum="280"
                                    Value="{Binding DrawerLength, Mode=TwoWay}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DrawerLength, StringFormat='{}{0:0}px'}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}" />
                        </Grid>

                        <Border Height="320"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="False">
                            <lumina:LuminaTopView Name="DrawerPreviewHost"
                                                  IsDrawerOpen="{Binding IsDrawerOpen, Mode=TwoWay}"
                                                  Background="{DynamicResource LuminaBackgroundBrush}">
                                <lumina:LuminaTopView.DrawerContent>
                                    <lumina:LuminaDrawer Placement="{Binding DrawerPlacement}"
                                                         DrawerLength="{Binding DrawerLength}"
                                                         ContentPadding="18">
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Text.0357}" />
                                                <TextBlock Classes="Helper"
                                                           Text="{l10n:Loc Sandbox.Text.0358}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Spacing="6">
                                                <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Text.0354}" HorizontalAlignment="Stretch" />
                                                <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Text.0355}" HorizontalAlignment="Stretch" />
                                                <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Text.0356}" HorizontalAlignment="Stretch" />
                                            </StackPanel>

                                            <Button Grid.Row="2"
                                                    Classes="Outline"
                                                    Content="{l10n:Loc Sandbox.Text.0600}"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding CloseDrawerCommand}" />
                                        </Grid>
                                    </lumina:LuminaDrawer>
                                </lumina:LuminaTopView.DrawerContent>

                                <Grid RowDefinitions="Auto,*" Background="{DynamicResource LuminaSurfaceElevatedBrush}">
                                    <Border Background="{DynamicResource LuminaSurfaceBrush}"
                                            BorderBrush="{DynamicResource LuminaDividerBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,12">
                                        <TextBlock Text="{l10n:Loc Sandbox.Text.1153}" FontWeight="SemiBold" />
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="16" Spacing="10">
                                        <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Text.0357}" />
                                        <TextBlock Classes="Helper"
                                                   Text="{l10n:Loc Sandbox.Text.0766}"
                                                   TextWrapping="Wrap" />
                                        <Button Classes="Primary"
                                                Content="{l10n:Loc Sandbox.Text.0212}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding SetDrawerPlacementCommand}"
                                                CommandParameter="{Binding DrawerPlacement}" />
                                    </StackPanel>
                                </Grid>
                            </lumina:LuminaTopView>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</ContentPage>
