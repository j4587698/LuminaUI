<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.BreadcrumbShowcasePage"
             x:DataType="vm:BreadcrumbShowcaseViewModel">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" Width="{Binding #PageScroll.Bounds.Width}" HorizontalAlignment="Stretch" Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.0716}" />
                <TextBlock Text="{l10n:Loc Sandbox.Text.0717}"
                           Foreground="{DynamicResource LuminaTextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="320" MaxItemWidth="620" HorizontalSpacing="16" VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0718}" />
                        <lumina:LuminaBreadcrumb Separator="›">
                            <lumina:LuminaBreadcrumbItem Icon="⌂" Content="{l10n:Loc Sandbox.Text.0354}" IsReadOnly="True" />
                            <lumina:LuminaBreadcrumbItem Icon="◫" Content="{l10n:Loc Sandbox.Text.0239}" IsReadOnly="True" />
                            <lumina:LuminaBreadcrumbItem Content="{l10n:Loc Sandbox.Text.0716}" IsReadOnly="True" />
                        </lumina:LuminaBreadcrumb>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0719}" />
                        <lumina:LuminaBreadcrumb ItemsSource="{Binding Nodes}"
                                                  DisplayMemberBinding="{Binding Title}"
                                                  IconBinding="{Binding Icon}"
                                                  CommandBinding="{Binding Command}"
                                                  CommandParameterBinding="{Binding Key}"
                                                  Separator="/" />
                        <TextBlock Text="{Binding LastNavigation}"
                                   Foreground="{DynamicResource LuminaTextMutedBrush}" />
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0720}" />
                        <lumina:LuminaBreadcrumb Separator="·">
                            <lumina:LuminaBreadcrumbItem>
                                <Border Padding="8,3"
                                        CornerRadius="999"
                                        Background="{DynamicResource LuminaPrimaryBgBrush}">
                                    <TextBlock Text="{l10n:Loc Sandbox.Text.0346}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource LuminaPrimaryBrush}" />
                                </Border>
                            </lumina:LuminaBreadcrumbItem>
                            <lumina:LuminaBreadcrumbItem Content="{l10n:Loc Sandbox.Text.1124}" IsReadOnly="True" />
                            <lumina:LuminaBreadcrumbItem Content="{l10n:Loc Sandbox.Text.1125}" IsReadOnly="True" />
                        </lumina:LuminaBreadcrumb>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</lumina:LuminaPage>
