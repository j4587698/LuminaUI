<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:notifications="clr-namespace:Avalonia.Controls.Notifications;assembly=Avalonia.Controls"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Name="PageRoot"
             x:Class="LuminaUI.Demo.Views.NavigationContainersShowcasePage"
             x:DataType="vm:NavigationContainersShowcaseViewModel">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24"
                    Width="{Binding #PageScroll.Bounds.Width}"
                    HorizontalAlignment="Stretch"
                    Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="Navigation &amp; Containers" />
                <TextBlock Classes="Body"
                           Text="Native navigation pages, content containers, carousel, transitioning content, and notification surfaces."
                           TextWrapping="Wrap" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="300"
                                          MaxItemWidth="640"
                                          HorizontalSpacing="16"
                                          VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="HeaderedContentControl" />
                        <HeaderedContentControl Header="Service status">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaSuccessBrush}" />
                                <TextBlock Grid.Column="1" Text="API healthy" />
                                <Border Grid.Row="1" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Sync completed" />
                                <Border Grid.Row="2" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaWarningBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Billing check pending" />
                            </Grid>
                        </HeaderedContentControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="ItemsControl" />
                        <ItemsControl Classes="Surface">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <lumina:LuminaTag Classes="Primary">Design</lumina:LuminaTag>
                            <lumina:LuminaTag>Build</lumina:LuminaTag>
                            <lumina:LuminaTag>Verify</lumina:LuminaTag>
                            <lumina:LuminaTag>Release</lumina:LuminaTag>
                        </ItemsControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="SplitView" />
                            <ToggleButton x:Name="SplitPaneToggle"
                                          Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="Pane"
                                          IsChecked="{Binding #DemoSplitView.IsPaneOpen, Mode=TwoWay}" />
                        </Grid>
                        <SplitView x:Name="DemoSplitView"
                                   Height="210"
                                   DisplayMode="CompactInline"
                                   IsPaneOpen="True"
                                   OpenPaneLength="168"
                                   CompactPaneLength="48">
                            <SplitView.Pane>
                                <StackPanel Spacing="6" Margin="8">
                                    <Button Classes="Ghost" Content="Inbox" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="Archive" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="Settings" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </SplitView.Pane>
                            <Border Padding="14"
                                    Background="{DynamicResource LuminaSurfaceBrush}"
                                    BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="Label" Text="Compact inline layout" />
                                    <TextBlock Classes="Helper"
                                               Text="The pane can stay readable on desktop and collapse to the compact strip on narrow layouts."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </SplitView>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="NavigationPage" />
                        <Border Height="240"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <NavigationPage x:Name="DemoNavigationPage">
                                <ContentPage Header="Project">
                                    <StackPanel Margin="16,68,16,16" Spacing="10">
                                        <TextBlock Classes="Label" Text="Navigation root" />
                                        <Button x:Name="PushNavigationButton"
                                                Classes="Primary Small"
                                                Content="Open detail"
                                                HorizontalAlignment="Left"
                                                Command="{Binding PushNavigationCommand}"
                                                CommandParameter="{Binding #DemoNavigationPage}" />
                                    </StackPanel>
                                </ContentPage>
                            </NavigationPage>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="LuminaDrawer" />
                            <ToggleButton Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="Open"
                                          IsChecked="{Binding IsDrawerOpen, Mode=TwoWay}" />
                        </Grid>
                        <WrapPanel>
                            <Button Classes="Ghost Small"
                                    Content="Left"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Left}" />
                            <Button Classes="Ghost Small"
                                    Content="Right"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Right}" />
                            <Button Classes="Ghost Small"
                                    Content="Top"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Top}" />
                            <Button Classes="Ghost Small"
                                    Content="Bottom"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Bottom}" />
                        </WrapPanel>
                        <Border Height="260"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <lumina:LuminaOverlayHost Name="NavigationDrawerPreviewHost"
                                                  IsDrawerOpen="{Binding IsDrawerOpen, Mode=TwoWay}"
                                                  Background="{DynamicResource LuminaBackgroundBrush}">
                                <lumina:LuminaOverlayHost.DrawerContent>
                                    <lumina:LuminaDrawer Placement="{Binding DrawerPlacement}"
                                                         DrawerLength="170"
                                                         ContentPadding="14">
                                        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                                            <StackPanel Spacing="6">
                                                <TextBlock Classes="Label" Text="Drawer content" />
                                                <TextBlock Classes="Helper"
                                                           Text="LuminaDrawer is hosted by the overlay layer."
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="6">
                                                <Button Classes="Ghost" Content="Home" HorizontalAlignment="Stretch" />
                                                <Button Classes="Ghost" Content="Reports" HorizontalAlignment="Stretch" />
                                                <Button Classes="Ghost" Content="Team" HorizontalAlignment="Stretch" />
                                            </StackPanel>
                                            <Button Grid.Row="2"
                                                    Classes="Outline Small"
                                                    Content="Close"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding CloseDrawerCommand}" />
                                        </Grid>
                                    </lumina:LuminaDrawer>
                                </lumina:LuminaOverlayHost.DrawerContent>
                                <StackPanel Margin="16" Spacing="10" Background="{DynamicResource LuminaSurfaceElevatedBrush}">
                                    <TextBlock Classes="Label" Text="Host content" />
                                    <TextBlock Classes="Helper"
                                               Text="The drawer surface uses the current OverlayHost overlay host."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </lumina:LuminaOverlayHost>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="TabbedPage" />
                        <Border Height="260"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <TabbedPage TabPlacement="Top">
                                <ContentPage Header="Home">
                                    <TextBlock Margin="16,64,16,16" Text="Home page content" />
                                </ContentPage>
                                <ContentPage Header="Search">
                                    <TextBlock Margin="16,64,16,16" Text="Search page content" />
                                </ContentPage>
                                <ContentPage Header="Profile">
                                    <TextBlock Margin="16,64,16,16" Text="Profile page content" />
                                </ContentPage>
                            </TabbedPage>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="Carousel" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <CheckBox Content="Auto play"
                                      IsChecked="{Binding IsCarouselAutoPlayEnabled, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding CarouselAutoPlayIntervalText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.5"
                                Maximum="8"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding CarouselAutoPlayIntervalSeconds, Mode=TwoWay}" />
                        <Carousel x:Name="DemoCarousel"
                                  Classes="Line"
                                  Height="220"
                                  SelectedIndex="0"
                                  lumina:LuminaCarouselOptions.IsAutoPlayEnabled="{Binding IsCarouselAutoPlayEnabled}"
                                  lumina:LuminaCarouselOptions.AutoPlayInterval="{Binding CarouselAutoPlayInterval}"
                                  lumina:LuminaCarouselOptions.ShowIndicators="False">
                            <Border Padding="24" Background="#EAF5FF">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#122033" Text="Release dashboard" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#526173" Text="Track build health, review queue, and component coverage in one compact surface." />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#D8E7F8"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#1677FF"
                                                   Text="98%" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#F7F4FF">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#211A36" Text="Component audit" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#615873" Text="Navigation, overlays, pickers, and action controls now have dedicated examples." />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="43"
                                            Background="#FFFFFF"
                                            BorderBrush="#E1D9FA"
                                            BorderThickness="1">
                                        <PathIcon Width="38"
                                                  Height="38"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="#6D4AFF"
                                                  Data="M4,13 L9,18 L20,6" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#FFF7E8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#33240F" Text="Responsive preview" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#765C33" Text="The carousel scales with the card and keeps controls anchored inside the component." />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#F4DFC0"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Foreground="#D98200"
                                                   Text="3" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Carousel>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="TransitioningContentControl" />
                        <TransitioningContentControl Content="Updated content surface">
                            <TransitioningContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Border Padding="16"
                                            Background="{DynamicResource LuminaHoverBackgroundBrush}"
                                            CornerRadius="8">
                                        <TextBlock Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </TransitioningContentControl.ContentTemplate>
                        </TransitioningContentControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="Notification cards" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="Label" Text="Notification duration" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding NotificationDurationText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.5"
                                Maximum="10"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding NotificationDurationSeconds, Mode=TwoWay}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="Label" Text="Notification position" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding NotificationPositionText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <WrapPanel>
                            <Button Classes="Ghost Small"
                                    Content="Top left"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.TopLeft}" />
                            <Button Classes="Ghost Small"
                                    Content="Top right"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.TopRight}" />
                            <Button Classes="Ghost Small"
                                    Content="Bottom left"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.BottomLeft}" />
                            <Button Classes="Ghost Small"
                                    Content="Bottom right"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.BottomRight}" />
                        </WrapPanel>
                        <WrapPanel>
                            <Button x:Name="ShowInfoNotificationButton"
                                    Classes="Outline"
                                    Content="Information"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowInfoNotificationCommand}" />
                            <Button x:Name="ShowSuccessNotificationButton"
                                    Classes="Outline Success"
                                    Content="Success"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowSuccessNotificationCommand}" />
                            <Button x:Name="ShowWarningNotificationButton"
                                    Classes="Outline Warning"
                                    Content="Warning"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowWarningNotificationCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</lumina:LuminaPage>
