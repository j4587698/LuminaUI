<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:controls="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:notifications="clr-namespace:Avalonia.Controls.Notifications;assembly=Avalonia.Controls"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Name="PageRoot"
             x:Class="LuminaUI.Demo.Views.NavigationContainersShowcasePage"
             x:DataType="vm:NavigationContainersShowcaseViewModel">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24"
                    Width="{Binding #PageScroll.Bounds.Width}"
                    HorizontalAlignment="Stretch"
                    Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Components.Navigation.Title}" />
                <TextBlock Classes="Body"
                           Text="{l10n:Loc Sandbox.Components.Navigation.Description}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="300"
                                          MaxItemWidth="640"
                                          HorizontalSpacing="16"
                                          VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.HeaderedContentControl}" />
                        <HeaderedContentControl Header="{l10n:Loc Sandbox.Components.Navigation.ServiceStatus}">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaSuccessBrush}" />
                                <TextBlock Grid.Column="1" Text="{l10n:Loc Sandbox.Components.Navigation.APIHealthy}" />
                                <Border Grid.Row="1" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaPrimaryBrush}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{l10n:Loc Sandbox.Components.Navigation.SyncCompleted}" />
                                <Border Grid.Row="2" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource LuminaWarningBrush}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{l10n:Loc Sandbox.Components.Navigation.BillingCheckPending}" />
                            </Grid>
                        </HeaderedContentControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.ItemsControl}" />
                        <ItemsControl Classes="Surface">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <lumina:LuminaTag Classes="Primary" Content="{l10n:Loc Sandbox.Components.Navigation.Design}" />
                            <lumina:LuminaTag Content="{l10n:Loc Sandbox.Components.Navigation.Build}" />
                            <lumina:LuminaTag Content="{l10n:Loc Sandbox.Components.Navigation.Verify}" />
                            <lumina:LuminaTag Content="{l10n:Loc Sandbox.Components.Navigation.Release}" />
                        </ItemsControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.SplitView}" />
                            <ToggleButton x:Name="SplitPaneToggle"
                                          Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="{l10n:Loc Sandbox.Components.Navigation.Pane}"
                                          IsChecked="{Binding #DemoSplitView.IsPaneOpen, Mode=TwoWay}" />
                        </Grid>
                        <SplitView x:Name="DemoSplitView"
                                   Height="210"
                                   DisplayMode="CompactInline"
                                   IsPaneOpen="True"
                                   OpenPaneLength="168"
                                   CompactPaneLength="48">
                            <SplitView.Pane>
                                <StackPanel Spacing="6" Margin="8">
                                    <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Inbox}" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Archive}" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Settings}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </SplitView.Pane>
                            <Border Padding="14"
                                    Background="{DynamicResource LuminaSurfaceBrush}"
                                    BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Components.Navigation.CompactInlineLayout}" />
                                    <TextBlock Classes="Helper"
                                               Text="{l10n:Loc Sandbox.Components.Navigation.CompactInlineLayoutDesc}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </SplitView>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.NavigationPage}" />
                        <Border Height="240"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <NavigationPage x:Name="DemoNavigationPage">
                                <ContentPage Header="{l10n:Loc Sandbox.Components.Navigation.Project}">
                                    <StackPanel Margin="16,68,16,16" Spacing="10">
                                        <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Components.Navigation.NavigationRoot}" />
                                        <Button x:Name="PushNavigationButton"
                                                Classes="Primary Small"
                                                Content="{l10n:Loc Sandbox.Components.Navigation.OpenDetail}"
                                                HorizontalAlignment="Left"
                                                Command="{Binding PushNavigationCommand}"
                                                CommandParameter="{Binding #DemoNavigationPage}" />
                                    </StackPanel>
                                </ContentPage>
                            </NavigationPage>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.DrawerPage}" />
                            <ToggleButton Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="{l10n:Loc Sandbox.Components.Navigation.Open}"
                                          IsChecked="{Binding IsDrawerOpen, Mode=TwoWay}" />
                        </Grid>
                        <WrapPanel>
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Left}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Left}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Right}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Right}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Top}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Top}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Bottom}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetDrawerPlacementCommand}"
                                    CommandParameter="{x:Static controls:DrawerPlacement.Bottom}" />
                        </WrapPanel>
                        <Border Height="260"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <DrawerPage Header="{l10n:Loc Sandbox.Components.Navigation.Workspace}"
                                        IsOpen="{Binding IsDrawerOpen, Mode=TwoWay}"
                                        DisplayMode="Overlay"
                                        DrawerPlacement="{Binding DrawerPlacement}"
                                        DrawerLength="170"
                                        CompactDrawerLength="48">
                                <DrawerPage.Drawer>
                                    <StackPanel Spacing="6" Margin="8">
                                        <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Home}" HorizontalAlignment="Stretch" />
                                        <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Reports}" HorizontalAlignment="Stretch" />
                                        <Button Classes="Ghost" Content="{l10n:Loc Sandbox.Components.Navigation.Team}" HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </DrawerPage.Drawer>
                                <StackPanel Margin="16,64,16,16" Spacing="10">
                                    <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Components.Navigation.DrawerContent}" />
                                    <TextBlock Classes="Helper"
                                               Text="{l10n:Loc Sandbox.Components.Navigation.DrawerPageDesc}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DrawerPage>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.TabbedPage}" />
                        <Border Height="260"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <TabbedPage TabPlacement="Top">
                                <ContentPage Header="{l10n:Loc Sandbox.Components.Navigation.Home}">
                                    <TextBlock Margin="16,64,16,16" Text="{l10n:Loc Sandbox.Components.Navigation.HomePageContent}" />
                                </ContentPage>
                                <ContentPage Header="{l10n:Loc Sandbox.Components.Navigation.Search}">
                                    <TextBlock Margin="16,64,16,16" Text="{l10n:Loc Sandbox.Components.Navigation.SearchPageContent}" />
                                </ContentPage>
                                <ContentPage Header="{l10n:Loc Sandbox.Components.Navigation.Profile}">
                                    <TextBlock Margin="16,64,16,16" Text="{l10n:Loc Sandbox.Components.Navigation.ProfilePageContent}" />
                                </ContentPage>
                            </TabbedPage>
                        </Border>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.Carousel}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <CheckBox Content="{l10n:Loc Sandbox.Components.Navigation.AutoPlay}"
                                      IsChecked="{Binding IsCarouselAutoPlayEnabled, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding CarouselAutoPlayIntervalText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.5"
                                Maximum="8"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding CarouselAutoPlayIntervalSeconds, Mode=TwoWay}" />
                        <Carousel x:Name="DemoCarousel"
                                  Classes="Line"
                                  Height="220"
                                  SelectedIndex="0"
                                  lumina:LuminaCarouselOptions.IsAutoPlayEnabled="{Binding IsCarouselAutoPlayEnabled}"
                                  lumina:LuminaCarouselOptions.AutoPlayInterval="{Binding CarouselAutoPlayInterval}"
                                  lumina:LuminaCarouselOptions.ShowIndicators="False">
                            <Border Padding="24" Background="#EAF5FF">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#122033" Text="{l10n:Loc Sandbox.Components.Navigation.ReleaseDashboard}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#526173" Text="{l10n:Loc Sandbox.Components.Navigation.ReleaseDashboardDesc}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#D8E7F8"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#1677FF"
                                                   Text="98%" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#F7F4FF">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#211A36" Text="{l10n:Loc Sandbox.Components.Navigation.ComponentAudit}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#615873" Text="{l10n:Loc Sandbox.Components.Navigation.ComponentAuditDesc}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="43"
                                            Background="#FFFFFF"
                                            BorderBrush="#E1D9FA"
                                            BorderThickness="1">
                                        <PathIcon Width="38"
                                                  Height="38"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="#6D4AFF"
                                                  Data="M4,13 L9,18 L20,6" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#FFF7E8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#33240F" Text="{l10n:Loc Sandbox.Components.Navigation.ResponsivePreview}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#765C33" Text="{l10n:Loc Sandbox.Components.Navigation.ResponsivePreviewDesc}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#F4DFC0"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Foreground="#D98200"
                                                   Text="3" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Carousel>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.TransitioningContentControl}" />
                        <TransitioningContentControl Content="{l10n:Loc Sandbox.Components.Navigation.UpdatedContentSurface}">
                            <TransitioningContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Border Padding="16"
                                            Background="{DynamicResource LuminaHoverBackgroundBrush}"
                                            CornerRadius="8">
                                        <TextBlock Text="{Binding}" />
                                    </Border>
                                </DataTemplate>
                            </TransitioningContentControl.ContentTemplate>
                        </TransitioningContentControl>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Components.Navigation.NotificationCards}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Components.Navigation.NotificationDuration}" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding NotificationDurationText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.5"
                                Maximum="10"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding NotificationDurationSeconds, Mode=TwoWay}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Components.Navigation.NotificationPosition}" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding NotificationPositionText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <WrapPanel>
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.TopLeft}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.TopLeft}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.TopRight}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.TopRight}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.BottomLeft}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.BottomLeft}" />
                            <Button Classes="Ghost Small"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.BottomRight}"
                                    Margin="0,0,8,8"
                                    Command="{Binding SetNotificationPositionCommand}"
                                    CommandParameter="{x:Static notifications:NotificationPosition.BottomRight}" />
                        </WrapPanel>
                        <WrapPanel>
                            <Button x:Name="ShowInfoNotificationButton"
                                    Classes="Outline"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Information}"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowInfoNotificationCommand}" />
                            <Button x:Name="ShowSuccessNotificationButton"
                                    Classes="Outline Success"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Success}"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowSuccessNotificationCommand}" />
                            <Button x:Name="ShowWarningNotificationButton"
                                    Classes="Outline Warning"
                                    Content="{l10n:Loc Sandbox.Components.Navigation.Warning}"
                                    Margin="0,0,10,10"
                                    Command="{Binding ShowWarningNotificationCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</ContentPage>
