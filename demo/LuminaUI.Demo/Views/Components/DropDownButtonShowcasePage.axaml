<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:DataType="vm:DropDownButtonShowcaseViewModel"
             x:Class="LuminaUI.Demo.Views.DropDownButtonShowcasePage">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24"
                    Width="{Binding #PageScroll.Bounds.Width}"
                    HorizontalAlignment="Stretch"
                    Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.1154}" />
                <TextBlock Classes="Body" Text="{l10n:Loc Sandbox.Text.0762}" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="280"
                                          MaxItemWidth="500"
                                          HorizontalSpacing="16"
                                          VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.1154}" />
                        <WrapPanel>
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0154}" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.0155}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M4,7 L20,7 M4,12 L16,12 M4,17 L12,17" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.0156}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M4,6 L20,6 M4,12 L20,12 M4,18 L20,18" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.0157}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M4,5 L20,5 M4,12 L20,12 M4,19 L20,19" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <DropDownButton Content="{l10n:Loc Sandbox.Actions.SheetActions}"
                                            Margin="0,0,12,12"
                                            lumina:LuminaOptions.PopupType="Sheet">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Actions.Duplicate}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M7,7 L7,5 C7,3.9 7.9,3 9,3 L19,3 C20.1,3 21,3.9 21,5 L21,15 C21,16.1 20.1,17 19,17 L17,17 M5,7 L15,7 C16.1,7 17,7.9 17,9 L17,19 C17,20.1 16.1,21 15,21 L5,21 C3.9,21 3,20.1 3,19 L3,9 C3,7.9 3.9,7 5,7 Z" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="{l10n:Loc Sandbox.Actions.Rename}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M4,20 L8,19 L19,8 L16,5 L5,16 Z M14,7 L17,10" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="{l10n:Loc Sandbox.Actions.Remove}">
                                            <MenuItem.Icon>
                                                <PathIcon Width="16" Height="16" Data="M5,7 L19,7 M10,11 L10,18 M14,11 L14,18 M8,7 L8,20 L16,20 L16,7 M10,4 L14,4 L15,7 L9,7 Z" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0158}" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <Flyout>
                                        <StackPanel Spacing="8" MinWidth="180">
                                            <TextBlock Classes="Label" Text="{l10n:Loc Sandbox.Text.0159}" />
                                            <Button Classes="Small Outline" Content="{l10n:Loc Sandbox.Text.0160}" />
                                        </StackPanel>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </WrapPanel>
                    </StackPanel>
                </lumina:LuminaCard>

                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.1155}" />
                        <WrapPanel>
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0190}" Classes="Primary" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0194}" Classes="Outline" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>

                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0195}" Classes="Ghost" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </WrapPanel>

                        <WrapPanel>
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0196}" Classes="Small" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                            
                            <DropDownButton Content="{l10n:Loc Sandbox.Text.0656}" Classes="Large" Margin="0,0,12,12">
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>

                            <DropDownButton Classes="Icon" Margin="0,0,12,12">
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="M5,12 A2,2 0 1,0 5,12.01 Z M12,12 A2,2 0 1,0 12,12.01 Z M19,12 A2,2 0 1,0 19,12.01 Z"
                                          Foreground="{Binding $parent[DropDownButton].Foreground}" />
                                <DropDownButton.Flyout>
                                    <MenuFlyout>
                                        <MenuItem Header="{l10n:Loc Sandbox.Text.1156}" />
                                    </MenuFlyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </WrapPanel>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</lumina:LuminaPage>
