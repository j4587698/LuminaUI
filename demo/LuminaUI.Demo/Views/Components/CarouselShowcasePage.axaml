<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.CarouselShowcasePage"
             x:DataType="vm:CarouselShowcaseViewModel">
    <ScrollViewer Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" HorizontalAlignment="Stretch" Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.0366}" />
                <TextBlock Classes="Body" Text="{l10n:Loc Sandbox.Text.0769}" TextWrapping="Wrap" />
            </StackPanel>
            <lumina:LuminaResponsivePanel MinItemWidth="300" MaxItemWidth="640" HorizontalSpacing="16" VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <TextBlock Classes="SectionTitle" Text="{l10n:Loc Sandbox.Text.0366}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <CheckBox Content="{l10n:Loc Sandbox.Text.0367}"
                                      IsChecked="{Binding IsCarouselAutoPlayEnabled, Mode=TwoWay}" />
                            <TextBlock Grid.Column="1"
                                       Classes="Helper"
                                       Text="{Binding CarouselAutoPlayIntervalText}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0.5"
                                Maximum="8"
                                TickFrequency="0.5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding CarouselAutoPlayIntervalSeconds, Mode=TwoWay}" />
                        <Carousel x:Name="DemoCarousel"
                                  Classes="Line"
                                  Height="220"
                                  SelectedIndex="0"
                                  lumina:LuminaCarouselOptions.IsAutoPlayEnabled="{Binding IsCarouselAutoPlayEnabled}"
                                  lumina:LuminaCarouselOptions.AutoPlayInterval="{Binding CarouselAutoPlayInterval}"
                                  lumina:LuminaCarouselOptions.ShowNavigationButtons="False">
                            <Border Padding="24" Background="#EAF5FF">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#122033" Text="{l10n:Loc Sandbox.Text.0368}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#526173" Text="{l10n:Loc Sandbox.Text.0369}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#D8E7F8"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#1677FF"
                                                   Text="{l10n:Loc Sandbox.Text.1132}" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#F7F4FF">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#211A36" Text="{l10n:Loc Sandbox.Text.0370}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#615873" Text="{l10n:Loc Sandbox.Text.0371}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="43"
                                            Background="#FFFFFF"
                                            BorderBrush="#E1D9FA"
                                            BorderThickness="1">
                                        <PathIcon Width="38"
                                                  Height="38"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="#6D4AFF"
                                                  Data="M4,13 L9,18 L20,6" />
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Padding="24" Background="#FFF7E8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#33240F" Text="{l10n:Loc Sandbox.Text.0372}" />
                                        <TextBlock TextWrapping="Wrap" Foreground="#765C33" Text="{l10n:Loc Sandbox.Text.0373}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Width="86"
                                            Height="86"
                                            CornerRadius="16"
                                            Background="#FFFFFF"
                                            BorderBrush="#F4DFC0"
                                            BorderThickness="1">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Foreground="#D98200"
                                                   Text="{l10n:Loc Sandbox.Text.1133}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Carousel>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</ContentPage>
