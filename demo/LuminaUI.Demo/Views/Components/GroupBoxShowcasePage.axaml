<lumina:LuminaPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.GroupBoxShowcasePage"
             x:DataType="vm:StaticShowcaseViewModel">

    <ScrollViewer x:Name="PageScroll" Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24"
                    Width="{Binding #PageScroll.Bounds.Width}"
                    HorizontalAlignment="Stretch"
                    Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{l10n:Loc Sandbox.Text.0055}" />
                <TextBlock Text="{l10n:Loc Sandbox.Text.0057}"
                           Foreground="{DynamicResource LuminaTextMutedBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <lumina:LuminaResponsivePanel MinItemWidth="280"
                                          MaxItemWidth="520"
                                          HorizontalSpacing="16"
                                          VerticalSpacing="16">
                <lumina:LuminaGroupBox Header="{l10n:Loc Sandbox.Text.0078}"
                                       Description="{l10n:Loc Sandbox.Text.0080}">
                    <StackPanel Spacing="12">
                        <TextBox PlaceholderText="{l10n:Loc Sandbox.Text.0081}" Text="{l10n:Loc Sandbox.Components.GroupBox.LuminaAdmin}" />
                        <TextBox PlaceholderText="{l10n:Loc Sandbox.Text.0082}" Text="{l10n:Loc Sandbox.Text.1175}" />
                        <CheckBox Content="{l10n:Loc Sandbox.Text.0083}" IsChecked="True" />
                    </StackPanel>
                </lumina:LuminaGroupBox>

                <lumina:LuminaGroupBox Header="{l10n:Loc Sandbox.Text.0084}"
                                       Description="{l10n:Loc Sandbox.Text.0086}"
                                       Classes="Accent">
                    <lumina:LuminaGroupBox.Actions>
                        <Button Content="{l10n:Loc Sandbox.Text.0169}" Classes="Ghost Small" />
                    </lumina:LuminaGroupBox.Actions>

                    <StackPanel Spacing="12">
                        <lumina:LuminaInputGroup FillIndex="1">
                            <lumina:LuminaInputGroupAddon Content="{l10n:Loc Sandbox.Text.1176}" />
                            <TextBox PlaceholderText="{l10n:Loc Sandbox.Text.0458}" Text="{l10n:Loc Sandbox.Text.1177}" />
                            <lumina:LuminaInputGroupAddon Content="{l10n:Loc Sandbox.Text.1178}" />
                        </lumina:LuminaInputGroup>
                        <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{l10n:Loc Sandbox.Components.GroupBox.Production}" />
                            <ComboBoxItem Content="{l10n:Loc Sandbox.Components.GroupBox.Staging}" />
                            <ComboBoxItem Content="{l10n:Loc Sandbox.Components.GroupBox.Local}" />
                        </ComboBox>
                    </StackPanel>
                </lumina:LuminaGroupBox>

                <lumina:LuminaGroupBox Header="{l10n:Loc Sandbox.Text.0493}"
                                       Description="{l10n:Loc Sandbox.Text.0091}"
                                       Classes="Subtle">
                    <StackPanel Spacing="10">
                        <ToggleSwitch Content="{l10n:Loc Sandbox.Text.0470}" IsChecked="True" />
                        <ToggleSwitch Content="{l10n:Loc Sandbox.Text.0092}" />
                    </StackPanel>
                </lumina:LuminaGroupBox>

                <lumina:LuminaGroupBox Header="{l10n:Loc Sandbox.Text.0093}"
                                       Description="{l10n:Loc Sandbox.Text.0095}"
                                       Classes="Filled">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Text="{l10n:Loc Sandbox.Text.0096}"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{l10n:Loc Sandbox.Text.0097}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        </Grid>
                        <ProgressBar Minimum="0" Maximum="100" Value="68" />
                    </StackPanel>
                </lumina:LuminaGroupBox>

                <lumina:LuminaGroupBox Header="{l10n:Loc Sandbox.Text.0098}"
                                       Description="{l10n:Loc Sandbox.Text.0099}"
                                       Classes="Glow">
                    <StackPanel Spacing="10">
                        <TextBox PlaceholderText="{l10n:Loc Sandbox.Text.0461}" />
                        <WrapPanel>
                            <Button Content="{l10n:Loc Sandbox.Text.0101}" Classes="Ghost Small" Margin="0,0,8,8" />
                            <Button Content="{l10n:Loc Sandbox.Text.0102}" Classes="Primary Small" Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </lumina:LuminaGroupBox>

                <lumina:LuminaGroupBox Description="{l10n:Loc Sandbox.Text.0103}"
                                       HeaderHorizontalAlignment="Center"
                                       Classes="Elevated Compact">
                    <lumina:LuminaGroupBox.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="10"
                                    Height="10"
                                    CornerRadius="5"
                                    Background="{DynamicResource LuminaSuccessBrush}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{l10n:Loc Sandbox.Text.0104}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        </StackPanel>
                    </lumina:LuminaGroupBox.Header>

                    <StackPanel Spacing="12">
                        <TextBlock Text="{l10n:Loc Sandbox.Text.0105}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource LuminaTextMutedBrush}" />
                        <Button Content="{l10n:Loc Sandbox.Text.0106}" HorizontalAlignment="Left" />
                    </StackPanel>
                </lumina:LuminaGroupBox>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</lumina:LuminaPage>
