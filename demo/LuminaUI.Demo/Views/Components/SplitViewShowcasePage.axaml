<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             x:Class="LuminaUI.Demo.Views.SplitViewShowcasePage">
    <ScrollViewer Margin="16" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" HorizontalAlignment="Stretch" Margin="0,36,0,40">
            <StackPanel Spacing="4">
                <TextBlock Classes="Display" Text="{DynamicResource Sandbox.Text.1247}" />
                <TextBlock Classes="Body" Text="{DynamicResource Sandbox.Text.0767}" TextWrapping="Wrap" />
            </StackPanel>
            <lumina:LuminaResponsivePanel MinItemWidth="300" MaxItemWidth="640" HorizontalSpacing="16" VerticalSpacing="16">
                <lumina:LuminaCard>
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Classes="SectionTitle" Text="{DynamicResource Sandbox.Text.1247}" />
                            <ToggleButton x:Name="SplitPaneToggle"
                                          Grid.Column="1"
                                          Classes="Small Outline"
                                          Content="{DynamicResource Sandbox.Text.0347}"
                                          IsChecked="{Binding #DemoSplitView.IsPaneOpen, Mode=TwoWay}" />
                        </Grid>
                        <SplitView x:Name="DemoSplitView"
                                   Height="210"
                                   DisplayMode="CompactInline"
                                   IsPaneOpen="True"
                                   OpenPaneLength="168"
                                   CompactPaneLength="48">
                            <SplitView.Pane>
                                <StackPanel Spacing="6" Margin="8">
                                    <Button Classes="Ghost" Content="{DynamicResource Sandbox.Text.0348}" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="{DynamicResource Sandbox.Text.0171}" HorizontalAlignment="Stretch" />
                                    <Button Classes="Ghost" Content="{DynamicResource Sandbox.Text.0048}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </SplitView.Pane>
                            <Border Padding="14"
                                    Background="{DynamicResource LuminaSurfaceBrush}"
                                    BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="Label" Text="{DynamicResource Sandbox.Text.0349}" />
                                    <TextBlock Classes="Helper"
                                               Text="{DynamicResource Sandbox.Text.0350}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </SplitView>
                    </StackPanel>
                </lumina:LuminaCard>
            </lumina:LuminaResponsivePanel>
        </StackPanel>
    </ScrollViewer>
</ContentPage>
