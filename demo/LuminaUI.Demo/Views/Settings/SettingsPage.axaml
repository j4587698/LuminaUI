<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
             xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI"
             xmlns:vm="using:LuminaUI.Demo.ViewModels"
             x:Class="LuminaUI.Demo.Views.SettingsPage"
             x:DataType="vm:SettingsPageViewModel">

    <ScrollViewer x:Name="PageScroll" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24" HorizontalAlignment="Stretch" Margin="0,12,0,24">
            <TextBlock Text="{l10n:Loc Sandbox.Settings.Title}" FontSize="36" FontWeight="Black" Foreground="{DynamicResource LuminaTextForegroundBrush}" />

            <lumina:LuminaSettingsCard Header="{l10n:Loc Sandbox.Settings.MobileTitle}"
                                       Description="{l10n:Loc Sandbox.Settings.MobileDescription}">
                <lumina:LuminaSettingsOption Icon="P"
                                              Header="{l10n:Loc Sandbox.Settings.Profile}"
                                              Description="{l10n:Loc Sandbox.Settings.ProfileDescription}"
                                              Value="{l10n:Loc Sandbox.User.Name}"
                                              Command="{Binding SelectMobileSettingCommand}"
                                              CommandParameter="{l10n:Loc Sandbox.Settings.Profile}" />
                <lumina:LuminaSettingsInputOption Icon="A"
                                                  Header="{l10n:Loc Sandbox.Text.0150}"
                                                  PlaceholderText="{l10n:Loc Sandbox.Text.0150}"
                                                  InputText="{Binding NicknameText}"
                                                  PopupType="Sheet" />
                <lumina:LuminaSettingsSwitchOption Icon="N"
                                                    Header="{l10n:Loc Sandbox.Settings.Notifications}"
                                                    Description="{l10n:Loc Sandbox.Settings.NotificationsDescription}"
                                                    IsChecked="{Binding MobileNotificationsEnabled}" />
                <lumina:LuminaSettingsSelectOption Icon="L"
                                                    Header="{l10n:Loc Sandbox.Settings.Language}"
                                                    SelectItemsSource="{Binding LanguageItems}"
                                                    SelectedIndex="{Binding SelectedLanguageIndex}"
                                                    PopupType="Sheet" />
                <lumina:LuminaSettingsInputOption Icon="S"
                                                  Header="{l10n:Loc Sandbox.Settings.Storage}"
                                                  PlaceholderText="{l10n:Loc Sandbox.Settings.Storage}"
                                                  InputText="{Binding StorageLimitText}"
                                                  AccessoryMinWidth="92"
                                                  PopupType="Sheet" />
                <lumina:LuminaSettingsOption Classes="Danger"
                                              Icon="!"
                                              Header="{l10n:Loc Sandbox.Settings.DeleteAccount}"
                                              Description="{l10n:Loc Sandbox.Settings.DeleteAccountDescription}"
                                              ShowChevron="False"
                                              Command="{Binding SelectMobileSettingCommand}"
                                              CommandParameter="{l10n:Loc Sandbox.Settings.DeleteAccount}" />
            </lumina:LuminaSettingsCard>

            <TextBlock Name="MobileSettingsStatusText"
                       Classes="Caption"
                       Margin="2,-16,2,0"
                       Text="{Binding MobileSettingsStatusText}" />
            
            <lumina:LuminaCard IsElevated="True">
                <StackPanel Spacing="16">
                    <TextBlock Text="{l10n:Loc Sandbox.Settings.Appearance}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource LuminaTextForegroundBrush}"/>
                    <TextBlock Text="{l10n:Loc Sandbox.Settings.AppearanceDescription}" Foreground="{DynamicResource LuminaTextMutedBrush}" Margin="0,-8,0,16"/>
                    
                    <lumina:LuminaSettingItem Header="{l10n:Loc Sandbox.Settings.ThemeMode}"
                                              Description="{l10n:Loc Sandbox.Settings.ThemeModeDescription}">
                        <ComboBox Name="ThemeModeComboBox"
                                  Width="156"
                                  ItemsSource="{Binding ThemeModeItems}"
                                  SelectedIndex="{Binding SelectedThemeModeIndex}" />
                    </lumina:LuminaSettingItem>

                    <lumina:LuminaSettingItem Header="{l10n:Loc Sandbox.Settings.Language}"
                                              Description="{l10n:Loc Sandbox.Language.CurrentValue}">
                        <ComboBox Name="LanguageComboBox"
                                  Width="148"
                                  ItemsSource="{Binding LanguageItems}"
                                  SelectedIndex="{Binding SelectedLanguageIndex}" />
                    </lumina:LuminaSettingItem>

                    <lumina:LuminaSettingItem Header="{l10n:Loc Sandbox.Localization.OverrideTitle}"
                                              Description="{l10n:Loc Sandbox.Localization.OverrideDescription}">
                        <TextBlock Text="{l10n:Loc Lumina.Common.Done}"
                                   Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                    </lumina:LuminaSettingItem>

                    <Border Height="1" Background="{DynamicResource LuminaDividerBrush}" Margin="0,8" />

                    <Grid ColumnDefinitions="*,Auto" Margin="0,8">
                        <StackPanel Grid.Column="0" Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{l10n:Loc Sandbox.Settings.ThemeColor}" FontWeight="SemiBold" Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                                <TextBlock Text="{l10n:Loc Sandbox.Settings.ThemeColorDescription}" FontSize="12" Foreground="{DynamicResource LuminaTextMutedBrush}" TextWrapping="Wrap" />
                            </StackPanel>

                            <WrapPanel>
                                <lumina:LuminaColorButton SwatchBrush="#2563EB" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#2563EB" ToolTip.Tip="Blue" />
                                <lumina:LuminaColorButton SwatchBrush="#4F46E5" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#4F46E5" ToolTip.Tip="Indigo" />
                                <lumina:LuminaColorButton SwatchBrush="#7C3AED" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#7C3AED" ToolTip.Tip="Violet" />
                                <lumina:LuminaColorButton SwatchBrush="#0D9488" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#0D9488" ToolTip.Tip="Teal" />
                                <lumina:LuminaColorButton SwatchBrush="#16A34A" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#16A34A" ToolTip.Tip="Emerald" />
                                <lumina:LuminaColorButton SwatchBrush="#E11D48" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#E11D48" ToolTip.Tip="Rose" />
                                <lumina:LuminaColorButton SwatchBrush="#EA580C" Command="{Binding ApplyAccentPresetCommand}" CommandParameter="#EA580C" ToolTip.Tip="Orange" />
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox Name="AccentHexTextBox" Width="116" Text="{Binding AccentHexText}" />
                                <Button Name="ApplyAccentButton" Content="{l10n:Loc Lumina.Common.Apply}" Classes="Outline" Command="{Binding ApplyAccentCommand}" />
                                <TextBlock Name="AccentStatusText" Text="{Binding AccentStatusText}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource LuminaTextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Name="AccentPreview"
                                Width="48"
                                Height="48"
                                Margin="16,0,0,0"
                                CornerRadius="14"
                                Background="{Binding AccentPreviewBrush}"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="1" />
                    </Grid>
                    
                    <Border Height="1" Background="{DynamicResource LuminaDividerBrush}" Margin="0,8" />
                    
                    <lumina:LuminaSettingItem Header="{l10n:Loc Sandbox.Settings.ReduceAnimations}"
                                              Description="{l10n:Loc Sandbox.Settings.ReduceAnimationsDescription}">
                        <Button Content="{l10n:Loc Sandbox.Settings.Disabled}" Classes="Ghost" />
                    </lumina:LuminaSettingItem>
                </StackPanel>
            </lumina:LuminaCard>
            
            <lumina:LuminaCard>
                <StackPanel Spacing="16">
                    <TextBlock Text="{l10n:Loc Sandbox.Settings.Account}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource LuminaTextForegroundBrush}"/>
                    <TextBlock Text="{l10n:Loc Sandbox.Settings.AccountDescription}" Foreground="{DynamicResource LuminaTextMutedBrush}" Margin="0,-8,0,16"/>
                    
                    <lumina:LuminaListItem Icon="P"
                                           Header="{l10n:Loc Sandbox.User.Name}"
                                           Description="{l10n:Loc Sandbox.Text.1175}"
                                           Background="Transparent"
                                           Padding="0" />
                    
                    <Button Content="{l10n:Loc Sandbox.Settings.LogOut}" Classes="Danger Outline" Margin="0,16,0,0" HorizontalAlignment="Left" />
                </StackPanel>
            </lumina:LuminaCard>

        </StackPanel>
    </ScrollViewer>
</UserControl>
