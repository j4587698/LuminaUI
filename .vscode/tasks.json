{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run LuminaUI MCP",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/tools/LuminaUI.Mcp/LuminaUI.Mcp.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Docker Compose LuminaUI MCP",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "--build",
        "lumina-mcp"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}