<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:LuminaUI.Converters">

    <StreamGeometry x:Key="LuminaCarouselPreviousGlyph">M15,6 L9,12 L15,18</StreamGeometry>
    <StreamGeometry x:Key="LuminaCarouselNextGlyph">M9,6 L15,12 L9,18</StreamGeometry>
    <Thickness x:Key="LuminaCarouselIndicatorDotMargin">3,0</Thickness>
    <x:Double x:Key="LuminaCarouselIndicatorDotSize">7</x:Double>
    <CornerRadius x:Key="LuminaCarouselIndicatorDotCornerRadius">4</CornerRadius>
    <x:Double x:Key="LuminaCarouselIndicatorDotSelectedWidth">20</x:Double>
    <Thickness x:Key="LuminaCarouselIndicatorLineMargin">2,0</Thickness>
    <x:Double x:Key="LuminaCarouselIndicatorLineHeight">4</x:Double>
    <CornerRadius x:Key="LuminaCarouselIndicatorLineCornerRadius">2</CornerRadius>
    <x:Double x:Key="LuminaCarouselIndicatorColumnarWidth">5</x:Double>
    <x:Double x:Key="LuminaCarouselIndicatorColumnarHeight">22</x:Double>
    <Thickness x:Key="LuminaCarouselIndicatorColumnarMargin">3,0</Thickness>
    <x:Double x:Key="LuminaCarouselIndicatorColumnarIdleHeight">10</x:Double>
    <CornerRadius x:Key="LuminaCarouselIndicatorColumnarCornerRadius">3</CornerRadius>
    <x:Double x:Key="LuminaCarouselButtonSize">36</x:Double>
    <Thickness x:Key="LuminaCarouselButtonPadding">0</Thickness>
    <Thickness x:Key="LuminaCarouselButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCarouselButtonCornerRadius">18</CornerRadius>
    <x:Double x:Key="LuminaCarouselButtonIconSize">18</x:Double>
    <x:Double x:Key="LuminaCarouselButtonIconCanvasSize">24</x:Double>
    <x:Double x:Key="LuminaCarouselButtonIconStrokeThickness">2.4</x:Double>
    <Thickness x:Key="LuminaCarouselBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCarouselCornerRadius">10</CornerRadius>
    <x:Double x:Key="LuminaCarouselIndicatorScrimHeight">52</x:Double>
    <Thickness x:Key="LuminaCarouselIndicatorMargin">0,0,0,16</Thickness>
    <Thickness x:Key="LuminaCarouselIndicatorPadding">0</Thickness>
    <x:Double x:Key="LuminaCarouselIndicatorMinHeight">20</x:Double>
    <Thickness x:Key="LuminaCarouselIndicatorBorderThickness">0</Thickness>
    <Thickness x:Key="LuminaCarouselPreviousButtonMargin">14,0,0,0</Thickness>
    <Thickness x:Key="LuminaCarouselNextButtonMargin">0,0,14,0</Thickness>
    <x:Double x:Key="LuminaCarouselLineIndicatorsWidth">180</x:Double>
    <Thickness x:Key="LuminaCarouselLeftIndicatorsMargin">18,0,0,16</Thickness>
    <Thickness x:Key="LuminaCarouselRightIndicatorsMargin">0,0,18,16</Thickness>

    <ControlTheme x:Key="LuminaCarouselIndicatorDotItem" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="{DynamicResource LuminaCarouselIndicatorDotMargin}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="{DynamicResource LuminaTextMutedBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border Name="PART_Dot"
                        Width="{DynamicResource LuminaCarouselIndicatorDotSize}"
                        Height="{DynamicResource LuminaCarouselIndicatorDotSize}"
                        CornerRadius="{DynamicResource LuminaCarouselIndicatorDotCornerRadius}"
                        Background="{TemplateBinding Background}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.16" />
                            <BrushTransition Property="Background" Duration="0:0:0.16" />
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_Dot">
            <Setter Property="Width" Value="{DynamicResource LuminaCarouselIndicatorDotSelectedWidth}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCarouselIndicatorLineItem"
                  TargetType="ListBoxItem"
                  BasedOn="{StaticResource LuminaCarouselIndicatorDotItem}">
        <Setter Property="Margin" Value="{DynamicResource LuminaCarouselIndicatorLineMargin}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border Name="PART_Line"
                        Height="{DynamicResource LuminaCarouselIndicatorLineHeight}"
                        CornerRadius="{DynamicResource LuminaCarouselIndicatorLineCornerRadius}"
                        Background="{TemplateBinding Background}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.16" />
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCarouselIndicatorColumnarItem"
                  TargetType="ListBoxItem"
                  BasedOn="{StaticResource LuminaCarouselIndicatorDotItem}">
        <Setter Property="Width" Value="{DynamicResource LuminaCarouselIndicatorColumnarWidth}" />
        <Setter Property="Height" Value="{DynamicResource LuminaCarouselIndicatorColumnarHeight}" />
        <Setter Property="Margin" Value="{DynamicResource LuminaCarouselIndicatorColumnarMargin}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="ListBoxItem">
                <Border Name="PART_Column"
                        Width="{DynamicResource LuminaCarouselIndicatorColumnarWidth}"
                        Height="{DynamicResource LuminaCarouselIndicatorColumnarIdleHeight}"
                        VerticalAlignment="Bottom"
                        CornerRadius="{DynamicResource LuminaCarouselIndicatorColumnarCornerRadius}"
                        Background="{TemplateBinding Background}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Height" Duration="0:0:0.18" />
                            <BrushTransition Property="Background" Duration="0:0:0.16" />
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:selected /template/ Border#PART_Column">
            <Setter Property="Height" Value="{DynamicResource LuminaCarouselIndicatorColumnarHeight}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCarouselButton" TargetType="Button">
        <Setter Property="Width" Value="{DynamicResource LuminaCarouselButtonSize}" />
        <Setter Property="Height" Value="{DynamicResource LuminaCarouselButtonSize}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCarouselButtonPadding}" />
        <Setter Property="Background" Value="#66000000" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#26FFFFFF" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCarouselButtonBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCarouselButtonCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Name="PART_ButtonRoot"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Viewbox Width="{DynamicResource LuminaCarouselButtonIconSize}"
                             Height="{DynamicResource LuminaCarouselButtonIconSize}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Stretch="Uniform">
                        <Canvas Width="{DynamicResource LuminaCarouselButtonIconCanvasSize}"
                                Height="{DynamicResource LuminaCarouselButtonIconCanvasSize}">
                            <Path Data="{TemplateBinding Content}"
                                  Fill="Transparent"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  StrokeThickness="{DynamicResource LuminaCarouselButtonIconStrokeThickness}" />
                        </Canvas>
                    </Viewbox>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="#99000000" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Background" Value="#B3000000" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type Carousel}" TargetType="Carousel">
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCarouselBorderThickness}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="AutoScrollToSelectedItem" Value="False" />
        <Setter Property="PageTransition">
            <PageSlide Orientation="Horizontal" Duration="0.28" />
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="Carousel">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{DynamicResource LuminaCarouselCornerRadius}"
                        ClipToBounds="True">
                    <Grid RowDefinitions="*,Auto">
                        <ScrollViewer Name="PART_ScrollViewer"
                                      Grid.Row="0"
                                      Grid.RowSpan="2"
                                      Background="Transparent"
                                      BringIntoViewOnFocusChange="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            Margin="{TemplateBinding Padding}"
                                            ItemsPanel="{TemplateBinding ItemsPanel}" />
                        </ScrollViewer>

                        <Border Name="PART_IndicatorScrim"
                                Grid.Row="1"
                                Height="{DynamicResource LuminaCarouselIndicatorScrimHeight}"
                                VerticalAlignment="Bottom"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#66000000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <ListBox Name="PART_Indicators"
                                 Grid.Row="1"
                                 Margin="{DynamicResource LuminaCarouselIndicatorMargin}"
                                 Padding="{DynamicResource LuminaCarouselIndicatorPadding}"
                                 MinHeight="{DynamicResource LuminaCarouselIndicatorMinHeight}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Bottom"
                                 Background="Transparent"
                                 BorderThickness="{DynamicResource LuminaCarouselIndicatorBorderThickness}"
                                 AutoScrollToSelectedItem="False"
                                 Focusable="False"
                                 ScrollViewer.BringIntoViewOnFocusChange="False"
                                 ItemContainerTheme="{StaticResource LuminaCarouselIndicatorDotItem}"
                                 ItemsSource="{TemplateBinding ItemCount, Converter={x:Static converters:LuminaCarouselConverters.ItemToObjectConverter}}"
                                 IsVisible="{TemplateBinding ItemCount, Converter={x:Static converters:LuminaCarouselConverters.ItemVisibleConverter}}"
                                 SelectedIndex="{TemplateBinding SelectedIndex, Mode=TwoWay}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Button Name="PART_PreviousButton"
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Margin="{DynamicResource LuminaCarouselPreviousButtonMargin}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Theme="{StaticResource LuminaCarouselButton}"
                                Content="{StaticResource LuminaCarouselPreviousGlyph}"
                                IsVisible="{TemplateBinding ItemCount, Converter={x:Static converters:LuminaCarouselConverters.ItemVisibleConverter}}"
                                Command="{Binding $parent[Carousel].Previous}" />

                        <Button Name="PART_NextButton"
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Margin="{DynamicResource LuminaCarouselNextButtonMargin}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Theme="{StaticResource LuminaCarouselButton}"
                                Content="{StaticResource LuminaCarouselNextGlyph}"
                                IsVisible="{TemplateBinding ItemCount, Converter={x:Static converters:LuminaCarouselConverters.ItemVisibleConverter}}"
                                Command="{Binding $parent[Carousel].Next}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Line /template/ ListBox#PART_Indicators">
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaCarouselIndicatorLineItem}" />
            <Setter Property="Width" Value="{DynamicResource LuminaCarouselLineIndicatorsWidth}" />
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{TemplateBinding ItemCount}" Rows="1" />
                </ItemsPanelTemplate>
            </Setter>
        </Style>

        <Style Selector="^.Columnar /template/ ListBox#PART_Indicators">
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaCarouselIndicatorColumnarItem}" />
        </Style>

        <Style Selector="^.HideIndicators /template/ Border#PART_IndicatorScrim">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^.HideIndicators /template/ ListBox#PART_Indicators">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^.HideNavigationButtons /template/ Button#PART_PreviousButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^.HideNavigationButtons /template/ Button#PART_NextButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^.Left /template/ ListBox#PART_Indicators">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="{DynamicResource LuminaCarouselLeftIndicatorsMargin}" />
        </Style>

        <Style Selector="^.Center /template/ ListBox#PART_Indicators">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style Selector="^.Right /template/ ListBox#PART_Indicators">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="{DynamicResource LuminaCarouselRightIndicatorsMargin}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type CarouselPage}" TargetType="CarouselPage" BasedOn="{StaticResource {x:Type CarouselPage}}">
        <Setter Property="Background" Value="Transparent" />
    </ControlTheme>

</ResourceDictionary>
