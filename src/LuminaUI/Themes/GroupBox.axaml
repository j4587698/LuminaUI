<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <Thickness x:Key="LuminaGroupBoxFrameMargin">0,10,0,0</Thickness>
    <Thickness x:Key="LuminaGroupBoxFrameBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaGroupBoxFrameCornerRadius">6</CornerRadius>
    <x:Double x:Key="LuminaGroupBoxContentRowSpacing">12</x:Double>
    <x:Double x:Key="LuminaGroupBoxDescriptionFontSize">12</x:Double>
    <Thickness x:Key="LuminaGroupBoxHeaderLineMargin">12,0,12,0</Thickness>
    <x:Double x:Key="LuminaGroupBoxHeaderColumnSpacing">8</x:Double>
    <Thickness x:Key="LuminaGroupBoxHeaderPadding">6,0</Thickness>
    <x:Double x:Key="LuminaGroupBoxHeaderFontSize">14</x:Double>

    <ControlTheme x:Key="{x:Type lumina:LuminaGroupBox}" TargetType="lumina:LuminaGroupBox">
        <Setter Property="Padding" Value="16,18,16,16" />
        <Setter Property="HeaderBackground" Value="{DynamicResource LuminaBackgroundBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />

        <Setter Property="Template">
            <ControlTemplate>
                <Grid ClipToBounds="False">
                    <Border Name="PART_Frame"
                            Margin="{DynamicResource LuminaGroupBoxFrameMargin}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                            BorderThickness="{DynamicResource LuminaGroupBoxFrameBorderThickness}"
                            CornerRadius="{DynamicResource LuminaGroupBoxFrameCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <Grid RowDefinitions="Auto,*"
                              RowSpacing="{DynamicResource LuminaGroupBoxContentRowSpacing}">
                            <TextBlock Name="PART_DescriptionText"
                                       Text="{TemplateBinding Description}"
                                       FontSize="{DynamicResource LuminaGroupBoxDescriptionFontSize}"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       TextWrapping="Wrap"
                                       IsVisible="{TemplateBinding HasDescription}" />
                            <ContentPresenter Grid.Row="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </Border>

                    <Grid Name="PART_HeaderLine"
                          Margin="{DynamicResource LuminaGroupBoxHeaderLineMargin}"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="{DynamicResource LuminaGroupBoxHeaderColumnSpacing}"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding HasHeader}">
                        <Border Name="PART_HeaderBackground"
                                Grid.Column="0"
                                Background="{TemplateBinding HeaderBackground}"
                                Padding="{DynamicResource LuminaGroupBoxHeaderPadding}"
                                HorizontalAlignment="{TemplateBinding HeaderHorizontalAlignment}">
                            <ContentPresenter Name="PART_HeaderPresenter"
                                              Content="{TemplateBinding Header}"
                                              TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}"
                                              TextElement.FontSize="{DynamicResource LuminaGroupBoxHeaderFontSize}"
                                              TextElement.FontWeight="SemiBold" />
                        </Border>

                        <Border Name="PART_ActionsBackground"
                                Grid.Column="2"
                                Background="{TemplateBinding HeaderBackground}"
                                Padding="{DynamicResource LuminaGroupBoxHeaderPadding}"
                                IsVisible="{TemplateBinding HasActions}">
                            <ContentPresenter Name="PART_ActionsPresenter"
                                              Content="{TemplateBinding Actions}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Accent /template/ Border#PART_Frame">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^.Accent /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^.Subtle /template/ Border#PART_Frame">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        </Style>

        <Style Selector="^.Filled /template/ Border#PART_Frame">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        </Style>

        <Style Selector="^.Filled /template/ Border#PART_HeaderBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        </Style>

        <Style Selector="^.Filled /template/ Border#PART_ActionsBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        </Style>

        <Style Selector="^.Elevated /template/ Border#PART_Frame">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
            <Setter Property="BoxShadow" Value="{DynamicResource LuminaShadowElevated}" />
        </Style>

        <Style Selector="^.Elevated /template/ Border#PART_HeaderBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        </Style>

        <Style Selector="^.Elevated /template/ Border#PART_ActionsBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        </Style>

        <Style Selector="^.Glow /template/ Border#PART_Frame">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 3 #1A2563EB, 0 8 24 #18000000" />
        </Style>

        <Style Selector="^.Compact">
            <Setter Property="Padding" Value="12,14,12,12" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
