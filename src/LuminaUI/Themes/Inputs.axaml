<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <x:Double x:Key="LuminaCascaderPopupPanelSpacing">6</x:Double>
    <Thickness x:Key="LuminaCascaderPopupFrameMargin">0,6,0,0</Thickness>
    <Thickness x:Key="LuminaCascaderPopupFramePadding">6</Thickness>
    <Thickness x:Key="LuminaCascaderPopupFrameBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCascaderPopupFrameCornerRadius">10</CornerRadius>
