    <x:Double x:Key="LuminaCascaderSheetBodyMaxHeight">480</x:Double>
    <x:Double x:Key="LuminaCascaderSheetBodyExtraHeight">120</x:Double>
    <x:Double x:Key="LuminaCascaderSheetContentSpacing">16</x:Double>
    <x:Double x:Key="LuminaCascaderSheetHeaderTitleFontSize">18</x:Double>
    <x:Double x:Key="LuminaCascaderSheetHeaderSubtitleFontSize">12</x:Double>
    <x:Double x:Key="LuminaCascaderSheetHeaderSpacing">2</x:Double>
    <x:Double x:Key="LuminaCascaderSheetBackIconSize">12</x:Double>
    <x:Double x:Key="LuminaCascaderSheetBackButtonMinSize">40</x:Double>
    <Thickness x:Key="LuminaCascaderSheetBackButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaCascaderSheetHeaderColumnSpacing">10</x:Double>
    <x:Double x:Key="LuminaCascaderSheetListSpacing">8</x:Double>
    <x:Double x:Key="LuminaCascaderSheetRowFontSize">15</x:Double>
    <x:Double x:Key="LuminaCascaderSheetRowColumnSpacing">8</x:Double>
    <x:Double x:Key="LuminaCascaderSheetRowCheckIconSize">18</x:Double>
    <x:Double x:Key="LuminaCascaderSheetRowChevronIconSize">12</x:Double>
    <x:Double x:Key="LuminaCascaderSheetRowMinHeight">52</x:Double>
    <Thickness x:Key="LuminaCascaderSheetRowPadding">14,10</Thickness>
    <Thickness x:Key="LuminaCascaderSheetRowBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCascaderSheetRowCornerRadius">14</CornerRadius>

    <x:Double x:Key="LuminaWheelPickerRowSpacing">14</x:Double>
    <x:Double x:Key="LuminaWheelPickerSummaryFontSize">15</x:Double>
    <Thickness x:Key="LuminaWheelPickerSummaryPadding">14,10</Thickness>
    <CornerRadius x:Key="LuminaWheelPickerSummaryCornerRadius">999</CornerRadius>
    <x:Double x:Key="LuminaWheelPickerColumnSpacing">8</x:Double>
    <x:Double x:Key="LuminaWheelColumnRowSpacing">8</x:Double>
    <x:Double x:Key="LuminaWheelColumnLabelFontSize">11</x:Double>
    <x:Double x:Key="LuminaWheelColumnItemHeight">44</x:Double>
    <Thickness x:Key="LuminaWheelColumnSelectionBandBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaWheelColumnSelectionBandCornerRadius">10</CornerRadius>
    <x:Double x:Key="LuminaWheelColumnSelectionBandOpacity">0.72</x:Double>
    <Thickness x:Key="LuminaWheelColumnFrameBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaWheelColumnFrameCornerRadius">16</CornerRadius>
    <x:Double x:Key="LuminaWheelColumnSelectedFontSize">20</x:Double>
    <x:Double x:Key="LuminaWheelColumnNearFontSize">16</x:Double>
    <x:Double x:Key="LuminaWheelColumnFarFontSize">14</x:Double>
    <x:Double x:Key="LuminaWheelColumnNearOpacity">0.72</x:Double>
    <x:Double x:Key="LuminaWheelColumnFarOpacity">0.42</x:Double>

    <x:Double x:Key="LuminaSheetLayoutSpacing">16</x:Double>
    <x:Double x:Key="LuminaSheetTitleFontSize">18</x:Double>
    <x:Double x:Key="LuminaSheetActionsColumnSpacing">8</x:Double>
    <x:Double x:Key="LuminaComboBoxSheetOptionsSpacing">6</x:Double>
    <x:Double x:Key="LuminaComboBoxSheetBodyMaxHeight">360</x:Double>
    <x:Double x:Key="LuminaActionSheetListSpacing">4</x:Double>
    <x:Double x:Key="LuminaActionSheetBodyMaxHeight">420</x:Double>
    <x:Double x:Key="LuminaActionSheetSeparatorHeight">1</x:Double>
    <Thickness x:Key="LuminaActionSheetSeparatorMargin">4,6</Thickness>
    <x:Double x:Key="LuminaActionSheetItemColumnSpacing">12</x:Double>
    <x:Double x:Key="LuminaActionSheetIconSize">20</x:Double>
    <x:Double x:Key="LuminaActionSheetCheckIconSize">18</x:Double>
    <x:Double x:Key="LuminaDateRangeSheetSelectorColumnSpacing">10</x:Double>
    <x:Double x:Key="LuminaDateRangeSheetBodySpacing">14</x:Double>
    <Thickness x:Key="LuminaDateRangeSheetDateButtonPadding">12,10</Thickness>
    <x:Double x:Key="LuminaDateRangeSheetDateButtonSpacing">4</x:Double>
    <x:Double x:Key="LuminaDateRangeSheetDateButtonTitleFontSize">12</x:Double>
    <x:Double x:Key="LuminaDateRangeSheetDateButtonTitleOpacity">0.7</x:Double>
    <x:Double x:Key="LuminaMultiSelectSheetListSpacing">4</x:Double>
    <x:Double x:Key="LuminaMultiSelectSheetBodyMinHeight">240</x:Double>
    <x:Double x:Key="LuminaMultiSelectSheetBodyMaxHeight">420</x:Double>
    <x:Double x:Key="LuminaMultiSelectSheetItemColumnSpacing">12</x:Double>
    <x:Double x:Key="LuminaSettingsOptionSheetInputMinHeight">38</x:Double>
    <x:Double x:Key="LuminaSettingsOptionSheetBodyMaxHeight">420</x:Double>
    <x:Double x:Key="LuminaSettingsOptionSheetOptionsSpacing">4</x:Double>
    <x:Double x:Key="LuminaSettingsOptionSheetOptionColumnSpacing">12</x:Double>
    <x:Double x:Key="LuminaSettingsOptionSheetCheckIconSize">18</x:Double>
    <Thickness x:Key="LuminaComboBoxItemPadding">12,8</Thickness>
    <x:Double x:Key="LuminaComboBoxItemMinHeight">34</x:Double>
    <Thickness x:Key="LuminaInputGroupAddonPadding">12,0</Thickness>
    <x:Double x:Key="LuminaInputGroupAddonDisabledOpacity">0.52</x:Double>
    <Thickness x:Key="LuminaPickerFlyoutButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaPickerFlyoutButtonMinSize">0</x:Double>
    <x:Double x:Key="LuminaCascaderNodeButtonMinHeight">32</x:Double>
    <Thickness x:Key="LuminaCascaderNodeButtonPadding">10,7</Thickness>
    <x:Double x:Key="LuminaCascaderNodeButtonFontSize">14</x:Double>
    <Thickness x:Key="LuminaCascaderNodeButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCascaderNodeButtonCornerRadius">6</CornerRadius>
    <x:Double x:Key="LuminaCascaderDisabledOpacity">0.52</x:Double>
    <x:Double x:Key="LuminaCascaderSurfaceColumnSpacing">8</x:Double>
    <x:Double x:Key="LuminaCascaderChevronIconSize">14</x:Double>
    <x:Double x:Key="LuminaCascaderClearButtonSize">28</x:Double>
    <Thickness x:Key="LuminaCascaderClearButtonMargin">0,0,30,0</Thickness>
    <Thickness x:Key="LuminaCascaderClearButtonPadding">0</Thickness>
    <Thickness x:Key="LuminaCascaderClearButtonBorderThickness">0</Thickness>
    <x:Double x:Key="LuminaCascaderClearIconSize">12</x:Double>
    <Thickness x:Key="LuminaPickerPadding">0</Thickness>
    <x:Double x:Key="LuminaPickerIconColumnWidth">36</x:Double>
    <Thickness x:Key="LuminaPickerTextPadding">0</Thickness>
    <x:Double x:Key="LuminaPickerDividerWidth">1</x:Double>
    <x:Double x:Key="LuminaPickerIconSize">16</x:Double>
    <x:Double x:Key="LuminaPickerDisabledOpacity">0.5</x:Double>
    <x:Double x:Key="LuminaPickerSmallMinHeight">28</x:Double>
    <x:Double x:Key="LuminaPickerLargeMinHeight">48</x:Double>
    <CornerRadius x:Key="LuminaSliderTrackCornerRadius">4</CornerRadius>
    <Thickness x:Key="LuminaSliderThumbBorderThickness">0</Thickness>
    <x:Double x:Key="LuminaSliderThumbSize">20</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderHeight">32</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderTrackHeight">8</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderThumbSize">18</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderStep">1</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderDisabledOpacity">0.52</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderCompactHeight">24</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderCompactTrackHeight">5</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderCompactThumbSize">14</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderLargeHeight">40</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderLargeTrackHeight">10</x:Double>
    <x:Double x:Key="LuminaPlaybackSliderLargeThumbSize">22</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressMinWidth">160</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressMinHeight">96</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressStrokeThickness">12</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressFontSize">32</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressDisabledOpacity">0.52</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressCompactMinWidth">128</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressCompactMinHeight">78</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressCompactStrokeThickness">8</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressLargeMinWidth">220</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressLargeMinHeight">132</x:Double>
    <x:Double x:Key="LuminaSemiCircleProgressLargeStrokeThickness">14</x:Double>

    <ControlTheme x:Key="{x:Type TextBox}" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />

        <Style Selector="^[AcceptsReturn=True]">
            <Setter Property="VerticalContentAlignment" Value="Top" />
        </Style>

        <Style Selector="^.Pill">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        </Style>

        <Style Selector="^.Search">
            <Setter Property="Padding" Value="4,4" />
        </Style>

        <Style Selector="^.LuminaInputGroupItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="^.LuminaInputGroupFirst">
            <Setter Property="CornerRadius" Value="6,0,0,6" />
        </Style>

        <Style Selector="^.LuminaInputGroupMiddle">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupLast">
            <Setter Property="CornerRadius" Value="0,6,6,0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupSingle">
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
        </Style>

        <Style Selector="^:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type ComboBox}" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />

        <Style Selector="^:pointerover /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
        </Style>

        <Style Selector="^:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
        </Style>

        <Style Selector="^[(lumina|LuminaOptions.PopupType)=Sheet]">
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="^.LuminaInputGroupItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="^.LuminaInputGroupFirst">
            <Setter Property="CornerRadius" Value="6,0,0,6" />
        </Style>

        <Style Selector="^.LuminaInputGroupMiddle">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupLast">
            <Setter Property="CornerRadius" Value="0,6,6,0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupSingle">
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type ComboBoxItem}" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
        <Setter Property="Padding" Value="{DynamicResource LuminaComboBoxItemPadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaComboBoxItemMinHeight}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type NumericUpDown}" TargetType="NumericUpDown" BasedOn="{StaticResource {x:Type NumericUpDown}}">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />

        <Style Selector="^.LuminaInputGroupItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="^.LuminaInputGroupFirst">
            <Setter Property="CornerRadius" Value="6,0,0,6" />
        </Style>

        <Style Selector="^.LuminaInputGroupMiddle">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupLast">
            <Setter Property="CornerRadius" Value="0,6,6,0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupSingle">
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
        </Style>

        <Style Selector="^:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaInputGroupAddon}" TargetType="lumina:LuminaInputGroupAddon">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="{DynamicResource LuminaInputGroupAddonPadding}" />
        <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaInputGroupAddon">
                <Border Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaInputGroupAddonDisabledOpacity}" />
        </Style>

        <Style Selector="^.LuminaInputGroupItem">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="^.LuminaInputGroupFirst">
            <Setter Property="CornerRadius" Value="6,0,0,6" />
        </Style>

        <Style Selector="^.LuminaInputGroupMiddle">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupLast">
            <Setter Property="CornerRadius" Value="0,6,6,0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style Selector="^.LuminaInputGroupSingle">
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaPickerFlyoutButton" TargetType="Button">
        <Setter Property="Padding" Value="{DynamicResource LuminaPickerFlyoutButtonPadding}" />
        <Setter Property="MinWidth" Value="{DynamicResource LuminaPickerFlyoutButtonMinSize}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaPickerFlyoutButtonMinSize}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:focus-visible /template/ Border#PART_Border">
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCascaderNodeButtonTheme" TargetType="Button">
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCascaderNodeButtonMinHeight}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCascaderNodeButtonPadding}" />
        <Setter Property="FontSize" Value="{DynamicResource LuminaCascaderNodeButtonFontSize}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCascaderNodeButtonBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCascaderNodeButtonCornerRadius}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Border Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        </Style>

        <Style Selector="^.active">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaCascaderDisabledOpacity}" />
        </Style>

        <Style Selector="^:focus-visible /template/ Border#PART_Border">
            <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaCascader}" TargetType="lumina:LuminaCascader">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaCascader">
                <Grid>
                    <Button Name="PART_SurfaceButton"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Foreground="{TemplateBinding Foreground}"
                            Theme="{StaticResource LuminaPickerFlyoutButton}">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="{DynamicResource LuminaCascaderSurfaceColumnSpacing}">
                            <TextBlock Name="PART_DisplayText"
                                       VerticalAlignment="Center"
                                       Text="{TemplateBinding DisplayText}"
                                       TextTrimming="CharacterEllipsis"
                                       TextElement.Foreground="{TemplateBinding Foreground}" />
                            <PathIcon Grid.Column="1"
                                      Width="{DynamicResource LuminaCascaderChevronIconSize}"
                                      Height="{DynamicResource LuminaCascaderChevronIconSize}"
                                      VerticalAlignment="Center"
                                      Data="M7,10 L12,15 L17,10 Z"
                                      Foreground="{DynamicResource LuminaTextMutedBrush}" />
                        </Grid>
                    </Button>

                    <Button Name="PART_ClearButton"
                            Width="{DynamicResource LuminaCascaderClearButtonSize}"
                            Height="{DynamicResource LuminaCascaderClearButtonSize}"
                            Margin="{DynamicResource LuminaCascaderClearButtonMargin}"
                            Padding="{DynamicResource LuminaCascaderClearButtonPadding}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="{DynamicResource LuminaCascaderClearButtonBorderThickness}"
                            Foreground="{DynamicResource LuminaTextMutedBrush}"
                            IsVisible="{TemplateBinding ShowClearButton}"
                            Theme="{StaticResource LuminaPickerFlyoutButton}">
                        <PathIcon Width="{DynamicResource LuminaCascaderClearIconSize}"
                                  Height="{DynamicResource LuminaCascaderClearIconSize}"
                                  Data="M18.3,5.71 L12,12 L18.3,18.29 L16.89,19.7 L10.59,13.41 L4.29,19.7 L2.88,18.29 L9.17,12 L2.88,5.71 L4.29,4.3 L10.59,10.59 L16.89,4.3 Z"
                                  Foreground="{Binding $parent[Button].Foreground}" />
                    </Button>

                    <Popup Name="PART_Popup"
                           InheritsTransform="True"
                           IsLightDismissEnabled="True"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="BottomEdgeAlignedLeft"
                           PlacementConstraintAdjustment="FlipY,SlideX,ResizeY"
                           PlacementTarget="{TemplateBinding}"
                           WindowManagerAddShadowHint="False" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[HasSelection=False] /template/ TextBlock#PART_DisplayText">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextMutedBrush}" />
        </Style>

        <Style Selector="^:pointerover /template/ Button#PART_SurfaceButton">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        </Style>

        <Style Selector="^:focus-within /template/ Button#PART_SurfaceButton">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaCascaderDisabledOpacity}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type DatePicker}" TargetType="DatePicker">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="{DynamicResource LuminaPickerPadding}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <ControlTemplate TargetType="DatePicker">
                <DataValidationErrors>
                    <Grid Name="LayoutRoot" Margin="{TemplateBinding Padding}">
                        <Button Name="PART_FlyoutButton"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Padding="{DynamicResource LuminaPickerPadding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Cursor="Hand"
                                DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                                Foreground="{TemplateBinding Foreground}"
                                IsEnabled="{TemplateBinding IsEnabled}"
                                Theme="{StaticResource LuminaPickerFlyoutButton}">
                            <Grid ColumnDefinitions="*,36">
                                <Grid Name="PART_ButtonContentGrid"
                                      Grid.Column="0"
                                      ColumnDefinitions="*,Auto,*,Auto,*">
                                    <TextBlock Name="PART_DayTextBlock"
                                               Padding="{DynamicResource LuminaPickerTextPadding}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{DynamicResource STRING_DATEPICKER_DAY_TEXT}"
                                               TextAlignment="Center" />
                                    <TextBlock Name="PART_MonthTextBlock"
                                               Padding="{DynamicResource LuminaPickerTextPadding}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{DynamicResource STRING_DATEPICKER_MONTH_TEXT}"
                                               TextAlignment="Center" />
                                    <TextBlock Name="PART_YearTextBlock"
                                               Padding="{DynamicResource LuminaPickerTextPadding}"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Center"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{DynamicResource STRING_DATEPICKER_YEAR_TEXT}"
                                               TextAlignment="Center" />
                                    <Rectangle Name="PART_FirstSpacer"
                                               Grid.Column="1"
                                               Width="{DynamicResource LuminaPickerDividerWidth}"
                                               HorizontalAlignment="Center"
                                               Fill="{DynamicResource LuminaDividerBrush}" />
                                    <Rectangle Name="PART_SecondSpacer"
                                               Grid.Column="3"
                                               Width="{DynamicResource LuminaPickerDividerWidth}"
                                               HorizontalAlignment="Center"
                                               Fill="{DynamicResource LuminaDividerBrush}" />
                                </Grid>
                                <Border Grid.Column="1"
                                        Width="{DynamicResource LuminaPickerIconColumnWidth}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch">
                                    <PathIcon Name="PART_Icon"
                                              Width="{DynamicResource LuminaPickerIconSize}"
                                              Height="{DynamicResource LuminaPickerIconSize}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M19,3 L18,3 L18,1 L16,1 L16,3 L8,3 L8,1 L6,1 L6,3 L5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 Z M19,19 L5,19 L5,8 L19,8 Z M7,10 L12,10 L12,15 L7,15 Z"
                                              Foreground="{DynamicResource LuminaTextMutedBrush}" />
                                </Border>
                            </Grid>
                        </Button>

                        <Popup Name="PART_Popup"
                               InheritsTransform="True"
                               IsLightDismissEnabled="True"
                               Placement="Bottom"
                               PlacementTarget="{TemplateBinding}"
                               WindowManagerAddShadowHint="False">
                            <DatePickerPresenter Name="PART_PickerPresenter" />
                        </Popup>
                    </Grid>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Button#PART_FlyoutButton">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        </Style>

        <Style Selector="^:focus-within /template/ Button#PART_FlyoutButton">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        </Style>

        <Style Selector="^:hasnodate /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextMutedBrush}" />
        </Style>

        <Style Selector="^:disabled /template/ Button#PART_FlyoutButton">
            <Setter Property="Opacity" Value="{DynamicResource LuminaPickerDisabledOpacity}" />
        </Style>

        <Style Selector="^.Small">
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPickerSmallMinHeight}" />
        </Style>

        <Style Selector="^.Large">
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPickerLargeMinHeight}" />
        </Style>

        <Style Selector="^[(lumina|LuminaOptions.PopupType)=Sheet]">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type TimePicker}" TargetType="TimePicker">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="{DynamicResource LuminaPickerPadding}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TimePicker">
                <DataValidationErrors>
                    <Grid Name="LayoutRoot" Margin="{TemplateBinding Padding}">
                        <Button Name="PART_FlyoutButton"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Padding="{DynamicResource LuminaPickerPadding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Cursor="Hand"
                                DataValidationErrors.Errors="{TemplateBinding (DataValidationErrors.Errors)}"
                                Foreground="{TemplateBinding Foreground}"
                                IsEnabled="{TemplateBinding IsEnabled}"
                                Theme="{StaticResource LuminaPickerFlyoutButton}">
                            <Grid ColumnDefinitions="*,36">
                                <Grid Name="PART_FlyoutButtonContentGrid"
                                      Grid.Column="0"
                                      ColumnDefinitions="*,Auto,*,Auto,*,Auto,*">
                                    <Border Name="PART_FirstPickerHost"
                                            Grid.Column="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <TextBlock Name="PART_HourTextBlock"
                                                   Padding="{DynamicResource LuminaPickerTextPadding}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="{DynamicResource STRING_TIMEPICKER_HOUR_TEXT}"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <Rectangle Name="PART_FirstColumnDivider"
                                               Grid.Column="1"
                                               Width="{DynamicResource LuminaPickerDividerWidth}"
                                               HorizontalAlignment="Center"
                                               Fill="{DynamicResource LuminaDividerBrush}" />

                                    <Border Name="PART_SecondPickerHost"
                                            Grid.Column="2"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <TextBlock Name="PART_MinuteTextBlock"
                                                   Padding="{DynamicResource LuminaPickerTextPadding}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="{DynamicResource STRING_TIMEPICKER_MINUTE_TEXT}"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <Rectangle Name="PART_SecondColumnDivider"
                                               Grid.Column="3"
                                               Width="{DynamicResource LuminaPickerDividerWidth}"
                                               HorizontalAlignment="Center"
                                               Fill="{DynamicResource LuminaDividerBrush}" />

                                    <Border Name="PART_ThirdPickerHost"
                                            Grid.Column="4"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <TextBlock Name="PART_SecondTextBlock"
                                                   Padding="{DynamicResource LuminaPickerTextPadding}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   Text="{DynamicResource STRING_TIMEPICKER_SECOND_TEXT}"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <Rectangle Name="PART_ThirdColumnDivider"
                                               Grid.Column="5"
                                               Width="{DynamicResource LuminaPickerDividerWidth}"
                                               HorizontalAlignment="Center"
                                               Fill="{DynamicResource LuminaDividerBrush}" />

                                    <Border Name="PART_FourthPickerHost"
                                            Grid.Column="6"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                        <TextBlock Name="PART_PeriodTextBlock"
                                                   Padding="{DynamicResource LuminaPickerTextPadding}"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   FontWeight="{TemplateBinding FontWeight}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   TextAlignment="Center" />
                                    </Border>
                                </Grid>
                                <Border Grid.Column="1"
                                        Width="{DynamicResource LuminaPickerIconColumnWidth}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch">
                                    <PathIcon Name="PART_Icon"
                                              Width="{DynamicResource LuminaPickerIconSize}"
                                              Height="{DynamicResource LuminaPickerIconSize}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M12,20 C16.41,20 20,16.41 20,12 C20,7.59 16.41,4 12,4 C7.59,4 4,7.59 4,12 C4,16.41 7.59,20 12,20 Z M12.5,7 L11,7 L11,13 L16.25,16.15 L17,14.92 L12.5,12.25 Z"
                                              Foreground="{DynamicResource LuminaTextMutedBrush}" />
                                </Border>
                            </Grid>
                        </Button>

                        <Popup Name="PART_Popup"
                               InheritsTransform="True"
                               IsLightDismissEnabled="True"
                               Placement="Bottom"
                               PlacementTarget="{TemplateBinding}"
                               WindowManagerAddShadowHint="False">
                            <TimePickerPresenter Name="PART_PickerPresenter" />
                        </Popup>
                    </Grid>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Button#PART_FlyoutButton">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        </Style>

        <Style Selector="^:focus-within /template/ Button#PART_FlyoutButton">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        </Style>

        <Style Selector="^:hasnotime /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextMutedBrush}" />
        </Style>

        <Style Selector="^:disabled /template/ Button#PART_FlyoutButton">
            <Setter Property="Opacity" Value="{DynamicResource LuminaPickerDisabledOpacity}" />
        </Style>

        <Style Selector="^.Small">
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPickerSmallMinHeight}" />
        </Style>

        <Style Selector="^.Large">
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPickerLargeMinHeight}" />
        </Style>

        <Style Selector="^[(lumina|LuminaOptions.PopupType)=Sheet]">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type Slider}" TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
        <Style Selector="^ /template/ Border#TrackBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaBorderBrush}" />
            <Setter Property="CornerRadius" Value="{DynamicResource LuminaSliderTrackCornerRadius}" />
        </Style>

        <Style Selector="^ /template/ Border#PART_SelectionRange">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^ /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource LuminaSliderThumbBorderThickness}" />
            <Setter Property="Width" Value="{DynamicResource LuminaSliderThumbSize}" />
            <Setter Property="Height" Value="{DynamicResource LuminaSliderThumbSize}" />
        </Style>

        <Style Selector="^:pointerover /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryHoverBrush}" />
            <Setter Property="RenderTransform" Value="scale(1.2)" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaPlaybackSlider}" TargetType="lumina:LuminaPlaybackSlider">
        <Setter Property="Height" Value="{DynamicResource LuminaPlaybackSliderHeight}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaPlaybackSliderHeight}" />
        <Setter Property="TrackHeight" Value="{DynamicResource LuminaPlaybackSliderTrackHeight}" />
        <Setter Property="ThumbSize" Value="{DynamicResource LuminaPlaybackSliderThumbSize}" />
        <Setter Property="Step" Value="{DynamicResource LuminaPlaybackSliderStep}" />
        <Setter Property="TrackBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        <Setter Property="BufferedBrush" Value="{DynamicResource LuminaBorderStrongBrush}" />
        <Setter Property="ProgressBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        <Setter Property="ThumbBrush" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="ThumbBorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaPlaybackSliderDisabledOpacity}" />
        </Style>

        <Style Selector="^.Compact">
            <Setter Property="Height" Value="{DynamicResource LuminaPlaybackSliderCompactHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPlaybackSliderCompactHeight}" />
            <Setter Property="TrackHeight" Value="{DynamicResource LuminaPlaybackSliderCompactTrackHeight}" />
            <Setter Property="ThumbSize" Value="{DynamicResource LuminaPlaybackSliderCompactThumbSize}" />
        </Style>

        <Style Selector="^.Large">
            <Setter Property="Height" Value="{DynamicResource LuminaPlaybackSliderLargeHeight}" />
            <Setter Property="MinHeight" Value="{DynamicResource LuminaPlaybackSliderLargeHeight}" />
            <Setter Property="TrackHeight" Value="{DynamicResource LuminaPlaybackSliderLargeTrackHeight}" />
            <Setter Property="ThumbSize" Value="{DynamicResource LuminaPlaybackSliderLargeThumbSize}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaSemiCircleProgressBar}" TargetType="lumina:LuminaSemiCircleProgressBar">
        <Setter Property="MinWidth" Value="{DynamicResource LuminaSemiCircleProgressMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaSemiCircleProgressMinHeight}" />
        <Setter Property="StrokeThickness" Value="{DynamicResource LuminaSemiCircleProgressStrokeThickness}" />
        <Setter Property="TrackBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        <Setter Property="ProgressBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource LuminaSemiCircleProgressFontSize}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <TextBlock Name="PART_DefaultText"
                               Margin="{TemplateBinding DisplayContentMargin}"
                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                               FontFamily="{TemplateBinding FontFamily}"
                               FontSize="{TemplateBinding DisplayFontSize}"
                               FontWeight="{TemplateBinding FontWeight}"
                               Foreground="{TemplateBinding Foreground}"
                               IsVisible="{TemplateBinding HasDefaultContent}"
                               Text="{TemplateBinding DisplayText}" />

                    <ContentPresenter Name="PART_ContentPresenter"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding DisplayContent}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      IsVisible="{TemplateBinding HasCustomContent}"
                                      Margin="{TemplateBinding DisplayContentMargin}"
                                      TextElement.FontFamily="{TemplateBinding FontFamily}"
                                      TextElement.FontSize="{TemplateBinding DisplayFontSize}"
                                      TextElement.FontWeight="{TemplateBinding FontWeight}"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaSemiCircleProgressDisabledOpacity}" />
        </Style>

        <Style Selector="^.Compact">
            <Setter Property="MinWidth" Value="{DynamicResource LuminaSemiCircleProgressCompactMinWidth}" />
            <Setter Property="MinHeight" Value="{DynamicResource LuminaSemiCircleProgressCompactMinHeight}" />
            <Setter Property="StrokeThickness" Value="{DynamicResource LuminaSemiCircleProgressCompactStrokeThickness}" />
        </Style>

        <Style Selector="^.Large">
            <Setter Property="MinWidth" Value="{DynamicResource LuminaSemiCircleProgressLargeMinWidth}" />
            <Setter Property="MinHeight" Value="{DynamicResource LuminaSemiCircleProgressLargeMinHeight}" />
            <Setter Property="StrokeThickness" Value="{DynamicResource LuminaSemiCircleProgressLargeStrokeThickness}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
