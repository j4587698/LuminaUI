<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:LuminaUI.Converters"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <Thickness x:Key="LuminaShellTopMenuDrawerBorderThickness">0,0,1,0</Thickness>
    <CornerRadius x:Key="LuminaShellTopMenuDrawerCornerRadius">0,4,4,0</CornerRadius>
    <Thickness x:Key="LuminaShellMenuHeaderMargin">16</Thickness>
    <x:Double x:Key="LuminaShellMenuHeaderHeight">48</x:Double>
    <Thickness x:Key="LuminaShellMenuScrollMargin">16,0,16,16</Thickness>
    <Thickness x:Key="LuminaShellMenuFooterMargin">16</Thickness>
    <Thickness x:Key="LuminaShellMenuFooterPadding">0,16,0,0</Thickness>
    <Thickness x:Key="LuminaShellMenuCompactToggleHostMargin">16,0,16,16</Thickness>
    <x:Double x:Key="LuminaShellMenuCompactToggleSize">36</x:Double>
    <x:Double x:Key="LuminaShellMenuCompactToggleIconSize">14</x:Double>
    <Thickness x:Key="LuminaShellPageContentPadding">0</Thickness>
    <x:Double x:Key="LuminaShellContentHeaderHeight">48</x:Double>
    <Thickness x:Key="LuminaShellContentHeaderMargin">0</Thickness>
    <Thickness x:Key="LuminaShellContentHeaderPadding">0,0,16,0</Thickness>
    <x:Double x:Key="LuminaShellContentHeaderFontSize">20</x:Double>
    <x:Double x:Key="LuminaShellCompactContentHeaderHeight">40</x:Double>
    <Thickness x:Key="LuminaShellCompactContentHeaderPadding">4,0,12,0</Thickness>
    <x:Double x:Key="LuminaShellCompactContentHeaderFontSize">18</x:Double>
    <Thickness x:Key="LuminaShellHeaderlessMenuToggleMargin">16</Thickness>
    <Thickness x:Key="LuminaShellTopMenuDrawerHeaderMargin">16,10,16,8</Thickness>
    <x:Double x:Key="LuminaShellTopMenuDrawerHeaderHeight">44</x:Double>
    <Thickness x:Key="LuminaShellTopMenuDrawerScrollMargin">16,0,16,12</Thickness>
    <Thickness x:Key="LuminaShellTopMenuDrawerFooterMargin">16,12,16,12</Thickness>
    <x:Double x:Key="LuminaShellOverlayCollapsedOpacity">0</x:Double>
    <x:Double x:Key="LuminaShellOverlayVisibleOpacity">1</x:Double>
    <Thickness x:Key="LuminaShellMenuCompactToggleHostCompactMargin">6</Thickness>
    <Thickness x:Key="LuminaShellMenuCompactScrollMargin">6,0,6,16</Thickness>

    <ControlTheme x:Key="{x:Type lumina:LuminaShell}" TargetType="lumina:LuminaShell">
        <Setter Property="Background" Value="{DynamicResource LuminaBackgroundBrush}" />
        <Setter Property="PaneBackground" Value="{DynamicResource LuminaNavigationPaneBrush}" />
        <Setter Property="PageContentPadding" Value="{DynamicResource LuminaShellPageContentPadding}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_Root" Background="{TemplateBinding Background}">
                    <SplitView Name="PART_SplitView" 
                               IsPaneOpen="{TemplateBinding EffectiveIsMenuOpen}" 
                               OpenPaneLength="{TemplateBinding EffectiveOpenPaneLength}"
                               CompactPaneLength="{TemplateBinding EffectiveCompactPaneLength}"
                               PaneBackground="{TemplateBinding PaneBackground}"
                               Background="Transparent">
                        
                        <SplitView.Pane>
                            <!-- Menu pane is separated by surface tone, not by an extra border. -->
                            <Border Background="{TemplateBinding PaneBackground}"
                                    IsVisible="{TemplateBinding EffectiveIsShellChromeVisible}"
                                    Padding="{TemplateBinding LayoutSafeAreaPadding}"
                                    lumina:LuminaShell.IsMenuCompact="{TemplateBinding EffectiveIsMenuCompact}">
                                <Grid RowDefinitions="Auto,*,Auto,Auto">
                                    <!-- 菜单头部插槽 -->
                                    <Border Name="PART_MenuHeader"
                                            Grid.Row="0"
                                            Margin="{DynamicResource LuminaShellMenuHeaderMargin}"
                                            Height="{DynamicResource LuminaShellMenuHeaderHeight}"
                                            ClipToBounds="True"
                                            IsVisible="{TemplateBinding EffectiveIsMenuOpen}">
                                        <ContentPresenter Content="{TemplateBinding EffectiveMenuHeader}" VerticalAlignment="Center" />
                                    </Border>
                                    
                                    <!-- 菜单内容投射器 -->
                                    <ScrollViewer Name="PART_MenuScrollViewer"
                                                  Grid.Row="1"
                                                  Margin="{DynamicResource LuminaShellMenuScrollMargin}"
                                                  BringIntoViewOnFocusChange="False"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Hidden">
                                        <ContentPresenter Content="{TemplateBinding EffectiveMenuContent}" />
                                    </ScrollViewer>
                                    
                                    <!-- 菜单底部插槽 -->
                                    <Border Name="PART_MenuFooter"
                                            Grid.Row="2"
                                            Margin="{DynamicResource LuminaShellMenuFooterMargin}"
                                            Padding="{DynamicResource LuminaShellMenuFooterPadding}"
                                            ClipToBounds="False"
                                            IsVisible="{TemplateBinding EffectiveIsMenuOpen}">
                                        <ContentPresenter Content="{TemplateBinding EffectiveMenuFooter}" />
                                    </Border>

                                    <Border Name="PART_MenuCompactToggleHost"
                                            Grid.Row="3"
                                            Margin="{DynamicResource LuminaShellMenuCompactToggleHostMargin}"
                                            IsVisible="{TemplateBinding CanCompactMenu}">
                                        <Button Name="PART_MenuCompactToggle"
                                                Classes="Ghost Icon"
                                                Width="{DynamicResource LuminaShellMenuCompactToggleSize}"
                                                Height="{DynamicResource LuminaShellMenuCompactToggleSize}"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Command="{Binding $parent[lumina:LuminaShell].ToggleCompactModeCommand}"
                                                ToolTip.Tip="Toggle compact mode">
                                            <PathIcon Name="PART_MenuCompactToggleIcon"
                                                      Width="{DynamicResource LuminaShellMenuCompactToggleIconSize}"
                                                      Height="{DynamicResource LuminaShellMenuCompactToggleIconSize}"
                                                      Data="M15.41,7.41L10.83,12L15.41,16.59L14,18L8,12L14,6L15.41,7.41Z"
                                                      Foreground="{DynamicResource LuminaTextMutedBrush}"
                                                      RenderTransformOrigin="50%,50%">
                                                <PathIcon.Transitions>
                                                    <Transitions>
                                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                                                    </Transitions>
                                                </PathIcon.Transitions>
                                            </PathIcon>
                                        </Button>
                                    </Border>
                                </Grid>
                            </Border>
                        </SplitView.Pane>
                        
                        <SplitView.Content>
                            <Border Padding="{TemplateBinding LayoutSafeAreaPadding}">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- 主区域头部栏插槽 -->
                                    <Border Name="PART_ContentHeader"
                                            Grid.Row="0"
                                            MinHeight="{DynamicResource LuminaShellContentHeaderHeight}"
                                            Margin="{DynamicResource LuminaShellContentHeaderMargin}"
                                            Padding="{DynamicResource LuminaShellContentHeaderPadding}"
                                            Background="Transparent"
                                            IsVisible="{TemplateBinding EffectiveIsShellHeaderVisible}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0" VerticalAlignment="Center">
                                            <lumina:LuminaHamburgerButton Name="PART_ContentHeaderMenuToggle"
                                                                          Grid.Column="0"
                                                                          Width="{DynamicResource LuminaShellContentHeaderHeight}"
                                                                          Height="{DynamicResource LuminaShellContentHeaderHeight}"
                                                                          IsVisible="{TemplateBinding EffectiveIsPaneToggleVisible}"
                                                                          IsOpen="{TemplateBinding IsMenuOpen}"
                                                                          Command="{Binding ToggleMenuCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                                                          ToolTip.Tip="Toggle navigation pane" />

                                            <StackPanel Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Name="PART_ContentHeaderTitleText"
                                                           Text="{TemplateBinding EffectiveHeaderTitle, Converter={x:Static converters:LuminaShellHeaderConverters.ToText}}"
                                                           FontSize="{DynamicResource LuminaShellContentHeaderFontSize}"
                                                           FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{TemplateBinding EffectiveHeaderTitle, Converter={x:Static converters:LuminaShellHeaderConverters.IsText}}" />
                                                <ContentPresenter Name="PART_ContentHeaderTitle"
                                                                  Content="{TemplateBinding EffectiveHeaderTitle}"
                                                                  IsVisible="{TemplateBinding EffectiveHeaderTitle, Converter={x:Static converters:LuminaShellHeaderConverters.IsCustomContent}}" />
                                                <TextBlock Name="PART_ContentHeaderSubtitleText"
                                                           Text="{TemplateBinding ActivePageSubtitle, Converter={x:Static converters:LuminaShellHeaderConverters.ToText}}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource LuminaTextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{TemplateBinding ActivePageSubtitle, Converter={x:Static converters:LuminaShellHeaderConverters.IsText}}" />
                                                <ContentPresenter Name="PART_ContentHeaderSubtitle"
                                                                  Content="{TemplateBinding ActivePageSubtitle}"
                                                                  IsVisible="{TemplateBinding ActivePageSubtitle, Converter={x:Static converters:LuminaShellHeaderConverters.IsCustomContent}}" />
                                            </StackPanel>

                                            <ContentPresenter Grid.Column="2"
                                                              Content="{TemplateBinding ActivePageActions}"
                                                              VerticalAlignment="Center"
                                                              IsVisible="{TemplateBinding ActivePageActions, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        </Grid>
                                    </Border>
                                
                                <!-- 主视图内容投射器 (添加了平滑切页动画) -->
                                <Border Name="PART_PageHost"
                                        Grid.Row="1"
                                        ClipToBounds="True"
                                        Padding="{TemplateBinding EffectivePageContentPadding}">
                                    <TransitioningContentControl Content="{TemplateBinding Content}">
                                        <TransitioningContentControl.PageTransition>
                                            <CrossFade Duration="0:0:0.25" />
                                        </TransitioningContentControl.PageTransition>
                                    </TransitioningContentControl>
                                </Border>
                                </Grid>
                            </Border>
                        </SplitView.Content>
                    </SplitView>

                    <lumina:LuminaHamburgerButton Name="PART_HeaderlessMenuToggle"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="{DynamicResource LuminaShellHeaderlessMenuToggleMargin}"
                                                  ZIndex="900"
                                                  Background="{DynamicResource LuminaSurfaceBrush}"
                                                  BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                                  IsVisible="{TemplateBinding EffectiveIsHeaderlessMenuToggleVisible}"
                                                  IsOpen="{TemplateBinding IsMenuOpen}"
                                                  Command="{Binding ToggleMenuCommand, RelativeSource={RelativeSource TemplatedParent}}" />

                    <!-- ============================================== -->
                    <!-- Dialog Overlay (遮罩层与弹窗容器)                  -->
                    <!-- ============================================== -->
                    <Border Name="PART_DialogOverlay"
                            Background="Transparent"
                            Opacity="{DynamicResource LuminaShellOverlayCollapsedOpacity}"
                            IsHitTestVisible="False"
                            ZIndex="1000">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                            </Transitions>
                        </Border.Transitions>
                        
                        <!-- 对弹窗实体进行缩放滑入动画 -->
                        <Grid>
                            <lumina:LuminaBackdropBlur BlurRadius="{DynamicResource LuminaOverlayBackdropBlurRadius}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch" />
                            <Border Background="{DynamicResource LuminaOverlayScrimBrush}"
                                    IsHitTestVisible="False" />

                            <Border Padding="{TemplateBinding OverlaySafeAreaPadding}">
                                <Border Name="PART_DialogContainer">
                                    <Border.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut" />
                                        </Transitions>
                                    </Border.Transitions>
                                    <ContentPresenter Content="{TemplateBinding DialogContent}"
                                                      Margin="{DynamicResource LuminaOverlayDialogMargin}"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ============================================== -->
                    <!-- BottomSheet Overlay (底部抽屉遮罩)                  -->
                    <!-- ============================================== -->
                    <Border Name="PART_DrawerOverlay"
                            Background="Transparent"
                            Opacity="{DynamicResource LuminaShellOverlayCollapsedOpacity}"
                            IsHitTestVisible="False"
                            ZIndex="1400">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                            </Transitions>
                        </Border.Transitions>

                        <Grid>
                            <lumina:LuminaBackdropBlur BlurRadius="{DynamicResource LuminaOverlayBackdropBlurRadius}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch" />
                            <Border Background="{DynamicResource LuminaOverlayScrimBrush}"
                                    IsHitTestVisible="False" />

                            <ContentPresenter Name="PART_DrawerContainer"
                                              Content="{TemplateBinding DrawerContent}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Grid>
                    </Border>

                    <Border Name="PART_BottomSheetOverlay"
                            Background="Transparent"
                            Opacity="{DynamicResource LuminaShellOverlayCollapsedOpacity}"
                            IsHitTestVisible="False"
                            ZIndex="1500">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                            </Transitions>
                        </Border.Transitions>
                        
                        <!-- 底部容器，默认向下平移 100% 藏在屏幕外 -->
                        <Grid>
                            <lumina:LuminaBackdropBlur BlurRadius="{DynamicResource LuminaOverlayBackdropBlurRadius}"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch" />
                            <Border Background="{DynamicResource LuminaOverlayScrimBrush}"
                                    IsHitTestVisible="False" />

                            <Border Name="PART_BottomSheetContainer"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch">
                                <ContentPresenter Content="{TemplateBinding BottomSheetContent}" />
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- ============================================== -->
                    <!-- Toast Overlay (全局底部通知)                       -->
                    <!-- ============================================== -->
                    <Border ZIndex="2000"
                            Padding="{TemplateBinding OverlaySafeAreaPadding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            IsHitTestVisible="False">
                        <ContentPresenter Name="PART_ToastPresenter" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>

        <!-- ============================================== -->
        <!-- 响应式与动画控制逻辑                               -->
        <!-- ============================================== -->

        <!-- 默认桌面模式：侧边栏是嵌入主布局的 (推挤主内容) -->
        <Style Selector="^ /template/ SplitView#PART_SplitView">
            <Setter Property="DisplayMode" Value="Inline" />
        </Style>

        <Style Selector="^:pane-left-compact /template/ SplitView#PART_SplitView">
            <Setter Property="DisplayMode" Value="CompactInline" />
        </Style>

        <Style Selector="^:menucompact /template/ Border#PART_MenuHeader">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^:menucompact /template/ Border#PART_MenuCompactToggleHost">
            <Setter Property="Margin" Value="{DynamicResource LuminaShellMenuCompactToggleHostCompactMargin}" />
        </Style>

        <Style Selector="^:menucompact /template/ Button#PART_MenuCompactToggle">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style Selector="^ /template/ PathIcon#PART_MenuCompactToggleIcon">
            <Setter Property="RenderTransform" Value="rotate(0deg)" />
        </Style>

        <Style Selector="^:menucompact /template/ PathIcon#PART_MenuCompactToggleIcon">
            <Setter Property="RenderTransform" Value="rotate(180deg)" />
        </Style>

        <Style Selector="^:menucompact /template/ ScrollViewer#PART_MenuScrollViewer">
            <Setter Property="Margin" Value="{DynamicResource LuminaShellMenuCompactScrollMargin}" />
        </Style>

        <Style Selector="^ /template/ lumina|LuminaHamburgerButton#PART_ContentHeaderMenuToggle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="^ /template/ lumina|LuminaHamburgerButton#PART_ContentHeaderMenuToggle:checked">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        </Style>

        <Style Selector="^ /template/ lumina|LuminaHamburgerButton#PART_ContentHeaderMenuToggle:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^.WindowGlass">
            <Setter Property="Background" Value="{DynamicResource LuminaWindowGlassBackgroundBrush}" />
            <Setter Property="PaneBackground" Value="{DynamicResource LuminaWindowGlassPaneBrush}" />
        </Style>

        <!-- 小屏幕模式：侧边栏变为浮动抽屉 (覆盖主内容) -->
        <Style Selector="^:small-screen /template/ SplitView#PART_SplitView">
            <Setter Property="DisplayMode" Value="Overlay" />
        </Style>

        <Style Selector="^:small-screen /template/ Border#PART_ContentHeader">
            <Setter Property="MinHeight" Value="{DynamicResource LuminaShellCompactContentHeaderHeight}" />
            <Setter Property="Padding" Value="{DynamicResource LuminaShellCompactContentHeaderPadding}" />
        </Style>

        <Style Selector="^:small-screen /template/ lumina|LuminaHamburgerButton#PART_ContentHeaderMenuToggle">
            <Setter Property="Width" Value="{DynamicResource LuminaShellCompactContentHeaderHeight}" />
            <Setter Property="Height" Value="{DynamicResource LuminaShellCompactContentHeaderHeight}" />
        </Style>

        <Style Selector="^:small-screen /template/ TextBlock#PART_ContentHeaderTitleText">
            <Setter Property="FontSize" Value="{DynamicResource LuminaShellCompactContentHeaderFontSize}" />
        </Style>

        <Style Selector="^:small-screen /template/ Border#PART_MenuCompactToggleHost">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        
        <!-- Dialog 打开时的动画状态 -->
        <Style Selector="^[IsDialogOpen=True] /template/ Border#PART_DialogOverlay">
            <Setter Property="Opacity" Value="{DynamicResource LuminaShellOverlayVisibleOpacity}" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
        <!-- Dialog 关闭时的卡片缩放偏移 -->
        <Style Selector="^[IsDialogOpen=False] /template/ Border#PART_DialogContainer">
            <Setter Property="RenderTransform" Value="scale(0.95) translateY(10px)" />
        </Style>
        <!-- Dialog 打开时的卡片正常位置 -->
        <Style Selector="^[IsDialogOpen=True] /template/ Border#PART_DialogContainer">
            <Setter Property="RenderTransform" Value="scale(1) translateY(0px)" />
        </Style>

        <!-- BottomSheet 打开时的动画状态 -->
        <Style Selector="^[IsBottomSheetOpen=True] /template/ Border#PART_BottomSheetOverlay">
            <Setter Property="Opacity" Value="{DynamicResource LuminaShellOverlayVisibleOpacity}" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

            <!-- 回到原本位置 -->

        <Style Selector="^[IsDrawerOpen=True] /template/ Border#PART_DrawerOverlay">
            <Setter Property="Opacity" Value="{DynamicResource LuminaShellOverlayVisibleOpacity}" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>

    </ControlTheme>

</ResourceDictionary>
