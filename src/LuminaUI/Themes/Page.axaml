<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <Thickness x:Key="LuminaPageHeaderMargin">0,0,0,16</Thickness>
    <x:Double x:Key="LuminaPageHeaderFontSize">28</x:Double>
    <Thickness x:Key="LuminaPageTopCommandBarMargin">0,0,0,12</Thickness>
    <Thickness x:Key="LuminaPageBottomCommandBarMargin">0,12,0,0</Thickness>
    <Thickness x:Key="LuminaPageStateHostPadding">24</Thickness>
    <x:Double x:Key="LuminaPageStateMaxWidth">420</x:Double>
    <x:Double x:Key="LuminaPageLoadingStateSpacing">16</x:Double>
    <x:Double x:Key="LuminaPageLoadingProgressWidth">160</x:Double>
    <x:Double x:Key="LuminaPageLoadingProgressHeight">4</x:Double>
    <x:Double x:Key="LuminaPageStateTextFontSize">14</x:Double>
    <x:Double x:Key="LuminaPageEmptyStateSpacing">14</x:Double>
    <x:Double x:Key="LuminaPageErrorStateSpacing">14</x:Double>
    <x:Double x:Key="LuminaPageStateIconSize">48</x:Double>
    <CornerRadius x:Key="LuminaPageStateIconCornerRadius">24</CornerRadius>
    <Thickness x:Key="LuminaPageEmptyStateIconBorderThickness">1</Thickness>
    <x:Double x:Key="LuminaPageStateIconFontSize">22</x:Double>

    <ControlTheme x:Key="{x:Type lumina:LuminaPage}" TargetType="lumina:LuminaPage">
        <Setter Property="AutomaticallyApplySafeAreaPadding" Value="True" />
        <Setter Property="Background" Value="{DynamicResource LuminaBackgroundBrush}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <Border Grid.Row="0"
                                Margin="{DynamicResource LuminaPageHeaderMargin}"
                                IsVisible="{TemplateBinding Header, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              TextElement.FontSize="{DynamicResource LuminaPageHeaderFontSize}"
                                              TextElement.FontWeight="Bold"
                                              TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        </Border>

                        <ContentPresenter Grid.Row="1"
                                          Margin="{DynamicResource LuminaPageTopCommandBarMargin}"
                                          Content="{TemplateBinding TopCommandBar}"
                                          IsVisible="{TemplateBinding TopCommandBar, Converter={x:Static ObjectConverters.IsNotNull}}" />

                        <Grid Grid.Row="2" ClipToBounds="True">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <Border Name="PART_StateHost"
                                    Background="{TemplateBinding Background}"
                                    Padding="{DynamicResource LuminaPageStateHostPadding}">
                                <Grid MaxWidth="{DynamicResource LuminaPageStateMaxWidth}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Grid Name="PART_LoadingState">
                                        <StackPanel Spacing="{DynamicResource LuminaPageLoadingStateSpacing}"
                                                    HorizontalAlignment="Center"
                                                    IsVisible="{TemplateBinding LoadingContent, Converter={x:Static ObjectConverters.IsNull}}">
                                            <ProgressBar Width="{DynamicResource LuminaPageLoadingProgressWidth}"
                                                         Height="{DynamicResource LuminaPageLoadingProgressHeight}"
                                                         IsIndeterminate="True"
                                                         Foreground="{DynamicResource LuminaPrimaryBrush}" />
                                            <TextBlock Text="{l10n:Loc Lumina.Page.Loading}"
                                                       FontSize="{DynamicResource LuminaPageStateTextFontSize}"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                                        </StackPanel>
                                        <ContentPresenter Content="{TemplateBinding LoadingContent}"
                                                          IsVisible="{TemplateBinding LoadingContent, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </Grid>

                                    <Grid Name="PART_EmptyState">
                                        <StackPanel Spacing="{DynamicResource LuminaPageEmptyStateSpacing}"
                                                    HorizontalAlignment="Center"
                                                    IsVisible="{TemplateBinding EmptyContent, Converter={x:Static ObjectConverters.IsNull}}">
                                            <Border Width="{DynamicResource LuminaPageStateIconSize}"
                                                    Height="{DynamicResource LuminaPageStateIconSize}"
                                                    CornerRadius="{DynamicResource LuminaPageStateIconCornerRadius}"
                                                    Background="{DynamicResource LuminaSurfaceBrush}"
                                                    BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                                    BorderThickness="{DynamicResource LuminaPageEmptyStateIconBorderThickness}">
                                                <TextBlock Text="—"
                                                           FontSize="{DynamicResource LuminaPageStateIconFontSize}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource LuminaTextMutedBrush}" />
                                            </Border>
                                            <TextBlock Text="{l10n:Loc Lumina.Page.Empty}"
                                                       FontSize="{DynamicResource LuminaPageStateTextFontSize}"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                                        </StackPanel>
                                        <ContentPresenter Content="{TemplateBinding EmptyContent}"
                                                          IsVisible="{TemplateBinding EmptyContent, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </Grid>

                                    <Grid Name="PART_ErrorState">
                                        <StackPanel Spacing="{DynamicResource LuminaPageErrorStateSpacing}"
                                                    HorizontalAlignment="Center"
                                                    IsVisible="{TemplateBinding ErrorContent, Converter={x:Static ObjectConverters.IsNull}}">
                                            <Border Width="{DynamicResource LuminaPageStateIconSize}"
                                                    Height="{DynamicResource LuminaPageStateIconSize}"
                                                    CornerRadius="{DynamicResource LuminaPageStateIconCornerRadius}"
                                                    Background="{DynamicResource LuminaDangerHoverBrush}">
                                                <TextBlock Text="!"
                                                           FontSize="{DynamicResource LuminaPageStateIconFontSize}"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource LuminaDangerForegroundBrush}" />
                                            </Border>
                                            <TextBlock Text="{l10n:Loc Lumina.Page.Error}"
                                                       FontSize="{DynamicResource LuminaPageStateTextFontSize}"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                                        </StackPanel>
                                        <ContentPresenter Content="{TemplateBinding ErrorContent}"
                                                          IsVisible="{TemplateBinding ErrorContent, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <ContentPresenter Grid.Row="3"
                                          Margin="{DynamicResource LuminaPageBottomCommandBarMargin}"
                                          Content="{TemplateBinding BottomCommandBar}"
                                          IsVisible="{TemplateBinding BottomCommandBar, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PART_StateHost">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ Grid#PART_LoadingState">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ Grid#PART_EmptyState">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ Grid#PART_ErrorState">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[PageState=Loading] /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[PageState=Loading] /template/ Border#PART_StateHost">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^[PageState=Loading] /template/ Grid#PART_LoadingState">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^[PageState=Empty] /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[PageState=Empty] /template/ Border#PART_StateHost">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^[PageState=Empty] /template/ Grid#PART_EmptyState">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^[PageState=Error] /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[PageState=Error] /template/ Border#PART_StateHost">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^[PageState=Error] /template/ Grid#PART_ErrorState">
            <Setter Property="IsVisible" Value="True" />
        </Style>

    </ControlTheme>

</ResourceDictionary>
