<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <Thickness x:Key="LuminaNavigationItemHeaderBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaNavigationItemHeaderCornerRadius">8</CornerRadius>
    <Thickness x:Key="LuminaNavigationItemHeaderPadding">10,8</Thickness>
    <x:Double x:Key="LuminaNavigationItemHeaderColumnSpacing">8</x:Double>
    <x:Double x:Key="LuminaNavigationItemIndicatorWidth">3</x:Double>
    <CornerRadius x:Key="LuminaNavigationItemIndicatorCornerRadius">2</CornerRadius>
    <x:Double x:Key="LuminaNavigationItemIndicatorCollapsedOpacity">0</x:Double>
    <x:Double x:Key="LuminaNavigationItemIndicatorFocusOpacity">0.55</x:Double>
    <x:Double x:Key="LuminaNavigationItemIndicatorSelectedOpacity">1</x:Double>
    <x:Double x:Key="LuminaNavigationItemIconWidth">20</x:Double>
    <x:Double x:Key="LuminaNavigationItemFontSize">14</x:Double>
    <x:Double x:Key="LuminaNavigationItemChevronSize">12</x:Double>
    <x:Double x:Key="LuminaNavigationItemChevronCollapsedOpacity">0</x:Double>
    <x:Double x:Key="LuminaNavigationItemChevronVisibleOpacity">0.85</x:Double>
    <x:Double x:Key="LuminaNavigationItemItemsContainerCollapsedHeight">0</x:Double>
    <x:Double x:Key="LuminaNavigationItemItemsContainerCollapsedOpacity">0</x:Double>
    <Thickness x:Key="LuminaNavigationItemItemsPresenterMargin">14,4,0,0</Thickness>
    <Thickness x:Key="LuminaNavigationItemCompactPadding">6,8</Thickness>
    <Thickness x:Key="LuminaNavigationItemChildPadding">8,7</Thickness>
    <x:Double x:Key="LuminaNavigationItemChildFontSize">13</x:Double>
    <Thickness x:Key="LuminaContentPagePadding">16</Thickness>
    <Thickness x:Key="LuminaContentPageHeaderMargin">0,0,0,16</Thickness>
    <x:Double x:Key="LuminaContentPageHeaderFontSize">28</x:Double>

    <ControlTheme x:Key="{x:Type lumina:LuminaNavigationItem}" TargetType="lumina:LuminaNavigationItem">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel>
                    <Border Name="PART_Header"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="{DynamicResource LuminaNavigationItemHeaderBorderThickness}"
                            CornerRadius="{DynamicResource LuminaNavigationItemHeaderCornerRadius}"
                            Padding="{DynamicResource LuminaNavigationItemHeaderPadding}"
                            Cursor="Hand">
                        <Grid>
                            <Grid Name="PART_HeaderLayout"
                                  ColumnDefinitions="Auto,Auto,*,Auto"
                                  ColumnSpacing="{DynamicResource LuminaNavigationItemHeaderColumnSpacing}">
                                <Border Name="PART_Indicator"
                                        Grid.Column="0"
                                        Width="{DynamicResource LuminaNavigationItemIndicatorWidth}"
                                        CornerRadius="{DynamicResource LuminaNavigationItemIndicatorCornerRadius}"
                                        Background="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}"
                                        Opacity="{DynamicResource LuminaNavigationItemIndicatorCollapsedOpacity}" />

                                <ContentPresenter Name="PART_IconPresenter"
                                                  Grid.Column="1"
                                                  Width="{DynamicResource LuminaNavigationItemIconWidth}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Icon}"
                                                  TextElement.FontSize="{DynamicResource LuminaNavigationItemFontSize}"
                                                  TextElement.Foreground="{DynamicResource LuminaTextMutedBrush}" />

                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Header}"
                                                  TextElement.FontSize="{DynamicResource LuminaNavigationItemFontSize}"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}" />

                                <PathIcon Name="PART_Chevron"
                                          Grid.Column="3"
                                          Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Width="{DynamicResource LuminaNavigationItemChevronSize}"
                                          Height="{DynamicResource LuminaNavigationItemChevronSize}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource LuminaTextMutedBrush}"
                                          Opacity="{DynamicResource LuminaNavigationItemChevronCollapsedOpacity}"
                                          RenderTransformOrigin="50%,50%">
                                    <PathIcon.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                                        </Transitions>
                                    </PathIcon.Transitions>
                                </PathIcon>
                            </Grid>

                            <ContentPresenter Name="PART_CompactIconPresenter"
                                              IsVisible="False"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}"
                                              TextElement.FontSize="{DynamicResource LuminaNavigationItemFontSize}"
                                              TextElement.Foreground="{DynamicResource LuminaTextMutedBrush}" />
                        </Grid>
                    </Border>

                    <Border Name="PART_ItemsContainer"
                            Height="{DynamicResource LuminaNavigationItemItemsContainerCollapsedHeight}"
                            Opacity="{DynamicResource LuminaNavigationItemItemsContainerCollapsedOpacity}"
                            ClipToBounds="True"
                            IsVisible="False">
                        <ItemsPresenter Name="PART_ItemsPresenter" Margin="{DynamicResource LuminaNavigationItemItemsPresenterMargin}" />
                    </Border>
                </StackPanel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PART_Header">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^:headerpointerover /template/ Border#PART_Header">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="^:headerpointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        </Style>

        <Style Selector="^:focus-visible /template/ Border#PART_Indicator">
            <Setter Property="Opacity" Value="{DynamicResource LuminaNavigationItemIndicatorFocusOpacity}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_Header">
            <Setter Property="Background" Value="{DynamicResource LuminaNavigationPaneItemSelectedBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_Indicator">
            <Setter Property="Opacity" Value="{DynamicResource LuminaNavigationItemIndicatorSelectedOpacity}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_CompactIconPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:hasitems /template/ PathIcon#PART_Chevron">
            <Setter Property="Opacity" Value="{DynamicResource LuminaNavigationItemChevronVisibleOpacity}" />
        </Style>

        <Style Selector="^ /template/ PathIcon#PART_Chevron">
            <Setter Property="RenderTransform" Value="rotate(0deg)" />
        </Style>

        <Style Selector="^:expanded /template/ PathIcon#PART_Chevron">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>

        <Style Selector="^:compact /template/ Border#PART_Header">
            <Setter Property="Padding" Value="{DynamicResource LuminaNavigationItemCompactPadding}" />
        </Style>

        <Style Selector="^:compact /template/ Grid#PART_HeaderLayout">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^:compact /template/ ContentPresenter#PART_CompactIconPresenter">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^.Child /template/ Border#PART_Header">
            <Setter Property="Padding" Value="{DynamicResource LuminaNavigationItemChildPadding}" />
        </Style>

        <Style Selector="^.Child /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.FontSize" Value="{DynamicResource LuminaNavigationItemChildFontSize}" />
            <Setter Property="TextElement.FontWeight" Value="Medium" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type ContentPage}" TargetType="ContentPage">
        <Setter Property="Padding" Value="{DynamicResource LuminaContentPagePadding}" />
        <Setter Property="Background" Value="{DynamicResource LuminaBackgroundBrush}" />
        
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Header Area -->
                        <Border Grid.Row="0" 
                                Margin="{DynamicResource LuminaContentPageHeaderMargin}"
                                IsVisible="{TemplateBinding Header, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ContentPresenter Content="{TemplateBinding Header}" 
                                              TextElement.FontSize="{DynamicResource LuminaContentPageHeaderFontSize}"
                                              TextElement.FontWeight="Bold"
                                              TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        </Border>

                        <!-- Main Content -->
                        <ContentPresenter Grid.Row="1"
                                          Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>

