<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <ControlTheme x:Key="{x:Type lumina:LuminaNavigationItem}" TargetType="lumina:LuminaNavigationItem">
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel>
                    <Border Name="PART_Header"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8"
                            Cursor="Hand">
                        <Grid>
                            <Grid Name="PART_HeaderLayout"
                                  ColumnDefinitions="3,24,*,16"
                                  ColumnSpacing="8">
                                <Border Name="PART_Indicator"
                                        Grid.Column="0"
                                        Width="3"
                                        CornerRadius="2"
                                        Background="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}"
                                        Opacity="0" />

                                <ContentPresenter Name="PART_IconPresenter"
                                                  Grid.Column="1"
                                                  Width="20"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Icon}"
                                                  TextElement.FontSize="14"
                                                  TextElement.Foreground="{DynamicResource LuminaTextMutedBrush}" />

                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Header}"
                                                  TextElement.FontSize="14"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}" />

                                <PathIcon Name="PART_Chevron"
                                          Grid.Column="3"
                                          Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                          Width="12"
                                          Height="12"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource LuminaTextMutedBrush}"
                                          Opacity="0"
                                          RenderTransformOrigin="50%,50%">
                                    <PathIcon.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                                        </Transitions>
                                    </PathIcon.Transitions>
                                </PathIcon>
                            </Grid>

                            <ContentPresenter Name="PART_CompactIconPresenter"
                                              IsVisible="False"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}"
                                              TextElement.FontSize="14"
                                              TextElement.Foreground="{DynamicResource LuminaTextMutedBrush}" />
                        </Grid>
                    </Border>

                    <Border Name="PART_ItemsContainer"
                            Height="0"
                            Opacity="0"
                            ClipToBounds="True"
                            IsVisible="False">
                        <ItemsPresenter Name="PART_ItemsPresenter" Margin="14,4,0,0" />
                    </Border>
                </StackPanel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PART_Header">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^:headerpointerover /template/ Border#PART_Header">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="^:headerpointerover /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        </Style>

        <Style Selector="^:focus-visible /template/ Border#PART_Indicator">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_Header">
            <Setter Property="Background" Value="{DynamicResource LuminaNavigationPaneItemSelectedBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_Indicator">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_IconPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_CompactIconPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaNavigationPaneItemSelectedForegroundBrush}" />
        </Style>

        <Style Selector="^:hasitems /template/ PathIcon#PART_Chevron">
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <Style Selector="^ /template/ PathIcon#PART_Chevron">
            <Setter Property="RenderTransform" Value="rotate(0deg)" />
        </Style>

        <Style Selector="^:expanded /template/ PathIcon#PART_Chevron">
            <Setter Property="RenderTransform" Value="rotate(90deg)" />
        </Style>

        <Style Selector="^:compact /template/ Border#PART_Header">
            <Setter Property="Padding" Value="6,8" />
        </Style>

        <Style Selector="^:compact /template/ Grid#PART_HeaderLayout">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^:compact /template/ ContentPresenter#PART_CompactIconPresenter">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^.Child /template/ Border#PART_Header">
            <Setter Property="Padding" Value="8,7" />
        </Style>

        <Style Selector="^.Child /template/ ContentPresenter#PART_HeaderPresenter">
            <Setter Property="TextElement.FontSize" Value="13" />
            <Setter Property="TextElement.FontWeight" Value="Medium" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type ContentPage}" TargetType="ContentPage">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{DynamicResource LuminaBackgroundBrush}" />
        
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                    <Grid RowDefinitions="Auto,*">
                        <!-- Header Area -->
                        <Border Grid.Row="0" 
                                Margin="0,0,0,16"
                                IsVisible="{TemplateBinding Header, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ContentPresenter Content="{TemplateBinding Header}" 
                                              TextElement.FontSize="28"
                                              TextElement.FontWeight="Bold"
                                              TextElement.Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        </Border>

                        <!-- Main Content -->
                        <ContentPresenter Grid.Row="1"
                                          Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>

