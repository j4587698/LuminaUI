<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:l10n="clr-namespace:LuminaUI.Localization;assembly=LuminaUI"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <x:Double x:Key="LuminaListItemIconSize">30</x:Double>
    <Thickness x:Key="LuminaListItemIconMargin">0,0,12,0</Thickness>
    <CornerRadius x:Key="LuminaListItemIconCornerRadius">15</CornerRadius>
    <x:Double x:Key="LuminaListItemIconFontSize">13</x:Double>
    <x:Double x:Key="LuminaListItemContentSpacing">3</x:Double>
    <x:Double x:Key="LuminaListItemHeaderFontSize">13</x:Double>
    <x:Double x:Key="LuminaListItemDescriptionFontSize">12</x:Double>
    <Thickness x:Key="LuminaListItemValueMargin">12,0,0,0</Thickness>
    <Thickness x:Key="LuminaColorSwatchBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaColorSwatchCornerRadius">12</CornerRadius>
    <x:Double x:Key="LuminaColorSwatchPreviewSize">64</x:Double>
    <CornerRadius x:Key="LuminaColorSwatchPreviewCornerRadius">32</CornerRadius>
    <Thickness x:Key="LuminaColorSwatchPreviewMargin">0,0,0,12</Thickness>
    <Thickness x:Key="LuminaColorSwatchPreviewBorderThickness">1</Thickness>
    <x:Double x:Key="LuminaColorSwatchTitleFontSize">14</x:Double>
    <Thickness x:Key="LuminaColorSwatchDescriptionMargin">0,4,0,0</Thickness>
    <x:Double x:Key="LuminaColorSwatchDescriptionFontSize">11</x:Double>
    <Thickness x:Key="LuminaColorButtonSwatchBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaColorButtonSwatchCornerRadius">12</CornerRadius>
    <x:Double x:Key="LuminaSettingItemColumnSpacing">16</x:Double>
    <x:Double x:Key="LuminaSettingItemTextSpacing">2</x:Double>
    <x:Double x:Key="LuminaSettingItemDescriptionFontSize">12</x:Double>
    <x:Double x:Key="LuminaSettingsCardSpacing">10</x:Double>
    <x:Double x:Key="LuminaSettingsCardHeaderSpacing">4</x:Double>
    <Thickness x:Key="LuminaSettingsCardHeaderMargin">2,0,2,0</Thickness>
    <x:Double x:Key="LuminaSettingsCardHeaderFontSize">13</x:Double>
    <x:Double x:Key="LuminaSettingsCardDescriptionFontSize">12</x:Double>
    <Thickness x:Key="LuminaSettingsCardBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaSettingsCardCornerRadius">14</CornerRadius>
    <x:Double x:Key="LuminaSettingsOptionColumnSpacing">12</x:Double>
    <x:Double x:Key="LuminaSettingsOptionIconSize">32</x:Double>
    <CornerRadius x:Key="LuminaSettingsOptionIconCornerRadius">9</CornerRadius>
    <x:Double x:Key="LuminaSettingsOptionIconFontSize">13</x:Double>
    <x:Double x:Key="LuminaSettingsOptionContentSpacing">3</x:Double>
    <x:Double x:Key="LuminaSettingsOptionHeaderFontSize">14</x:Double>
    <x:Double x:Key="LuminaSettingsOptionDescriptionFontSize">12</x:Double>
    <x:Double x:Key="LuminaSettingsOptionValueFontSize">13</x:Double>
    <x:Double x:Key="LuminaSettingsOptionChevronFontSize">16</x:Double>
    <x:Double x:Key="LuminaSettingsOptionPopupMaxHeight">320</x:Double>
    <Thickness x:Key="LuminaSettingsOptionPopupMargin">0,6,0,0</Thickness>
    <Thickness x:Key="LuminaSettingsOptionPopupPadding">6</Thickness>
    <Thickness x:Key="LuminaSettingsOptionPopupBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaSettingsOptionPopupCornerRadius">10</CornerRadius>
    <x:Double x:Key="LuminaSettingsOptionPopupCheckColumnWidth">24</x:Double>
    <x:Double x:Key="LuminaSettingsOptionPopupCheckIconSize">18</x:Double>
    <Thickness x:Key="LuminaSettingsOptionInputPopupPadding">12</Thickness>
    <x:Double x:Key="LuminaSettingsOptionInputPopupSpacing">12</x:Double>
    <x:Double x:Key="LuminaSettingsOptionInputMinHeight">38</x:Double>
    <x:Double x:Key="LuminaSettingsOptionInputActionsSpacing">8</x:Double>
    <Thickness x:Key="LuminaIndexedListIndexHostMargin">0,0,4,0</Thickness>
    <Thickness x:Key="LuminaIndexedListIndexHostPadding">0</Thickness>
    <x:Double x:Key="LuminaIndexedListIndexPanelMinWidth">16</x:Double>
    <x:Double x:Key="LuminaIndexedListIndexPanelSpacing">0</x:Double>
    <Thickness x:Key="LuminaIndexedSectionHeaderPadding">16,4</Thickness>
    <x:Double x:Key="LuminaIndexedSectionHeaderFontSize">13</x:Double>
    <Thickness x:Key="LuminaIndexedSectionItemsMargin">0,0,24,0</Thickness>
    <Thickness x:Key="LuminaLinkedCategoryListCategoryMargin">0,0,12,0</Thickness>
    <Thickness x:Key="LuminaLinkedCategoryListCategoryPadding">6</Thickness>
    <Thickness x:Key="LuminaLinkedCategoryListBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaLinkedCategoryListCornerRadius">12</CornerRadius>
    <x:Double x:Key="LuminaLinkedCategoryListCategorySpacing">4</x:Double>
    <Thickness x:Key="LuminaLinkedCategorySectionHeaderPadding">16,10,16,6</Thickness>
    <x:Double x:Key="LuminaLinkedCategorySectionHeaderFontSize">13</x:Double>
    <x:Double x:Key="LuminaIndexButtonSize">16</x:Double>
    <Thickness x:Key="LuminaIndexButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaIndexButtonFontSize">10</x:Double>
    <CornerRadius x:Key="LuminaIndexButtonCornerRadius">8</CornerRadius>
    <x:Double x:Key="LuminaCategoryButtonMinHeight">38</x:Double>
    <Thickness x:Key="LuminaCategoryButtonPadding">10,8</Thickness>
    <x:Double x:Key="LuminaCategoryButtonFontSize">13</x:Double>
    <CornerRadius x:Key="LuminaCategoryButtonCornerRadius">8</CornerRadius>

    <ControlTheme x:Key="{x:Type lumina:LuminaAutoScrollText}" TargetType="lumina:LuminaAutoScrollText">
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaAutoScrollText">
                <Border Name="PART_Viewport"
                        MinHeight="{TemplateBinding MinHeight}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        ClipToBounds="True">
                    <StackPanel Name="PART_Track"
                                Orientation="Horizontal"
                                Spacing="{TemplateBinding Gap}"
                                VerticalAlignment="Center">
                        <TextBlock Name="PART_PrimaryText"
                                   Text="{TemplateBinding Text}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextWrapping="NoWrap" />
                        <TextBlock Name="PART_SecondaryText"
                                   Text="{TemplateBinding Text}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextWrapping="NoWrap"
                                   IsVisible="False" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Pill">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style Selector="^.Muted">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaListItem}" TargetType="lumina:LuminaListItem">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaListItem">
                <Border Name="PART_Root"
                        MinHeight="{TemplateBinding MinHeight}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border IsVisible="{TemplateBinding HasIcon}"
                                Width="{DynamicResource LuminaListItemIconSize}"
                                Height="{DynamicResource LuminaListItemIconSize}"
                                Margin="{DynamicResource LuminaListItemIconMargin}"
                                Background="{DynamicResource LuminaPrimaryBgBrush}"
                                CornerRadius="{DynamicResource LuminaListItemIconCornerRadius}"
                                VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Icon}"
                                       FontSize="{DynamicResource LuminaListItemIconFontSize}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource LuminaPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Spacing="{DynamicResource LuminaListItemContentSpacing}"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontSize="{DynamicResource LuminaListItemHeaderFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{TemplateBinding Description}"
                                       IsVisible="{TemplateBinding HasDescription}"
                                       FontSize="{DynamicResource LuminaListItemDescriptionFontSize}"
                                       Foreground="{DynamicResource LuminaTextTertiaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Margin="{DynamicResource LuminaListItemValueMargin}"
                                   Text="{TemplateBinding Value}"
                                   IsVisible="{TemplateBinding HasValue}"
                                   FontSize="{DynamicResource LuminaListItemHeaderFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource LuminaTextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Plain">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="^.Compact">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style Selector="^.Interactive">
            <Style Selector="^ /template/ Border#PART_Root">
                <Setter Property="Transitions">
                    <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.12" />
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
                    </Transitions>
                </Setter>
            </Style>
        </Style>

        <Style Selector="^.Interactive:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaColorSwatch}" TargetType="lumina:LuminaColorSwatch">
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="152" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaColorSwatch">
                <Border Padding="{TemplateBinding Padding}"
                        Background="{DynamicResource LuminaSurfaceBrush}"
                        BorderBrush="{DynamicResource LuminaBorderBrush}"
                        BorderThickness="{DynamicResource LuminaColorSwatchBorderThickness}"
                        CornerRadius="{DynamicResource LuminaColorSwatchCornerRadius}">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="{DynamicResource LuminaColorSwatchPreviewSize}"
                                Height="{DynamicResource LuminaColorSwatchPreviewSize}"
                                CornerRadius="{DynamicResource LuminaColorSwatchPreviewCornerRadius}"
                                Margin="{DynamicResource LuminaColorSwatchPreviewMargin}"
                                Background="{TemplateBinding SwatchBrush}"
                                BorderBrush="{DynamicResource LuminaBorderBrush}"
                                BorderThickness="{DynamicResource LuminaColorSwatchPreviewBorderThickness}" />
                        <TextBlock Text="{TemplateBinding Title}"
                                   FontSize="{DynamicResource LuminaColorSwatchTitleFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource LuminaTextForegroundBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{TemplateBinding Description}"
                                   IsVisible="{TemplateBinding HasDescription}"
                                   Margin="{DynamicResource LuminaColorSwatchDescriptionMargin}"
                                   FontSize="{DynamicResource LuminaColorSwatchDescriptionFontSize}"
                                   Foreground="{DynamicResource LuminaTextTertiaryBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaColorButton}" TargetType="lumina:LuminaColorButton" BasedOn="{StaticResource LuminaButton}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaColorButton">
                <Border Name="PART_Border"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Border Background="{TemplateBinding SwatchBrush}"
                            BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                            BorderThickness="{DynamicResource LuminaColorButtonSwatchBorderThickness}"
                            CornerRadius="{DynamicResource LuminaColorButtonSwatchCornerRadius}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{DynamicResource LuminaStatePressedBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaSettingItem}" TargetType="lumina:LuminaSettingItem">
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaSettingItem">
                <Grid Margin="{TemplateBinding Margin}"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="{DynamicResource LuminaSettingItemColumnSpacing}">
                    <StackPanel Grid.Column="0"
                                Spacing="{DynamicResource LuminaSettingItemTextSpacing}"
                                VerticalAlignment="Center">
                        <TextBlock Text="{TemplateBinding Header}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource LuminaTextForegroundBrush}" />
                        <TextBlock Text="{TemplateBinding Description}"
                                   FontSize="{DynamicResource LuminaSettingItemDescriptionFontSize}"
                                   Foreground="{DynamicResource LuminaTextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <ContentPresenter Grid.Column="1"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      VerticalAlignment="Center" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaSettingsCard}" TargetType="lumina:LuminaSettingsCard">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaSettingsCard">
                <StackPanel Margin="{TemplateBinding Margin}" Spacing="{DynamicResource LuminaSettingsCardSpacing}">
                    <StackPanel IsVisible="{TemplateBinding HasHeader}"
                                Spacing="{DynamicResource LuminaSettingsCardHeaderSpacing}"
                                Margin="{DynamicResource LuminaSettingsCardHeaderMargin}">
                        <TextBlock Text="{TemplateBinding Header}"
                                   FontSize="{DynamicResource LuminaSettingsCardHeaderFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                        <TextBlock Text="{TemplateBinding Description}"
                                   IsVisible="{TemplateBinding HasDescription}"
                                   FontSize="{DynamicResource LuminaSettingsCardDescriptionFontSize}"
                                   Foreground="{DynamicResource LuminaTextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Background="{DynamicResource LuminaSurfaceBrush}"
                            BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                            BorderThickness="{DynamicResource LuminaSettingsCardBorderThickness}"
                            CornerRadius="{DynamicResource LuminaSettingsCardCornerRadius}"
                            ClipToBounds="True">
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                    </Border>
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaSettingsOption}" TargetType="lumina:LuminaSettingsOption">
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaSettingsOption">
                <Grid>
                    <Border Name="PART_Root"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                              ColumnSpacing="{DynamicResource LuminaSettingsOptionColumnSpacing}"
                              VerticalAlignment="Center">
                            <Border IsVisible="{TemplateBinding HasIcon}"
                                    Width="{DynamicResource LuminaSettingsOptionIconSize}"
                                    Height="{DynamicResource LuminaSettingsOptionIconSize}"
                                    Background="{DynamicResource LuminaPrimaryBgBrush}"
                                    CornerRadius="{DynamicResource LuminaSettingsOptionIconCornerRadius}"
                                    VerticalAlignment="Center">
                                <ContentPresenter Content="{TemplateBinding Icon}"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  TextElement.FontSize="{DynamicResource LuminaSettingsOptionIconFontSize}"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="{DynamicResource LuminaPrimaryBrush}" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Spacing="{DynamicResource LuminaSettingsOptionContentSpacing}"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontSize="{DynamicResource LuminaSettingsOptionHeaderFontSize}"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{TemplateBinding Description}"
                                           IsVisible="{TemplateBinding HasDescription}"
                                           FontSize="{DynamicResource LuminaSettingsOptionDescriptionFontSize}"
                                           Foreground="{DynamicResource LuminaTextTertiaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <ContentPresenter Grid.Column="2"
                                              Content="{TemplateBinding Value}"
                                              IsVisible="{TemplateBinding HasValue}"
                                              HorizontalContentAlignment="Right"
                                              VerticalContentAlignment="Center"
                                              TextElement.FontSize="{DynamicResource LuminaSettingsOptionValueFontSize}"
                                              TextElement.FontWeight="Medium"
                                              TextElement.Foreground="{DynamicResource LuminaTextMutedBrush}" />

                            <ContentPresenter Grid.Column="2"
                                              Content="{TemplateBinding TrailingContent}"
                                              IsVisible="{TemplateBinding HasTrailingContent}"
                                              HorizontalContentAlignment="Right"
                                              VerticalContentAlignment="Center" />

                            <TextBlock Grid.Column="2"
                                       MinWidth="{TemplateBinding AccessoryMinWidth}"
                                       MaxWidth="{TemplateBinding AccessoryMaxWidth}"
                                       Text="{TemplateBinding InputDisplayText}"
                                       IsVisible="{TemplateBinding ShowTextInputAccessory}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource LuminaSettingsOptionValueFontSize}"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       TextAlignment="Right"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="2"
                                       MinWidth="{TemplateBinding AccessoryMinWidth}"
                                       MaxWidth="{TemplateBinding AccessoryMaxWidth}"
                                       Text="{TemplateBinding SelectedDisplayText}"
                                       IsVisible="{TemplateBinding ShowSelectAccessory}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource LuminaSettingsOptionValueFontSize}"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       TextAlignment="Right"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Grid.Column="3"
                                       Text=">"
                                       IsVisible="{TemplateBinding ShowChevronIcon}"
                                       FontSize="{DynamicResource LuminaSettingsOptionChevronFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource LuminaTextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Popup Name="PART_SelectPopup"
                           IsOpen="{Binding IsSelectPopupOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                           IsLightDismissEnabled="True"
                           Placement="BottomEdgeAlignedRight"
                           PlacementConstraintAdjustment="FlipY,SlideX,ResizeY"
                           PlacementTarget="{Binding #PART_Root}"
                           WindowManagerAddShadowHint="False">
                        <Border MinWidth="{Binding #PART_Root.Bounds.Width}"
                                MaxHeight="{DynamicResource LuminaSettingsOptionPopupMaxHeight}"
                                Margin="{DynamicResource LuminaSettingsOptionPopupMargin}"
                                Padding="{DynamicResource LuminaSettingsOptionPopupPadding}"
                                Background="{DynamicResource LuminaPopoverBrush}"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="{DynamicResource LuminaSettingsOptionPopupBorderThickness}"
                                CornerRadius="{DynamicResource LuminaSettingsOptionPopupCornerRadius}"
                                BoxShadow="{DynamicResource LuminaShadowPopup}">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{TemplateBinding SelectOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="lumina:LuminaSettingsSelectOptionItem">
                                            <Button Name="PART_SelectOptionButton"
                                                    Classes="ActionSheetItem">
                                                <Grid ColumnDefinitions="*,24"
                                                      ColumnSpacing="{DynamicResource LuminaSettingsOptionColumnSpacing}">
                                                    <TextBlock Text="{Binding Text}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource LuminaTextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <PathIcon Grid.Column="1"
                                                              Width="{DynamicResource LuminaSettingsOptionPopupCheckIconSize}"
                                                              Height="{DynamicResource LuminaSettingsOptionPopupCheckIconSize}"
                                                              Data="M9,16.2 L4.8,12 L3.4,13.4 L9,19 L21,7 L19.6,5.6 Z"
                                                              IsVisible="{Binding IsSelected}"
                                                              Foreground="{DynamicResource LuminaPrimaryBrush}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Popup>

                    <Popup Name="PART_InputPopup"
                           IsOpen="{Binding IsInputPopupOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                           IsLightDismissEnabled="True"
                           Placement="BottomEdgeAlignedRight"
                           PlacementConstraintAdjustment="FlipY,SlideX,ResizeY"
                           PlacementTarget="{Binding #PART_Root}"
                           WindowManagerAddShadowHint="False">
                        <Border MinWidth="{Binding #PART_Root.Bounds.Width}"
                                Margin="{DynamicResource LuminaSettingsOptionPopupMargin}"
                                Padding="{DynamicResource LuminaSettingsOptionInputPopupPadding}"
                                Background="{DynamicResource LuminaPopoverBrush}"
                                BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                BorderThickness="{DynamicResource LuminaSettingsOptionPopupBorderThickness}"
                                CornerRadius="{DynamicResource LuminaSettingsOptionPopupCornerRadius}"
                                BoxShadow="{DynamicResource LuminaShadowPopup}">
                            <StackPanel Spacing="{DynamicResource LuminaSettingsOptionInputPopupSpacing}">
                                <TextBox MinHeight="{DynamicResource LuminaSettingsOptionInputMinHeight}"
                                         Text="{Binding InputDraftText, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                         PlaceholderText="{TemplateBinding PlaceholderText}"
                                         HorizontalContentAlignment="Stretch" />
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="{DynamicResource LuminaSettingsOptionInputActionsSpacing}">
                                    <Button Name="PART_InputCancelButton"
                                            Grid.Column="1"
                                            Classes="Outline"
                                            Content="{l10n:Loc Lumina.Common.Cancel}" />
                                    <Button Name="PART_InputDoneButton"
                                            Grid.Column="2"
                                            Classes="Primary"
                                            Content="{l10n:Loc Lumina.Common.Done}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Background" Value="{DynamicResource LuminaStatePressedBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextDisabledBrush}" />
        </Style>

        <Style Selector="^.Danger">
            <Setter Property="Foreground" Value="{DynamicResource LuminaDangerBrush}" />
        </Style>

        <Style Selector="^.Danger /template/ Border#PART_Root">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaTag}" TargetType="lumina:LuminaTag">
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaTag">
                <ContentPresenter Margin="{TemplateBinding Margin}"
                                  Padding="{TemplateBinding Padding}"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  TextElement.Foreground="{TemplateBinding Foreground}" />
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Primary">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaIndexedList}" TargetType="lumina:LuminaIndexedList">
        <Setter Property="MinHeight" Value="320" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaIndexedList">
                <Grid>
                    <ScrollViewer Name="PART_ScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                    </ScrollViewer>

                    <!-- Mobile style index overlay -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="{DynamicResource LuminaIndexedListIndexHostMargin}"
                            Padding="{DynamicResource LuminaIndexedListIndexHostPadding}"
                            Background="Transparent">
                        <StackPanel Name="PART_IndexPanel"
                                    MinWidth="{DynamicResource LuminaIndexedListIndexPanelMinWidth}"
                                    Spacing="{DynamicResource LuminaIndexedListIndexPanelSpacing}"
                                    HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaIndexedSection}" TargetType="lumina:LuminaIndexedSection">
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaIndexedSection">
                <StackPanel>
                    <Border Padding="{DynamicResource LuminaIndexedSectionHeaderPadding}"
                            Background="{DynamicResource LuminaBackgroundBrush}">
                        <TextBlock Text="{TemplateBinding Header}"
                                   FontSize="{DynamicResource LuminaIndexedSectionHeaderFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                    </Border>
                    <!-- Give enough right margin to avoid the index bar -->
                    <ItemsPresenter Name="PART_ItemsPresenter"
                                    Margin="{DynamicResource LuminaIndexedSectionItemsMargin}"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaLinkedCategoryList}" TargetType="lumina:LuminaLinkedCategoryList">
        <Setter Property="MinHeight" Value="320" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaLinkedCategoryList">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            Width="{TemplateBinding CategoryWidth}"
                            Margin="{DynamicResource LuminaLinkedCategoryListCategoryMargin}"
                            Padding="{DynamicResource LuminaLinkedCategoryListCategoryPadding}"
                            Background="{DynamicResource LuminaBackgroundBrush}"
                            BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                            BorderThickness="{DynamicResource LuminaLinkedCategoryListBorderThickness}"
                            CornerRadius="{DynamicResource LuminaLinkedCategoryListCornerRadius}">
                        <StackPanel Name="PART_CategoryPanel"
                                    Spacing="{DynamicResource LuminaLinkedCategoryListCategorySpacing}" />
                    </Border>

                    <Border Grid.Column="1"
                            Background="{DynamicResource LuminaSurfaceBrush}"
                            BorderBrush="{DynamicResource LuminaBorderSubtleBrush}"
                            BorderThickness="{DynamicResource LuminaLinkedCategoryListBorderThickness}"
                            CornerRadius="{DynamicResource LuminaLinkedCategoryListCornerRadius}"
                            ClipToBounds="True">
                        <ScrollViewer Name="PART_ScrollViewer"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter Name="PART_ItemsPresenter"
                                            ItemsPanel="{TemplateBinding ItemsPanel}" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type lumina:LuminaLinkedCategorySection}" TargetType="lumina:LuminaLinkedCategorySection">
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaLinkedCategorySection">
                <StackPanel>
                    <Border Padding="{DynamicResource LuminaLinkedCategorySectionHeaderPadding}"
                            Background="{DynamicResource LuminaSurfaceBrush}">
                        <TextBlock Text="{TemplateBinding Header}"
                                   FontSize="{DynamicResource LuminaLinkedCategorySectionHeaderFontSize}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource LuminaTextSecondaryBrush}" />
                    </Border>
                    <ItemsPresenter Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="LuminaIndexButtonTheme" TargetType="Button" BasedOn="{StaticResource LuminaButton}">
        <Setter Property="Width" Value="{DynamicResource LuminaIndexButtonSize}" />
        <Setter Property="Height" Value="{DynamicResource LuminaIndexButtonSize}" />
        <Setter Property="MinWidth" Value="{DynamicResource LuminaIndexButtonSize}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaIndexButtonSize}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaIndexButtonPadding}" />
        <Setter Property="FontSize" Value="{DynamicResource LuminaIndexButtonFontSize}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaIndexButtonCornerRadius}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextTertiaryBrush}" />

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="RenderTransform" Value="scale(1.2)" />
        </Style>

        <Style Selector="^.Selected">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryForegroundBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCategoryButtonTheme" TargetType="Button" BasedOn="{StaticResource LuminaButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCategoryButtonMinHeight}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCategoryButtonPadding}" />
        <Setter Property="FontSize" Value="{DynamicResource LuminaCategoryButtonFontSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCategoryButtonCornerRadius}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />

        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
        </Style>

        <Style Selector="^.Selected">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
