<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:chrome="using:Avalonia.Controls.Chrome"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <!-- 标题栏基础按钮样式 -->
    <ControlTheme x:Key="LuminaTitleBarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="(chrome:WindowDecorationProperties.ElementRole)" Value="DecorationsElement"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Content="{TemplateBinding Content}" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}"/>
        </Style>
    </ControlTheme>

    <!-- 关闭按钮专属样式 (悬停变红) -->
    <ControlTheme x:Key="LuminaTitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource LuminaTitleBarButton}">
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource LuminaDangerHoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource LuminaDangerForegroundBrush}"/>
        </Style>
    </ControlTheme>

    <!-- LuminaTitleBar 核心结构 -->
    <ControlTheme x:Key="{x:Type lumina:LuminaTitleBar}" TargetType="lumina:LuminaTitleBar">
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource LuminaBackgroundBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Background="{TemplateBinding Background}">
                    <!-- 拖拽区域 (放置在底层，占据整个标题栏。它的透明背景能捕获没有被按钮消耗的点击事件) -->
                    <Border Grid.Column="0"
                            Grid.ColumnSpan="4"
                            Name="PART_DragArea"
                            Background="Transparent"
                            chrome:WindowDecorationProperties.ElementRole="TitleBar" />
                    
                    <!-- 左侧内容槽 (开放命中测试，以便内部按钮可以被点击) -->
                    <ContentPresenter Grid.Column="0"
                                      Content="{TemplateBinding LeftContent}"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding LeftContentMargin}"
                                      chrome:WindowDecorationProperties.ElementRole="User" />
                    
                    <!-- 中间内容槽 (通常放居中标题) -->
                    <ContentPresenter Grid.Column="1" Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Stretch" IsHitTestVisible="False"/>
                    
                    <!-- 右侧内容槽 -->
                    <ContentPresenter Grid.Column="2"
                                      Content="{TemplateBinding RightContent}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,16,0"
                                      chrome:WindowDecorationProperties.ElementRole="User" />

                    <!-- 右侧窗口按钮 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" IsVisible="{TemplateBinding ShowSystemButtons}">
                        <Button Name="PART_PinButton"
                                Theme="{StaticResource LuminaTitleBarButton}"
                                IsVisible="{TemplateBinding ShowPinButton}">
                            <Viewbox Width="13" Height="13">
                                <Path Name="PinIcon"
                                      Stretch="Uniform"
                                      Fill="{Binding $parent[Button].Foreground}"
                                      Data="M16,12 L18,14 L18,16 L12.8,16 L12.8,22 L11.2,22 L11.2,16 L6,16 L6,14 L8,12 L8,4 L7,4 L7,2 L17,2 L17,4 L16,4 Z M10,4 L10,12.8 L8.8,14 L15.2,14 L14,12.8 L14,4 Z" />
                            </Viewbox>
                        </Button>
                        <Button Name="PART_FullScreenButton"
                                Theme="{StaticResource LuminaTitleBarButton}"
                                IsVisible="{TemplateBinding ShowFullScreenButton}"
                                chrome:WindowDecorationProperties.ElementRole="FullScreenButton">
                            <Viewbox Width="11" Height="11">
                                <Path Name="FullScreenIcon"
                                      Stretch="Uniform"
                                      Fill="Transparent"
                                      Stroke="{Binding $parent[Button].Foreground}"
                                      StrokeThickness="1.4"
                                      StrokeLineCap="Square"
                                      Data="M3,5 L3,3 L5,3 M9,3 L11,3 L11,5 M11,9 L11,11 L9,11 M5,11 L3,11 L3,9" />
                            </Viewbox>
                        </Button>
                        <Button Name="PART_MinimizeButton"
                                Theme="{StaticResource LuminaTitleBarButton}"
                                IsVisible="{TemplateBinding ShowMinimizeButton}"
                                chrome:WindowDecorationProperties.ElementRole="MinimizeButton">
                            <!-- 最小化横线 -->
                            <TextBlock Text="—" FontSize="11" Margin="0,8,0,0" />
                        </Button>
                        <Button Name="PART_MaximizeButton"
                                Theme="{StaticResource LuminaTitleBarButton}"
                                IsVisible="{TemplateBinding ShowMaximizeButton}"
                                chrome:WindowDecorationProperties.ElementRole="MaximizeButton">
                            <!-- 最大化方框 -->
                            <Border BorderBrush="{Binding $parent[Button].Foreground}" BorderThickness="1" Width="10" Height="10" Margin="0,2,0,0"/>
                        </Button>
                        <Button Name="PART_CloseButton"
                                Theme="{StaticResource LuminaTitleBarCloseButton}"
                                IsVisible="{TemplateBinding ShowCloseButton}"
                                chrome:WindowDecorationProperties.ElementRole="CloseButton">
                            <!-- 关闭叉叉 -->
                            <TextBlock Text="✕" FontSize="14" Margin="0,2,0,0"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </ControlTemplate>
        </Setter>
        <Style Selector="^[IsFullScreen=True] /template/ Path#FullScreenIcon">
            <Setter Property="Data" Value="M5,3 L5,5 L3,5 M9,5 L9,3 L11,3 M9,9 L11,9 L11,11 M5,11 L5,9 L3,9" />
        </Style>
        <Style Selector="^[IsPinned=True] /template/ Button#PART_PinButton">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>
        <Style Selector="^[IsPinned=True] /template/ Path#PinIcon">
            <Setter Property="Data" Value="M7,3 L17,3 L17,5 L16,5 L16,11.2 L19,14.2 L19,16 L13,16 L13,22 L11,22 L11,16 L5,16 L5,14.2 L8,11.2 L8,5 L7,5 Z" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
