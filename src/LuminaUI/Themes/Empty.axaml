<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="using:LuminaUI.Controls">

    <x:Double x:Key="LuminaEmptyDefaultSpacing">12</x:Double>
    <x:Double x:Key="LuminaEmptyIconPanelSize">64</x:Double>
    <x:Double x:Key="LuminaEmptyDefaultIconSize">48</x:Double>
    <x:Double x:Key="LuminaEmptyDefaultIconCanvasSize">24</x:Double>
    <x:Double x:Key="LuminaEmptyTitleFontSize">14</x:Double>
    <x:Double x:Key="LuminaEmptyDescriptionFontSize">13</x:Double>
    <x:Double x:Key="LuminaEmptyDescriptionMaxWidth">280</x:Double>
    <Thickness x:Key="LuminaEmptyActionMargin">0,4,0,0</Thickness>
    <x:Double x:Key="LuminaEmptyCompactSpacing">8</x:Double>

    <ControlTheme x:Key="{x:Type lumina:LuminaEmpty}" TargetType="lumina:LuminaEmpty">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate TargetType="lumina:LuminaEmpty">
                <Border Background="#00FFFFFF"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}">
                    <Panel>
                        <ContentPresenter Name="PART_CustomContent"
                                          Content="{TemplateBinding CustomContent}"
                                          ContentTemplate="{TemplateBinding CustomContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsVisible="{TemplateBinding HasCustomContent}" />

                        <StackPanel Name="PART_DefaultLayout"
                                    Spacing="{DynamicResource LuminaEmptyDefaultSpacing}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding !$parent[lumina:LuminaEmpty].HasCustomContent}">
                            <Panel Width="{DynamicResource LuminaEmptyIconPanelSize}"
                                   Height="{DynamicResource LuminaEmptyIconPanelSize}"
                                   HorizontalAlignment="Center"
                                   IsVisible="{TemplateBinding ShowIcon}">
                                <ContentPresenter Content="{TemplateBinding Icon}"
                                                  ContentTemplate="{TemplateBinding IconTemplate}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding $parent[lumina:LuminaEmpty].Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />

                                <Viewbox Width="{DynamicResource LuminaEmptyDefaultIconSize}"
                                         Height="{DynamicResource LuminaEmptyDefaultIconSize}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsVisible="{Binding $parent[lumina:LuminaEmpty].Icon, Converter={x:Static ObjectConverters.IsNull}}">
                                    <Canvas Width="{DynamicResource LuminaEmptyDefaultIconCanvasSize}"
                                            Height="{DynamicResource LuminaEmptyDefaultIconCanvasSize}">
                                        <Path Fill="{DynamicResource LuminaTextMutedBrush}"
                                              Data="M20 6H16V4C16 2.9 15.1 2 14 2H10C8.9 2 8 2.9 8 4V6H4C2.9 6 2 6.9 2 8V19C2 20.1 2.9 21 4 21H20C21.1 21 22 20.1 22 19V8C22 6.9 21.1 6 20 6ZM10 4H14V6H10V4ZM20 19H4V8H20V19ZM12 12C10.9 12 10 11.1 10 10H8C8 12.2 9.8 14 12 14C14.2 14 16 12.2 16 10H14C14 11.1 13.1 12 12 12Z" />
                                    </Canvas>
                                </Viewbox>
                            </Panel>

                            <TextBlock Text="{TemplateBinding DisplayTitle}"
                                       FontSize="{DynamicResource LuminaEmptyTitleFontSize}"
                                       FontWeight="DemiBold"
                                       Foreground="{DynamicResource LuminaTextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{TemplateBinding Description}"
                                       IsVisible="{TemplateBinding HasDescription}"
                                       FontSize="{DynamicResource LuminaEmptyDescriptionFontSize}"
                                       Foreground="{DynamicResource LuminaTextTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="{DynamicResource LuminaEmptyDescriptionMaxWidth}" />

                            <ContentPresenter Content="{TemplateBinding Action}"
                                              ContentTemplate="{TemplateBinding ActionTemplate}"
                                              IsVisible="{TemplateBinding HasAction}"
                                              HorizontalAlignment="Center"
                                              Margin="{DynamicResource LuminaEmptyActionMargin}" />
                        </StackPanel>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Compact /template/ StackPanel#PART_DefaultLayout">
            <Setter Property="Spacing" Value="{DynamicResource LuminaEmptyCompactSpacing}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
