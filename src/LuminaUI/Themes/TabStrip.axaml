<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="LuminaTabStripBorderThickness">0</Thickness>
    <Thickness x:Key="LuminaTabStripChromeBorderThickness">1,1,1,0</Thickness>
    <CornerRadius x:Key="LuminaTabStripChromeCornerRadius">8,8,0,0</CornerRadius>
    <Thickness x:Key="LuminaTabStripPillBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaTabStripPillCornerRadius">999</CornerRadius>
    <Thickness x:Key="LuminaTabStripMobileBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaTabStripMobileCornerRadius">16</CornerRadius>
    <Thickness x:Key="LuminaLineTabStripItemPadding">12,8</Thickness>
    <Thickness x:Key="LuminaLineTabStripItemBorderThickness">0</Thickness>
    <CornerRadius x:Key="LuminaLineTabStripItemCornerRadius">6</CornerRadius>
    <x:Double x:Key="LuminaLineTabStripIndicatorThickness">2</x:Double>
    <Thickness x:Key="LuminaLineTabStripIndicatorMargin">8,0</Thickness>
    <CornerRadius x:Key="LuminaLineTabStripIndicatorCornerRadius">1</CornerRadius>
    <x:Double x:Key="LuminaTabStripItemDisabledOpacity">0.45</x:Double>
    <Thickness x:Key="LuminaChromeTabStripItemMargin">2,2,0,0</Thickness>
    <Thickness x:Key="LuminaChromeTabStripItemPadding">14,8</Thickness>
    <Thickness x:Key="LuminaChromeTabStripItemBorderThickness">1,1,1,0</Thickness>
    <CornerRadius x:Key="LuminaChromeTabStripItemCornerRadius">7,7,0,0</CornerRadius>
    <x:Double x:Key="LuminaChromeTabStripItemMinHeight">34</x:Double>
    <Thickness x:Key="LuminaPillTabStripItemMargin">2</Thickness>
    <Thickness x:Key="LuminaPillTabStripItemPadding">13,7</Thickness>
    <CornerRadius x:Key="LuminaPillTabStripItemCornerRadius">999</CornerRadius>
    <x:Double x:Key="LuminaPillTabStripItemMinHeight">32</x:Double>
    <Thickness x:Key="LuminaVerticalTabStripItemPadding">12,9</Thickness>
    <CornerRadius x:Key="LuminaVerticalTabStripItemCornerRadius">7</CornerRadius>
    <x:Double x:Key="LuminaVerticalTabStripIndicatorWidth">3</x:Double>
    <CornerRadius x:Key="LuminaVerticalTabStripIndicatorCornerRadius">2</CornerRadius>
    <Thickness x:Key="LuminaVerticalTabStripContentMargin">8,0,0,0</Thickness>
    <Thickness x:Key="LuminaCompactTabStripItemPadding">9,5</Thickness>
    <CornerRadius x:Key="LuminaCompactTabStripItemCornerRadius">5</CornerRadius>
    <x:Double x:Key="LuminaMobileTabStripItemMinHeight">62</x:Double>
    <x:Double x:Key="LuminaMobileTabStripItemMinWidth">64</x:Double>
    <Thickness x:Key="LuminaMobileTabStripItemPadding">8,6</Thickness>
    <CornerRadius x:Key="LuminaMobileTabStripItemCornerRadius">12</CornerRadius>
    <Thickness x:Key="LuminaMobileTabStripItemMargin">4</Thickness>

    <ControlTheme x:Key="{x:Type TabStrip}" TargetType="TabStrip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaTabStripBorderThickness}" />
        <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaLineTabStripItem}" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStrip">
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^.Chrome">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource LuminaTabStripChromeBorderThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource LuminaTabStripChromeCornerRadius}" />
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaChromeTabStripItem}" />
        </Style>

        <Style Selector="^.Bottom">
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaBottomLineTabStripItem}" />
        </Style>

        <Style Selector="^.Pills">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource LuminaTabStripPillBorderThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource LuminaTabStripPillCornerRadius}" />
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaPillTabStripItem}" />
        </Style>

        <Style Selector="^.Vertical">
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaVerticalTabStripItem}" />
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter>
        </Style>

        <Style Selector="^.Compact">
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaCompactTabStripItem}" />
        </Style>

        <Style Selector="^.Mobile">
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource LuminaTabStripMobileBorderThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource LuminaTabStripMobileCornerRadius}" />
            <Setter Property="ItemContainerTheme" Value="{StaticResource LuminaMobileTabStripItem}" />
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </Setter>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaLineTabStripItem" TargetType="TabStripItem">
        <Setter Property="Padding" Value="{DynamicResource LuminaLineTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaLineTabStripItemBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaLineTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Grid RowDefinitions="*,2">
                    <Border Name="PART_ItemBackground"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <Border Name="PART_SelectedIndicator"
                            Grid.Row="1"
                            Height="{DynamicResource LuminaLineTabStripIndicatorThickness}"
                            Margin="{DynamicResource LuminaLineTabStripIndicatorMargin}"
                            Background="Transparent"
                            CornerRadius="{DynamicResource LuminaLineTabStripIndicatorCornerRadius}"
                            IsVisible="False" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_ItemBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_SelectedIndicator">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type TabStripItem}" TargetType="TabStripItem" BasedOn="{StaticResource LuminaLineTabStripItem}" />

    <ControlTheme x:Key="LuminaBottomLineTabStripItem" TargetType="TabStripItem">
        <Setter Property="Padding" Value="{DynamicResource LuminaLineTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaLineTabStripItemBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaLineTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Grid RowDefinitions="2,*">
                    <Border Name="PART_SelectedIndicator"
                            Height="{DynamicResource LuminaLineTabStripIndicatorThickness}"
                            Margin="{DynamicResource LuminaLineTabStripIndicatorMargin}"
                            Background="Transparent"
                            CornerRadius="{DynamicResource LuminaLineTabStripIndicatorCornerRadius}"
                            IsVisible="False" />
                    <Border Name="PART_ItemBackground"
                            Grid.Row="1"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_ItemBackground">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_SelectedIndicator">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaChromeTabStripItem" TargetType="TabStripItem">
        <Setter Property="Margin" Value="{DynamicResource LuminaChromeTabStripItemMargin}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaChromeTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaChromeTabStripItemBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaChromeTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Border Name="PART_Tab"
                        MinHeight="{DynamicResource LuminaChromeTabStripItemMinHeight}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderSubtleBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaPillTabStripItem" TargetType="TabStripItem">
        <Setter Property="Margin" Value="{DynamicResource LuminaPillTabStripItemMargin}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaPillTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaPillTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Border Name="PART_Pill"
                        MinHeight="{DynamicResource LuminaPillTabStripItemMinHeight}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaVerticalTabStripItem" TargetType="TabStripItem">
        <Setter Property="Padding" Value="{DynamicResource LuminaVerticalTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaVerticalTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Grid ColumnDefinitions="3,*">
                    <Border Name="PART_SelectedIndicator"
                            Width="{DynamicResource LuminaVerticalTabStripIndicatorWidth}"
                            Background="Transparent"
                            CornerRadius="{DynamicResource LuminaVerticalTabStripIndicatorCornerRadius}"
                            IsVisible="False" />
                    <Border Name="PART_ItemBackground"
                            Grid.Column="1"
                            Margin="{DynamicResource LuminaVerticalTabStripContentMargin}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#PART_SelectedIndicator">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="LuminaCompactTabStripItem" TargetType="TabStripItem" BasedOn="{StaticResource LuminaLineTabStripItem}">
        <Setter Property="Padding" Value="{DynamicResource LuminaCompactTabStripItemPadding}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCompactTabStripItemCornerRadius}" />
    </ControlTheme>

    <ControlTheme x:Key="LuminaMobileTabStripItem" TargetType="TabStripItem">
        <Setter Property="MinHeight" Value="{DynamicResource LuminaMobileTabStripItemMinHeight}" />
        <Setter Property="MinWidth" Value="{DynamicResource LuminaMobileTabStripItemMinWidth}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaMobileTabStripItemPadding}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaMobileTabStripItemCornerRadius}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabStripItem">
                <Border Name="PART_TabBackground"
                        Margin="{DynamicResource LuminaMobileTabStripItemMargin}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource LuminaTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Setter Property="Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaTabStripItemDisabledOpacity}" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
