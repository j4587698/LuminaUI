<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:lumina="clr-namespace:LuminaUI.Controls;assembly=LuminaUI">

    <x:Double x:Key="LuminaCalendarDatePickerMinHeight">36</x:Double>
    <Thickness x:Key="LuminaCalendarDatePickerPadding">12,6</Thickness>
    <CornerRadius x:Key="LuminaCalendarDatePickerCornerRadius">6</CornerRadius>
    <Thickness x:Key="LuminaCalendarDatePickerBorderThickness">1</Thickness>
    <Thickness x:Key="LuminaCalendarDatePickerTextBoxBorderThickness">0</Thickness>
    <x:Double x:Key="LuminaCalendarDatePickerButtonSize">34</x:Double>
    <Thickness x:Key="LuminaCalendarDatePickerButtonMargin">0,1,1,1</Thickness>
    <Thickness x:Key="LuminaCalendarDatePickerButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaCalendarDatePickerIconSize">16</x:Double>
    <x:Double x:Key="LuminaCalendarDatePickerIconCanvasSize">24</x:Double>
    <x:Double x:Key="LuminaCalendarDatePickerIconStrokeThickness">2</x:Double>
    <Thickness x:Key="LuminaCalendarDatePickerPopupMargin">0,6,0,0</Thickness>
    <Thickness x:Key="LuminaCalendarDatePickerPopupBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCalendarDatePickerPopupCornerRadius">12</CornerRadius>
    <Thickness x:Key="LuminaCalendarBorderThickness">0</Thickness>
    <CornerRadius x:Key="LuminaCalendarCornerRadius">12</CornerRadius>
    <x:Double x:Key="LuminaCalendarDatePickerDisabledOpacity">0.55</x:Double>
    <x:Double x:Key="LuminaCalendarItemMinWidth">296</x:Double>
    <x:Double x:Key="LuminaCalendarItemMinHeight">318</x:Double>
    <x:Double x:Key="LuminaCalendarItemDayTitleFontSize">12</x:Double>
    <Thickness x:Key="LuminaCalendarItemPadding">12</Thickness>
    <x:Double x:Key="LuminaCalendarItemHeaderButtonSize">32</x:Double>
    <Thickness x:Key="LuminaCalendarItemHeaderButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaCalendarItemDayTitleRowHeight">28</x:Double>
    <Thickness x:Key="LuminaCalendarButtonMargin">2</Thickness>
    <Thickness x:Key="LuminaCalendarButtonPadding">4</Thickness>
    <x:Double x:Key="LuminaCalendarButtonMinHeight">38</x:Double>
    <Thickness x:Key="LuminaCalendarButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCalendarButtonCornerRadius">8</CornerRadius>
    <Thickness x:Key="LuminaCalendarDayButtonMargin">2</Thickness>
    <Thickness x:Key="LuminaCalendarDayButtonPadding">0</Thickness>
    <x:Double x:Key="LuminaCalendarDayButtonMinHeight">34</x:Double>
    <Thickness x:Key="LuminaCalendarDayButtonBorderThickness">1</Thickness>
    <CornerRadius x:Key="LuminaCalendarDayButtonCornerRadius">8</CornerRadius>
    <x:Double x:Key="LuminaCalendarDayButtonDisabledOpacity">0.45</x:Double>

    <ControlTheme x:Key="{x:Type CalendarDatePicker}" TargetType="CalendarDatePicker">
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCalendarDatePickerMinHeight}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCalendarDatePickerPadding}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCalendarDatePickerCornerRadius}" />
        <Setter Property="Background" Value="{DynamicResource LuminaSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="PlaceholderForeground" Value="{DynamicResource LuminaTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarDatePickerBorderThickness}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="IsTodayHighlighted" Value="True" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarDatePicker">
                <DataValidationErrors>
                    <Grid Name="LayoutRoot">
                        <Border Name="Background"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Name="PART_TextBox"
                                     Grid.Column="0"
                                     MinHeight="{TemplateBinding MinHeight}"
                                     Padding="{TemplateBinding Padding}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                     VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     BorderThickness="{DynamicResource LuminaCalendarDatePickerTextBoxBorderThickness}"
                                     CornerRadius="{TemplateBinding CornerRadius}"
                                     Foreground="{TemplateBinding Foreground}"
                                     PlaceholderForeground="{TemplateBinding PlaceholderForeground}"
                                     PlaceholderText="{TemplateBinding PlaceholderText}"
                                     UseFloatingPlaceholder="{TemplateBinding UseFloatingPlaceholder}">
                                <TextBox.Styles>
                                    <Style Selector="TextBox#PART_TextBox:pointerover /template/ Border#PART_BorderElement">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarDatePickerTextBoxBorderThickness}" />
                                        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
                                    </Style>
                                    <Style Selector="TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarDatePickerTextBoxBorderThickness}" />
                                        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
                                    </Style>
                                </TextBox.Styles>
                            </TextBox>

                            <Button Name="PART_Button"
                                    Grid.Column="1"
                                    Classes="Ghost Icon"
                                    Width="{DynamicResource LuminaCalendarDatePickerButtonSize}"
                                    Height="{DynamicResource LuminaCalendarDatePickerButtonSize}"
                                    MinWidth="{DynamicResource LuminaCalendarDatePickerButtonSize}"
                                    Margin="{DynamicResource LuminaCalendarDatePickerButtonMargin}"
                                    Padding="{DynamicResource LuminaCalendarDatePickerButtonPadding}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Focusable="False">
                                <Viewbox Width="{DynamicResource LuminaCalendarDatePickerIconSize}"
                                         Height="{DynamicResource LuminaCalendarDatePickerIconSize}">
                                    <Canvas Width="{DynamicResource LuminaCalendarDatePickerIconCanvasSize}"
                                            Height="{DynamicResource LuminaCalendarDatePickerIconCanvasSize}">
                                        <Path Data="M8 2L8 6"
                                              Stroke="{DynamicResource LuminaTextMutedBrush}"
                                              StrokeThickness="{DynamicResource LuminaCalendarDatePickerIconStrokeThickness}"
                                              StrokeLineCap="Round" />
                                        <Path Data="M16 2L16 6"
                                              Stroke="{DynamicResource LuminaTextMutedBrush}"
                                              StrokeThickness="{DynamicResource LuminaCalendarDatePickerIconStrokeThickness}"
                                              StrokeLineCap="Round" />
                                        <Path Data="M3 10L21 10"
                                              Stroke="{DynamicResource LuminaTextMutedBrush}"
                                              StrokeThickness="{DynamicResource LuminaCalendarDatePickerIconStrokeThickness}"
                                              StrokeLineCap="Round" />
                                        <Path Data="M5 4L19 4C20.1 4 21 4.9 21 6L21 20C21 21.1 20.1 22 19 22L5 22C3.9 22 3 21.1 3 20L3 6C3 4.9 3.9 4 5 4Z"
                                              Stroke="{DynamicResource LuminaTextMutedBrush}"
                                              StrokeThickness="{DynamicResource LuminaCalendarDatePickerIconStrokeThickness}" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Popup Name="PART_Popup"
                                   Grid.Column="0"
                                   InheritsTransform="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   IsLightDismissEnabled="True"
                                   Placement="BottomEdgeAlignedLeft"
                                   PlacementTarget="{TemplateBinding}">
                                <Panel Margin="{DynamicResource LuminaCalendarDatePickerPopupMargin}" ClipToBounds="False">
                                    <Border Background="{DynamicResource LuminaPopoverBrush}"
                                            BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                            BorderThickness="{DynamicResource LuminaCalendarDatePickerPopupBorderThickness}"
                                            CornerRadius="{DynamicResource LuminaCalendarDatePickerPopupCornerRadius}"
                                            BoxShadow="{DynamicResource LuminaShadowPopup}" />
                                    <Border Background="{DynamicResource LuminaPopoverBrush}"
                                            BorderBrush="{DynamicResource LuminaBorderDefaultBrush}"
                                            BorderThickness="{DynamicResource LuminaCalendarDatePickerPopupBorderThickness}"
                                            CornerRadius="{DynamicResource LuminaCalendarDatePickerPopupCornerRadius}"
                                            ClipToBounds="True">
                                        <Calendar Name="PART_Calendar"
                                                  BorderThickness="{DynamicResource LuminaCalendarBorderThickness}"
                                                  DisplayDate="{TemplateBinding DisplayDate}"
                                                  DisplayDateEnd="{TemplateBinding DisplayDateEnd}"
                                                  DisplayDateStart="{TemplateBinding DisplayDateStart}"
                                                  FirstDayOfWeek="{TemplateBinding FirstDayOfWeek}"
                                                  IsTodayHighlighted="{TemplateBinding IsTodayHighlighted}"
                                                  SelectedDate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedDate, Mode=TwoWay}" />
                                    </Border>
                                </Panel>
                            </Popup>
                        </Grid>
                    </Grid>
                </DataValidationErrors>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource LuminaHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryHoverBrush}" />
        </Style>

        <Style Selector="^:focus-within /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="BoxShadow" Value="0 0 0 3 #332563EB" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaCalendarDatePickerDisabledOpacity}" />
        </Style>

        <Style Selector="^[(lumina|LuminaOptions.PopupType)=Sheet]">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type Calendar}" TargetType="Calendar">
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="Background" Value="{DynamicResource LuminaPopoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource LuminaBorderDefaultBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCalendarCornerRadius}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Calendar">
                <StackPanel Name="PART_Root"
                            HorizontalAlignment="Center"
                            ClipToBounds="True">
                    <CalendarItem Name="PART_CalendarItem"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  HeaderBackground="{TemplateBinding HeaderBackground}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type CalendarItem}" TargetType="CalendarItem">
        <Setter Property="MinWidth" Value="{DynamicResource LuminaCalendarItemMinWidth}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCalendarItemMinHeight}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextForegroundBrush}" />
        <Setter Property="DayTitleTemplate">
            <Template>
                <TextBlock x:DataType="x:String"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource LuminaCalendarItemDayTitleFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource LuminaTextMutedBrush}"
                           Text="{Binding}" />
            </Template>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarItem">
                <Border Padding="{DynamicResource LuminaCalendarItemPadding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid MinWidth="{TemplateBinding MinWidth}"
                          MinHeight="{TemplateBinding MinHeight}"
                          RowDefinitions="Auto,12,*">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <RepeatButton Name="PART_PreviousButton"
                                          Grid.Column="0"
                                          Classes="Ghost Small"
                                          Width="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          Height="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          MinWidth="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          Padding="{DynamicResource LuminaCalendarItemHeaderButtonPadding}"
                                          Content="&lt;" />

                            <Button Name="PART_HeaderButton"
                                    Grid.Column="1"
                                    Classes="Ghost Small"
                                    Height="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource LuminaTextForegroundBrush}" />

                            <RepeatButton Name="PART_NextButton"
                                          Grid.Column="2"
                                          Classes="Ghost Small"
                                          Width="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          Height="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          MinWidth="{DynamicResource LuminaCalendarItemHeaderButtonSize}"
                                          Padding="{DynamicResource LuminaCalendarItemHeaderButtonPadding}"
                                          Content="&gt;" />
                        </Grid>

                        <Grid Name="PART_MonthView"
                              Grid.Row="2"
                              HorizontalAlignment="Stretch"
                              IsVisible="False"
                              ColumnDefinitions="*,*,*,*,*,*,*">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="{DynamicResource LuminaCalendarItemDayTitleRowHeight}" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                        </Grid>

                        <Grid Name="PART_YearView"
                              Grid.Row="2"
                              Background="{TemplateBinding Background}"
                              IsVisible="False"
                              ColumnDefinitions="*,*,*,*"
                              RowDefinitions="*,*,*" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type CalendarButton}" TargetType="CalendarButton">
        <Setter Property="ClickMode" Value="Release" />
        <Setter Property="Margin" Value="{DynamicResource LuminaCalendarButtonMargin}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCalendarButtonPadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCalendarButtonMinHeight}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarButtonBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCalendarButtonCornerRadius}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarButton">
                <Border Name="Root"
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Name="Content"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaStatePressedBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaPrimaryForegroundBrush}" />
        </Style>

        <Style Selector="^:inactive /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextDisabledBrush}" />
        </Style>

        <Style Selector="^:blackout /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextDisabledBrush}" />
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type CalendarDayButton}" TargetType="CalendarDayButton">
        <Setter Property="ClickMode" Value="Release" />
        <Setter Property="Margin" Value="{DynamicResource LuminaCalendarDayButtonMargin}" />
        <Setter Property="Padding" Value="{DynamicResource LuminaCalendarDayButtonPadding}" />
        <Setter Property="MinHeight" Value="{DynamicResource LuminaCalendarDayButtonMinHeight}" />
        <Setter Property="Foreground" Value="{DynamicResource LuminaTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="{DynamicResource LuminaCalendarDayButtonBorderThickness}" />
        <Setter Property="CornerRadius" Value="{DynamicResource LuminaCalendarDayButtonCornerRadius}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarDayButton">
                <Border Name="Root"
                        Margin="{TemplateBinding Margin}"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter Name="Content"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaStateHoverBrush}" />
        </Style>

        <Style Selector="^:pressed /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaStatePressedBrush}" />
        </Style>

        <Style Selector="^:today /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:today /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ Border#Root">
            <Setter Property="Background" Value="{DynamicResource LuminaPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LuminaPrimaryBrush}" />
        </Style>

        <Style Selector="^:selected /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaPrimaryForegroundBrush}" />
        </Style>

        <Style Selector="^:inactive /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextDisabledBrush}" />
        </Style>

        <Style Selector="^:blackout /template/ ContentPresenter#Content">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource LuminaTextDisabledBrush}" />
        </Style>

        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource LuminaCalendarDayButtonDisabledOpacity}" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
