<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <PackageId>LuminaUI.Diagnostics</PackageId>
    <Version>$(LuminaUIDiagnosticsVersion)</Version>
    <PackageVersion>$(LuminaUIDiagnosticsVersion)</PackageVersion>
    <AssemblyVersion>$(LuminaUIDiagnosticsAssemblyVersion)</AssemblyVersion>
    <FileVersion>$(LuminaUIDiagnosticsAssemblyVersion)</FileVersion>
    <InformationalVersion>$(LuminaUIDiagnosticsVersion)</InformationalVersion>
    <Description>Application-side named-pipe diagnostics host for LuminaUI-enabled Avalonia applications.</Description>
    <PackageTags>Avalonia;UI;Diagnostics;MCP;LuminaUI</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <ProjectReference Include="..\LuminaUI.Diagnostics.Abstractions\LuminaUI.Diagnostics.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="LuminaUI.Diagnostics.Tests" />
  </ItemGroup>

</Project>
